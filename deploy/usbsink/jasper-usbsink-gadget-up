#!/usr/bin/env bash
# Bring up the Jasper USB Audio Class 2 gadget descriptor in ConfigFS.
#
# Runs once at jasper-usbsink-init.service start. The dtoverlay
# `dwc2,dr_mode=peripheral` (added to /boot/firmware/config.txt by
# install.sh) puts the BCM2712 OTG controller into peripheral mode at
# boot; this script writes the ConfigFS tree that exposes the speaker to a
# connected host as a USB audio output device.
#
# Idempotent: if the gadget directory already exists, exits 0 without
# touching it. The teardown script (jasper-usbsink-gadget-down) clears
# the tree; the next start re-creates it cleanly.
#
# Adapted from PiCorrect's setup.sh:68-123. The JTS-specific changes:
# - Manufacturer / product strings rebranded to Jasper
# - Tagged paths under /sys/kernel/config/usb_gadget/jts-usb-audio
# - libcomposite is modprobed by the systemd unit's ExecStartPre, not
#   here, so the script itself stays minimal and side-effect-free
#   beyond ConfigFS writes
#
# Reference: Linux Documentation/usb/gadget-testing.txt (UAC2 section).
# See docs/HANDOFF-usbsink.md for the full design.
set -euo pipefail

CONFIGFS=/sys/kernel/config
NAME=jts-usb-audio
GADGET_DIR="${CONFIGFS}/usb_gadget/${NAME}"
SPEAKER_NAME_FILE="${JASPER_SPEAKER_NAME_FILE:-/var/lib/jasper/speaker_name.env}"

if [[ -r "$SPEAKER_NAME_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$SPEAKER_NAME_FILE" 2>/dev/null || true
fi
SPEAKER_NAME="${JASPER_SPEAKER_NAME:-JTS}"

# Idempotent: if descriptor exists AND is bound to a UDC, we're done.
# (If a partial setup left an unbound descriptor, the down script
# clears it before this runs again — see ExecStop in the unit file.)
if [[ -d "${GADGET_DIR}" ]]; then
    bound_udc=$(cat "${GADGET_DIR}/UDC" 2>/dev/null || true)
    if [[ -n "${bound_udc}" ]]; then
        echo "jasper-usbsink-gadget-up: ${NAME} already configured and bound to ${bound_udc}"
        exit 0
    fi
    echo "jasper-usbsink-gadget-up: ${NAME} exists but not bound; clearing before re-create"
    "$(dirname "$0")/jasper-usbsink-gadget-down" || true
fi

if [[ ! -d "${CONFIGFS}" ]]; then
    echo "jasper-usbsink-gadget-up: ${CONFIGFS} not mounted (kernel CONFIG_USB_CONFIGFS missing?)" >&2
    exit 1
fi

cd "${CONFIGFS}/usb_gadget"
mkdir "${NAME}"
cd "${NAME}"

# USB device identifiers. Linux Foundation VID + Multifunction
# Composite PID is the "no commercial vendor ID needed" convention used
# by every libcomposite example in the kernel docs. Hosts disambiguate
# multiple JTS units by serial.
echo 0x1d6b > idVendor    # Linux Foundation
echo 0x0104 > idProduct   # Multifunction Composite Gadget
echo 0x0100 > bcdDevice   # JTS firmware revision 1.00
echo 0x0200 > bcdUSB      # USB 2.0

# Device strings (English / 0x409). The serial is sourced from the
# Pi's CPU serial so a host pairing multiple JTS units doesn't see
# them as the same device.
mkdir -p strings/0x409
SERIAL=$(awk -F': ' '/^Serial/{print $2; exit}' /proc/cpuinfo 2>/dev/null || true)
echo "${SERIAL:-jts-unknown}" > strings/0x409/serialnumber
echo "Jasper Tech Speaker" > strings/0x409/manufacturer
echo "${SPEAKER_NAME} USB Audio" > strings/0x409/product

# Configuration descriptor. One configuration, named "c.1", holding
# the single UAC2 function. MaxPower in mA — 500 mA matches the USB
# 2.0 default; we draw power separately via the 8086 splitter, so this
# is informational only.
mkdir -p configs/c.1/strings/0x409
echo "${SPEAKER_NAME} USB Audio Configuration" > configs/c.1/strings/0x409/configuration
echo 500 > configs/c.1/MaxPower

# UAC2 function. JTS is unidirectional: host sends audio TO the Pi
# (host playback = device capture in UAC2 terminology). No reverse
# direction (Pi-to-host capture endpoint) — would require p_chmask
# != 0, which we explicitly leave at 0.
#
#   c_srate=48000   sample rate matches snd-aloop + the Apple dongle
#   c_ssize=4       32-bit samples (S32_LE)
#   c_chmask=3      stereo (bit 0 = L, bit 1 = R)
#   c_volume_present=1, c_mute_present=1   exposes Volume Control Unit
#                   + mute switch to the host, so the host's slider
#                   shows as a real control rather than greyed out.
#                   ALSA surfaces these on the Pi side as
#                   "PCM Capture Volume" / "PCM Capture Switch" mixer
#                   elements, which jasper-usbsink observes for the
#                   volume bridge.
#   p_chmask=0      no playback endpoint (host cannot record FROM us)
mkdir -p functions/uac2.usb0
echo 48000 > functions/uac2.usb0/c_srate
echo 4 > functions/uac2.usb0/c_ssize
echo 3 > functions/uac2.usb0/c_chmask
echo 1 > functions/uac2.usb0/c_volume_present
echo 1 > functions/uac2.usb0/c_mute_present
echo 0 > functions/uac2.usb0/p_chmask
echo "JTS Capture Endpoint" > functions/uac2.usb0/function_name
echo "JTS Capture Input" > functions/uac2.usb0/c_it_name
echo "JTS Capture Output" > functions/uac2.usb0/c_ot_name
echo "JTS Volume" > functions/uac2.usb0/c_fu_vol_name

# Link function into the configuration so the gadget framework knows
# what interfaces to expose.
ln -s functions/uac2.usb0 configs/c.1/

# Bind to the UDC driver. There's only one OTG controller on the BCM2712
# (dwc2). Listing /sys/class/udc returns its name (e.g. "3f980000.usb"
# or similar — the exact value depends on the device tree).
UDC=$(ls /sys/class/udc 2>/dev/null | head -n1 || true)
if [[ -z "${UDC}" ]]; then
    echo "jasper-usbsink-gadget-up: no UDC available under /sys/class/udc — " \
         "is dwc2 loaded and the dtoverlay set?" >&2
    exit 1
fi
echo "${UDC}" > UDC

echo "jasper-usbsink-gadget-up: ${NAME} bound to UDC ${UDC}"
