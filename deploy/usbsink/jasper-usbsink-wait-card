#!/usr/bin/env bash
# Poll for /proc/asound/UAC2Gadget to appear after the UDC bind.
#
# Writing to ConfigFS/UDC returns before the kernel finishes
# registering the ALSA card — typically <500 ms on a Pi 5, but with
# enough jitter that fan-in can race the card's existence and fail to open its
# direct capture device. Runs as jasper-usbsink.service's ExecStartPre so the
# lifecycle readiness marker becomes active only after ALSA is genuinely ready.
# (It moved here from the retired jasper-usbsink-init unit: the composite
# gadget owner now also carries the always-on USB network and must not
# block on a card that only exists when the uac2 audio function is composed.)
#
# Argument: timeout in seconds (default 30). Returns 0 if the card
# appears, non-zero on timeout.
#
# PiCorrect uses the same pattern in setup.sh — 30 s is more than
# enough; failure here usually indicates libcomposite didn't load or
# the UDC bind failed silently, and we want a clear timeout rather
# than publishing readiness before fan-in can capture the card.
set -euo pipefail

TIMEOUT="${1:-30}"
CARD_PROC=/proc/asound/UAC2Gadget

elapsed=0
while [[ "${elapsed}" -lt "${TIMEOUT}" ]]; do
    if [[ -d "${CARD_PROC}" ]]; then
        echo "jasper-usbsink-wait-card: ${CARD_PROC} present after ${elapsed}s"
        exit 0
    fi
    sleep 1
    elapsed=$((elapsed + 1))
done

echo "jasper-usbsink-wait-card: ${CARD_PROC} did not appear within ${TIMEOUT}s" >&2
echo "  Check: lsmod | grep libcomposite (should be loaded)" >&2
echo "         ls /sys/class/udc (should list one entry)" >&2
echo "         cat /sys/kernel/config/usb_gadget/jts-usb-audio/UDC " \
     "(should match the udc entry, not be empty)" >&2
exit 1
