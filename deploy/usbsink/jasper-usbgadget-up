#!/usr/bin/env bash
# Bring up the Jasper composite USB gadget descriptor in ConfigFS.
#
# The gadget carries up to two functions:
#   - ncm.usb0  — a USB management NETWORK link (default-on where the resolved
#     hardware transport is available): a
#     laptop plugged into the Pi's USB-C port gets an IP link to the Pi so
#     http://<hostname>/ works even with Wi-Fi off. See
#     docs/HANDOFF-usb-gadget.md.
#   - uac2.usb0 — USB AUDIO. The host-to-Pi direction is the wizard-toggled
#     jasper-usbsink source. When the separate /wake USB-microphone intent is
#     enabled, the same function also advertises a mono Pi-to-host direction.
#     The default microphone-Off attribute block remains byte-identical to the
#     pre-composite gadget (a low-latency contract — see
#     docs/HANDOFF-usb-low-latency.md and the doctor's
#     check_usbsink_low_latency_contract).
#
# Runs at jasper-usbgadget.service start (oneshot + RemainAfterExit).
# libcomposite is modprobed by the systemd unit's ExecStartPre, not here,
# so this script stays side-effect-free beyond ConfigFS writes.
#
# NAMING DEBT: the ConfigFS gadget dir name stays `jts-usb-audio` even
# though the gadget is no longer audio-only — the doctor's low-latency
# contract check reads that exact path, and renaming it would break the
# byte-identical attribute contract. Accepted debt; see the HANDOFF.
#
# Idempotent: if the descriptor already exists AND is bound to a UDC, exits
# 0 without touching it. A partial (unbound) descriptor is torn down and
# rebuilt. The function truth table is computed once and logged as a
# structured `event=usb_gadget.compose` line.
#
# Testability: the ConfigFS root, UDC class dir, canonical audio-allowed probe,
# and derived-lifecycle-readiness probe are overridable via env (defaults are
# the real paths), so
# pytest can drive this hermetically against a temp dir — see
# tests/test_usbgadget_script.py. Overriding them does NOT change runtime
# behavior on a real Pi (the defaults are the production values).
#
# Reference: Linux Documentation/usb/gadget-testing.txt (UAC2 + NCM).
set -euo pipefail
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

CONFIGFS="${JASPER_CONFIGFS_ROOT:-/sys/kernel/config}"
UDC_CLASS_DIR="${JASPER_UDC_CLASS_DIR:-/sys/class/udc}"
CPUINFO="${JASPER_CPUINFO_FILE:-/proc/cpuinfo}"
NAME=jts-usb-audio
GADGET_DIR="${CONFIGFS}/usb_gadget/${NAME}"
SPEAKER_NAME_FILE="${JASPER_SPEAKER_NAME_FILE:-/var/lib/jasper/speaker_name.env}"
SPEAKER_NAME_READER="${JASPER_SPEAKER_NAME_READER:-/opt/jasper/.venv/bin/python}"

# Injectable probes. The canonical source-aware start guard authorizes audio
# from current household intent plus role. The derived unit enablement is a
# separate readiness mirror: it can suppress audio after a failed/stale On
# transition, but can never override canonical Off or follower parking.
# Overridable so tests can drive every row of the truth table without systemd.
AUDIO_ALLOWED_CMD="${JASPER_USBGADGET_AUDIO_ALLOWED_CMD:-/opt/jasper/.venv/bin/jasper-local-source-allowed --source usbsink}"
AUDIO_READY_CMD="${JASPER_USBGADGET_AUDIO_READY_CMD:-systemctl is-enabled --quiet jasper-usbsink.service}"
AUDIO_DATA_READY_CMD="${JASPER_USBGADGET_AUDIO_DATA_READY_CMD:-/opt/jasper/.venv/bin/python -m jasper.fanin.status --usbsink-direct-armed}"
HARDWARE_ALLOWED_CMD="${JASPER_USBGADGET_HARDWARE_ALLOWED_CMD:-/opt/jasper/.venv/bin/python -m jasper.audio_hardware.usb_port_role --require-management-transport}"
USB_MIC_ENABLED_CMD="${JASPER_USBGADGET_USB_MIC_ENABLED_CMD:-/opt/jasper/.venv/bin/python -m jasper.usb_mic --check-intent}"

log() {
    echo "jasper-usbgadget-up: $*"
}

emit() {
    # Structured single-line event for journal grep (the wifi-guardian idiom).
    # `$1` is the outcome suffix on `event=usb_gadget.`; `$2` is the kv tail.
    if [[ -n "${2:-}" ]]; then
        printf 'event=usb_gadget.%s %s\n' "$1" "$2" >&2
    else
        printf 'event=usb_gadget.%s\n' "$1" >&2
    fi
}

if ! ${HARDWARE_ALLOWED_CMD}; then
    emit skip "reason=hardware_unavailable where=up"
    "$(dirname "$0")/jasper-usbgadget-down" || true
    exit 0
fi

SPEAKER_NAME="JTS"

# Management-writable identity state is untrusted at this root boundary.
# The canonical Python reader owns env quoting plus the 32-character,
# printable-name policy. Never source/eval/pre-read the path or copy its raw
# value into ConfigFS strings / structured logs. The reader performs one
# descriptor-held, no-follow, nonblocking, 64 KiB-capped read so FIFO/symlink/
# replacement races fail safely to JTS.
canonical_name="$("${SPEAKER_NAME_READER}" -m jasper.speaker_name "${SPEAKER_NAME_FILE}" 2>/dev/null || true)"
if [[ -n "${canonical_name}" ]]; then
    SPEAKER_NAME="${canonical_name}"
fi
MIC_NAME="${SPEAKER_NAME} Mic"

write_if_present() {
    local path="$1"
    local value="$2"
    if [[ -e "${path}" ]]; then
        echo "${value}" > "${path}"
    fi
}

# ---- Function truth table (computed once) ----------------------------------
#
# network is on unless the kill switch is the exact literal `disabled`
# (case-insensitive; any other value logs a warning and stays enabled —
# mirrors JASPER_SHAIRPORT_SUPERVISOR). Audio is on only when canonical
# /sources intent + role authorize it, the derived usbsink unit is enabled,
# AND live fan-in STATUS proves the DIRECT consumer is armed.
#
#   network  audio            functions
#   -------  ---------------  ----------------------
#   on       on               ncm.usb0 + uac2.usb0
#   on       off/parked       ncm.usb0
#   off      on               uac2.usb0  (legacy shape)
#   off      off              none  (ExecCondition already skipped the unit)

net_raw="${JASPER_USB_NETWORK:-enabled}"
# Lowercase via tr (portable across bash 3.2/5.x; ${var,,} is bash 4+ only).
net_lc="$(printf '%s' "${net_raw}" | tr '[:upper:]' '[:lower:]')"
WANT_NETWORK=1
if [[ "${net_lc}" == "disabled" ]]; then
    WANT_NETWORK=0
elif [[ "${net_lc}" != "enabled" && -n "${net_lc}" ]]; then
    log "WARN JASPER_USB_NETWORK=${net_raw} is not 'enabled'/'disabled'; staying enabled" >&2
fi

WANT_AUDIO=0
audio_reason="intent_disabled_or_parked"
if ${AUDIO_ALLOWED_CMD} >/dev/null 2>&1; then
    audio_reason="derived_unit_disabled"
    if ${AUDIO_READY_CMD} >/dev/null 2>&1; then
        audio_reason="direct_lane_unarmed"
        if ${AUDIO_DATA_READY_CMD} >/dev/null 2>&1; then
            WANT_AUDIO=1
            audio_reason="enabled_direct_ready"
        fi
    fi
fi

# The return microphone is deliberately a refinement of the existing UAC2
# source in this first slice. It can never create an audio function on its own:
# USB Audio Input must already be authorized, armed, and ready above.
WANT_USB_MIC=0
if [[ "${WANT_AUDIO}" == "1" ]] && ${USB_MIC_ENABLED_CMD} >/dev/null 2>&1; then
    WANT_USB_MIC=1
fi

emit compose \
    "network=${WANT_NETWORK} audio=${WANT_AUDIO} usb_mic=${WANT_USB_MIC} net_intent=${net_lc:-enabled} audio_reason=${audio_reason}"

if [[ "${WANT_NETWORK}" == "0" && "${WANT_AUDIO}" == "0" ]]; then
    # Nothing to compose. The unit's ExecCondition (jasper-usbgadget-wanted)
    # normally skips the unit in this state, so reaching here means an operator
    # started it by hand — tear any stale descriptor down and exit clean so we
    # never publish an empty gadget.
    emit skip "reason=no_function_wanted"
    "$(dirname "$0")/jasper-usbgadget-down" || true
    exit 0
fi

# ---- Idempotency: bound descriptor => done ---------------------------------

if [[ -d "${GADGET_DIR}" ]]; then
    bound_udc=$(cat "${GADGET_DIR}/UDC" 2>/dev/null || true)
    if [[ -n "${bound_udc}" ]]; then
        log "${NAME} already configured and bound to ${bound_udc}"
        emit up "state=already_bound udc=${bound_udc}"
        exit 0
    fi
    log "${NAME} exists but not bound; clearing before re-create"
    "$(dirname "$0")/jasper-usbgadget-down" || true
fi

if [[ ! -d "${CONFIGFS}" ]]; then
    log "${CONFIGFS} not mounted (kernel CONFIG_USB_CONFIGFS missing?)" >&2
    emit skip "reason=no_configfs"
    exit 1
fi

cd "${CONFIGFS}/usb_gadget"
mkdir "${NAME}"
cd "${NAME}"

# USB device identifiers. Linux Foundation VID + Multifunction Composite PID
# is the "no commercial vendor ID needed" convention. bcdDevice bumped
# 0x0100 -> 0x0200 with the composite change so hosts that cache descriptors
# by VID:PID:bcdDevice re-read the new function set. HARDWARE-VERIFY: confirm
# the host re-enumerates on the bump.
echo 0x1d6b > idVendor    # Linux Foundation
echo 0x0104 > idProduct   # Multifunction Composite Gadget
if [[ "${WANT_USB_MIC}" == "1" ]]; then
    # Stable descriptor revision for the bidirectional audio shape. macOS
    # caches by VID:PID:bcdDevice, so On and Off intentionally differ.
    echo 0x0210 > bcdDevice
else
    echo 0x0200 > bcdDevice   # JTS revision 2.00 (no host microphone)
fi
echo 0x0200 > bcdUSB      # USB 2.0

# Device strings (English / 0x409). Serial is the Pi's CPU serial so a host
# pairing multiple JTS units doesn't see them as the same device — and it is
# ALSO the seed for the deterministic NCM MACs below. Product string is now
# just the speaker name (the gadget is no longer audio-only; the host-side
# audio label is owned by the name-patch, and the NIC label shouldn't say
# "USB Audio"). HARDWARE-VERIFY: host audio device label unchanged.
mkdir -p strings/0x409
SERIAL=$(awk -F': ' '/^Serial/{print $2; exit}' "${CPUINFO}" 2>/dev/null || true)
SERIAL="${SERIAL:-jts-unknown}"
echo "${SERIAL}" > strings/0x409/serialnumber
echo "Jasper Tech Speaker" > strings/0x409/manufacturer
echo "${SPEAKER_NAME}" > strings/0x409/product

# Configuration descriptor. One configuration "c.1" holding whichever
# functions are wanted. MaxPower is informational (we draw power via the
# 8086 splitter).
mkdir -p configs/c.1/strings/0x409
echo "${SPEAKER_NAME} Configuration" > configs/c.1/strings/0x409/configuration
echo 500 > configs/c.1/MaxPower

# ---- NCM network function --------------------------------------------------
#
# Deterministic, locally-administered MACs derived from the CPU serial. If the
# MACs were left at libcomposite's random default, the host would see a
# brand-new network adapter on every boot (new interface name, dropped
# routes/leases) — this determinism is load-bearing for "it just works". Two
# different speakers derive different MACs (different serials -> different
# hash). host_addr and dev_addr differ in the final byte so the two ends of
# the link never collide.
derive_mac() {
    # $1 = salt (distinguishes host vs dev). Emit a locally-administered
    # unicast MAC: first octet 0x02 (LAA bit set, multicast bit clear). The
    # remaining five octets come from a sha256 of serial+salt. Pure-shell
    # hashing via sha256sum (coreutils, always present on the Pi).
    local salt="$1" hash
    hash=$(printf '%s' "${SERIAL}-${salt}" | sha256sum | cut -c1-10)
    printf '02:%s:%s:%s:%s:%s' \
        "${hash:0:2}" "${hash:2:2}" "${hash:4:2}" "${hash:6:2}" "${hash:8:2}"
}

if [[ "${WANT_NETWORK}" == "1" ]]; then
    mkdir -p functions/ncm.usb0
    host_mac="$(derive_mac host)"
    dev_mac="$(derive_mac dev)"
    # host_addr/dev_addr always exist on an NCM function (unlike the
    # kernel-version-dependent uac2 low-latency attrs), so write them
    # unconditionally — the determinism is load-bearing.
    echo "${host_mac}" > functions/ncm.usb0/host_addr
    echo "${dev_mac}" > functions/ncm.usb0/dev_addr
    ln -s functions/ncm.usb0 configs/c.1/
    log "ncm.usb0 host_addr=${host_mac} dev_addr=${dev_mac}"
fi

# ---- UAC2 audio function ---------------------------------------------------
#
# The host-to-Pi side is byte-identical to the pre-composite gadget
# (low-latency contract, protection list). p_* is the Pi-to-host side: it stays
# disabled at p_chmask=0 unless the separate USB microphone intent is On.
if [[ "${WANT_AUDIO}" == "1" ]]; then
    mkdir -p functions/uac2.usb0
    echo 48000 > functions/uac2.usb0/c_srate
    echo 4 > functions/uac2.usb0/c_ssize
    echo 3 > functions/uac2.usb0/c_chmask
    echo 1 > functions/uac2.usb0/c_volume_present
    echo 1 > functions/uac2.usb0/c_mute_present
    # Advertised capture-volume range, in UAC2 1/256-dB units (the kernel
    # configfs unit for c_volume_*; see u_audio_volume_tlv "UAC volume
    # resolution is 1/256 dB"). We narrow it from the kernel's wide ~-128..0 dB
    # default to -50..0 dB so macOS tapers its slider POSITION over a range
    # aligned with JTS's own volume curve (jasper.volume_curve.percent_to_db's
    # -50 dB floor). WHY: a wide default compresses the whole Mac slider into
    # the top few dB, so a low-mid slider read ~73% on JTS (issue #1698).
    # WHAT: min=-12800 (-50 dB = -50*256), max=0 (0 dB), res=256 (1 dB step).
    # Bind-time validity requires (max-min) % res == 0: 12800 % 256 == 0 (50
    # steps). These are the codification of the range contract; the SINGLE
    # source of truth is jasper/usbsink/volume_bridge.py's
    # USBSINK_VOLUME_DB_{MIN,MAX}/STEP_DB constants, and a contract test in
    # tests/test_usbsink_volume_bridge.py pins these literals to round(const*256)
    # so bash and Python can't drift. The read side (_raw_to_pct) recovers
    # physical dB from the control's step index (via the DB_MINMAX TLV, this
    # range as fallback) then amplitude-normalizes. Best-effort via
    # write_if_present: older kernels may not expose these attrs, and a missing
    # attr must not fail gadget bring-up (the kernel default range then
    # applies). Keep the min at/above -60 dB so the slider bottom stays useful;
    # final feel needs an on-Mac slider check.
    write_if_present functions/uac2.usb0/c_volume_min -12800
    write_if_present functions/uac2.usb0/c_volume_max 0
    write_if_present functions/uac2.usb0/c_volume_res 256
    if [[ "${WANT_USB_MIC}" == "1" ]]; then
        echo 1 > functions/uac2.usb0/p_chmask
        write_if_present functions/uac2.usb0/p_srate 48000
        write_if_present functions/uac2.usb0/p_ssize 2
        write_if_present functions/uac2.usb0/p_hs_bint 1
        # USB terminal type 0x0201 = microphone.
        write_if_present functions/uac2.usb0/p_terminal_type 513
        write_if_present functions/uac2.usb0/p_it_name "${MIC_NAME}"
        write_if_present functions/uac2.usb0/p_ot_name "JTS USB Host"
    else
        echo 0 > functions/uac2.usb0/p_chmask
    fi
    # Low-latency route hints, only where the running kernel exposes them.
    write_if_present functions/uac2.usb0/c_sync async
    write_if_present functions/uac2.usb0/req_number 2
    write_if_present functions/uac2.usb0/c_hs_bint 1
    echo "JTS Capture Endpoint" > functions/uac2.usb0/function_name
    echo "JTS Capture Input" > functions/uac2.usb0/c_it_name
    echo "JTS Capture Output" > functions/uac2.usb0/c_ot_name
    echo "JTS Volume" > functions/uac2.usb0/c_fu_vol_name
    ln -s functions/uac2.usb0 configs/c.1/
    log "uac2.usb0 linked (USB audio input enabled, USB microphone=${WANT_USB_MIC})"
fi

# ---- Bind to the UDC -------------------------------------------------------
#
# One OTG controller on the BCM2712 (dwc2). The ExecCondition already ensured
# a UDC exists, but re-check for the operator-hand-start path.
UDC=$(ls "${UDC_CLASS_DIR}" 2>/dev/null | head -n1 || true)
if [[ -z "${UDC}" ]]; then
    log "no UDC available under ${UDC_CLASS_DIR} — is dwc2 loaded and the dtoverlay set?" >&2
    emit skip "reason=no_udc"
    exit 1
fi
echo "${UDC}" > UDC

log "${NAME} bound to UDC ${UDC}"
emit up "state=bound udc=${UDC} network=${WANT_NETWORK} audio=${WANT_AUDIO} usb_mic=${WANT_USB_MIC}"
