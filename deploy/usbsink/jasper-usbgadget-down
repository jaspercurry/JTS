#!/usr/bin/env bash
# Tear down the Jasper composite USB gadget descriptor.
#
# Best-effort: each step's failure is logged but doesn't abort the rest. A
# partially-broken descriptor (previous gadget-up died mid-way) should still
# get cleaned up enough that the next gadget-up can rebuild from scratch.
#
# Tears down BOTH functions generically (uac2.usb0 + ncm.usb0) — whichever
# were composed. Sequence:
#   1. Unbind from UDC (write empty string) — releases the gadget.
#   2. Remove every function symlink from the configuration.
#   3. rmdir the per-language strings, functions, and configuration.
#   4. rmdir the gadget directory itself (refuses if anything still bound —
#      the safety net we rely on).
#
# The systemd unit's ExecStopPost handles `rmmod` of the gadget/network
# modules separately — this script touches only ConfigFS state.
#
# The ConfigFS root is env-overridable (default the real path) so pytest can
# drive teardown hermetically; see tests/test_usbgadget_script.py.
set -uo pipefail

CONFIGFS="${JASPER_CONFIGFS_ROOT:-/sys/kernel/config}"
NAME=jts-usb-audio
GADGET_DIR="${CONFIGFS}/usb_gadget/${NAME}"

emit() {
    if [[ -n "${2:-}" ]]; then
        printf 'event=usb_gadget.%s %s\n' "$1" "$2" >&2
    else
        printf 'event=usb_gadget.%s\n' "$1" >&2
    fi
}

if [[ ! -d "${GADGET_DIR}" ]]; then
    echo "jasper-usbgadget-down: ${NAME} not present, nothing to do"
    exit 0
fi

# The dir exists (checked above); if the cd races a concurrent teardown and
# fails, there is nothing left to clean up.
cd "${GADGET_DIR}" || exit 0

# Unbind from UDC — writing an empty string releases the gadget. Must happen
# before we can remove the function symlinks.
if [[ -s UDC ]]; then
    bound_udc=$(cat UDC 2>/dev/null || true)
    if echo "" > UDC 2>/dev/null; then
        echo "jasper-usbgadget-down: unbound from UDC ${bound_udc}"
    else
        echo "jasper-usbgadget-down: WARN failed to unbind from UDC ${bound_udc}" >&2
    fi
fi

# Remove every function symlink from the configuration (either function may or
# may not be present in a given composition).
rm -f configs/c.1/uac2.usb0 configs/c.1/ncm.usb0 || true

# Strings.
rmdir configs/c.1/strings/0x409 2>/dev/null || true
rmdir strings/0x409 2>/dev/null || true

# Configuration and function objects (best-effort; absent ones no-op).
rmdir configs/c.1 2>/dev/null || true
rmdir functions/uac2.usb0 2>/dev/null || true
rmdir functions/ncm.usb0 2>/dev/null || true

# Finally the gadget directory itself. rmdir refuses if anything is still
# bound — that's the safety net.
cd /
if rmdir "${GADGET_DIR}" 2>/dev/null; then
    echo "jasper-usbgadget-down: ${NAME} torn down"
    emit down "state=torn_down"
else
    echo "jasper-usbgadget-down: WARN ${GADGET_DIR} did not rmdir cleanly " \
         "(something still bound?); next gadget-up will retry" >&2
    emit down "state=rmdir_failed"
fi
