[Unit]
Description=Jasper Bluetooth no-code pairing agent
Requires=bluetooth.service
After=bluetooth.service
# Safe to restart after transient Bluetooth/OOM churn; finite so a broken
# BlueZ stack does not spin forever.
StartLimitIntervalSec=600
StartLimitBurst=20

[Service]
Type=simple
# JTS is a headless speaker. Its single default BlueZ agent advertises
# NoInputNoOutput so pairing is no-code "Just Works"; PIN/passkey/numeric
# comparison flows are rejected as unsupported.
ExecCondition=/opt/jasper/.venv/bin/jasper-local-source-allowed
ExecStart=/opt/jasper/.venv/bin/jasper-bluetooth-agent
TimeoutStopSec=10s
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
