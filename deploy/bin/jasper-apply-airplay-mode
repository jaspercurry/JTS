#!/usr/bin/env bash
# jasper-apply-airplay-mode — render /etc/shairport-sync.conf from the
# template at /etc/shairport-sync.conf.template, substituting:
#   - disable_synchronization based on /var/lib/jasper/airplay_mode.env
#   - AirPlay device name based on JASPER_SPEAKER_NAME (in
#     /var/lib/jasper/speaker_name.env)
#   - audio_backend_latency_offset_in_seconds derived from the active
#     CamillaDSP config's samplerate/chunksize/target_level, the
#     fan-in output buffer, jasper-outputd's optional content bridge,
#     plus jasper-outputd's DAC buffer; AND, only while this speaker is
#     an active bonded leader, the Snapcast round-trip playout buffer
#     (JASPER_AIRPLAY_BONDED_EXTRA_DELAY_SEC, written by
#     jasper-grouping-reconcile). Absent on solo/follower => unchanged.
#   - output_device fixed to `shairport_substream`, AirPlay's private
#     fan-in lane
#
# Invoked from three places:
#   1. shairport-sync.service ExecStartPre (so every restart picks up
#      the current mode).
#   2. install.sh (so a fresh install lands with the conf rendered).
#   3. jasper-airplay-mode CLI and the /airplay/ web UI, after they
#      update the env file and before they restart shairport.
#
# Env input:
#   JASPER_AIRPLAY_FREE_RUNNING — "yes" / "no". Default: "no".
#   JASPER_SPEAKER_NAME         — display name shown in renderer pickers.
#                                 Default: JTS.
#   JASPER_CAMILLA_STATEFILE    — CamillaDSP statefile path.
#                                 Default: /var/lib/camilladsp/outputd-statefile.yml.
#   JASPER_CAMILLA_DEFAULT_CONFIG — fallback CamillaDSP config path.
#                                   Default: /etc/camilladsp/outputd-cutover.yml.
#   JASPER_FANIN_ENV_FILE       — optional fan-in env file used to
#                                 source JASPER_FANIN_OUTPUT_BUFFER_FRAMES.
#                                 Default: /var/lib/jasper/fanin.env.
#   JASPER_OUTPUTD_ENV_FILE     — optional outputd retune file used to
#                                 read JASPER_OUTPUTD_DAC_BUFFER_FRAMES
#                                 and content-bridge latency knobs. The
#                                 renderer intentionally ignores
#                                 outputd knobs from /etc/jasper/jasper.env
#                                 and the process environment because the
#                                 outputd unit overrides those with
#                                 packaged defaults before loading this
#                                 retune file.
#                                 Default: /var/lib/jasper/outputd.env.
#   JASPER_GROUPING_AIRPLAY_ENV_FILE — optional reconciler-owned file
#                                 carrying JASPER_AIRPLAY_BONDED_EXTRA_DELAY_SEC,
#                                 the bonded-leader Snapcast round-trip
#                                 delay folded into the offset. Absent on
#                                 solo/follower (the common case) => the
#                                 offset is byte-identical to before.
#                                 Default: /var/lib/jasper/grouping-airplay.env.
# File outputs:
#   /etc/shairport-sync.conf — atomic write via /etc/shairport-sync.conf.tmp.
#
# Exits 0 on success. Logs to stderr.

set -euo pipefail

TEMPLATE="${JASPER_SHAIRPORT_TEMPLATE:-/etc/shairport-sync.conf.template}"
TARGET="${JASPER_SHAIRPORT_CONF:-/etc/shairport-sync.conf}"
ENV_FILE="${JASPER_AIRPLAY_MODE_ENV:-/var/lib/jasper/airplay_mode.env}"
JASPER_ENV_FILE="${JASPER_ENV_FILE:-/etc/jasper/jasper.env}"
SPEAKER_NAME_FILE="${JASPER_SPEAKER_NAME_FILE:-/var/lib/jasper/speaker_name.env}"
CAMILLA_STATEFILE="${JASPER_CAMILLA_STATEFILE:-/var/lib/camilladsp/outputd-statefile.yml}"
CAMILLA_DEFAULT_CONFIG="${JASPER_CAMILLA_DEFAULT_CONFIG:-/etc/camilladsp/outputd-cutover.yml}"
FANIN_ENV_FILE="${JASPER_FANIN_ENV_FILE:-/var/lib/jasper/fanin.env}"
OUTPUTD_ENV_FILE="${JASPER_OUTPUTD_ENV_FILE:-/var/lib/jasper/outputd.env}"
# Reconciler-owned env file (jasper-grouping-reconcile) carrying the
# bonded-leader AirPlay offset delta. ABSENT/empty on solo + followers,
# so a non-bonded speaker derives the byte-identical solo offset.
GROUPING_AIRPLAY_ENV_FILE="${JASPER_GROUPING_AIRPLAY_ENV_FILE:-/var/lib/jasper/grouping-airplay.env}"
DEFAULT_OUTPUTD_DAC_BUFFER_FRAMES=3072
DEFAULT_OUTPUTD_CONTENT_BRIDGE_TARGET_FRAMES=4096

if [[ ! -f "$TEMPLATE" ]]; then
    echo "jasper-apply-airplay-mode: template missing at $TEMPLATE" >&2
    exit 1
fi

camilla_config_path() {
    local configured=""
    if [[ -r "$CAMILLA_STATEFILE" ]]; then
        configured="$(
            awk '
                /^[[:space:]]*config_path[[:space:]]*:/ {
                    sub(/^[^:]*:[[:space:]]*/, "")
                    sub(/[[:space:]]*$/, "")
                    print
                    exit
                }
            ' "$CAMILLA_STATEFILE"
        )"
    fi

    if [[ -n "$configured" && -r "$configured" ]]; then
        printf '%s\n' "$configured"
    else
        printf '%s\n' "$CAMILLA_DEFAULT_CONFIG"
    fi
}

camilla_devices_int() {
    local config="$1"
    local key="$2"
    awk -v key="$key" '
        /^[[:space:]]*devices:[[:space:]]*($|#)/ {
            in_devices = 1
            next
        }
        in_devices && /^[^[:space:]#][^:]*:[[:space:]]*($|#)/ {
            exit
        }
        in_devices {
            line = $0
            sub(/[[:space:]]*#.*/, "", line)
            pattern = "^[[:space:]]*" key "[[:space:]]*:[[:space:]]*"
            if (line ~ pattern) {
                sub(pattern, "", line)
                sub(/[[:space:]]*$/, "", line)
                if (line ~ /^[0-9]+$/) {
                    print line
                    exit
                }
            }
        }
    ' "$config"
}

fanin_output_buffer_frames() {
    local value="${JASPER_FANIN_OUTPUT_BUFFER_FRAMES:-}"
    if [[ -z "$value" && -r "$FANIN_ENV_FILE" ]]; then
        value="$(
            awk -F= '
                /^[[:space:]]*JASPER_FANIN_OUTPUT_BUFFER_FRAMES[[:space:]]*=/ {
                    sub(/^[^=]*=[[:space:]]*/, "")
                    sub(/[[:space:]]*(#.*)?$/, "")
                    print
                    exit
                }
            ' "$FANIN_ENV_FILE"
        )"
    fi
    value="${value//[[:space:]]/}"
    value="${value%\"}"
    value="${value#\"}"
    value="${value%\'}"
    value="${value#\'}"
    if [[ "$value" =~ ^[0-9]+$ ]]; then
        printf '%s\n' "$value"
    else
        printf '3072\n'
    fi
}

env_file_value() {
    local file="$1"
    local key="$2"
    [[ -r "$file" ]] || return 0
    awk -F= -v key="$key" '
        $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
            sub(/^[^=]*=[[:space:]]*/, "")
            sub(/[[:space:]]*(#.*)?$/, "")
            print
            exit
        }
    ' "$file"
}

positive_int_or_default() {
    local value="$1"
    local default="$2"
    value="${value//[[:space:]]/}"
    value="${value%\"}"
    value="${value#\"}"
    value="${value%\'}"
    value="${value#\'}"
    if [[ "$value" =~ ^[0-9]+$ && "$value" -gt 0 ]]; then
        printf '%s\n' "$value"
    else
        printf '%s\n' "$default"
    fi
}

outputd_dac_buffer_frames() {
    local value
    value="$(env_file_value "$OUTPUTD_ENV_FILE" JASPER_OUTPUTD_DAC_BUFFER_FRAMES || true)"
    positive_int_or_default "$value" "$DEFAULT_OUTPUTD_DAC_BUFFER_FRAMES"
}

outputd_content_bridge_mode() {
    local raw
    local value
    raw="$(env_file_value "$OUTPUTD_ENV_FILE" JASPER_OUTPUTD_CONTENT_BRIDGE || true)"
    value="$raw"
    value="${value//[[:space:]]/}"
    value="${value%\"}"
    value="${value#\"}"
    value="${value%\'}"
    value="${value#\'}"
    value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
    case "$value" in
        ""|direct|off|disabled)
            printf 'direct\n'
            ;;
        rate_match|ratematch|rate-matched|rate_matched)
            printf 'rate_match\n'
            ;;
        *)
            echo "jasper-apply-airplay-mode: invalid JASPER_OUTPUTD_CONTENT_BRIDGE='$raw'; using direct latency term" >&2
            printf 'direct\n'
            ;;
    esac
}

outputd_content_bridge_target_frames() {
    local value
    value="$(env_file_value "$OUTPUTD_ENV_FILE" JASPER_OUTPUTD_CONTENT_BRIDGE_TARGET_FRAMES || true)"
    positive_int_or_default "$value" "$DEFAULT_OUTPUTD_CONTENT_BRIDGE_TARGET_FRAMES"
}

outputd_content_bridge_latency_frames() {
    if [[ "$(outputd_content_bridge_mode)" == "rate_match" ]]; then
        outputd_content_bridge_target_frames
    else
        printf '0\n'
    fi
}

bonded_extra_delay_sec() {
    # Extra fixed downstream delay (SECONDS) to fold into the offset while
    # this speaker is an active bonded LEADER: the Snapcast round-trip
    # playout buffer its own output gains over solo. Written by
    # jasper-grouping-reconcile into GROUPING_AIRPLAY_ENV_FILE as
    # JASPER_AIRPLAY_BONDED_EXTRA_DELAY_SEC. ABSENT/empty on solo and
    # followers => 0.0 => byte-identical solo offset. A non-numeric or
    # negative value is ignored (0.0) so a bad write can never advance
    # playout PAST the anchor (a worse desync than the lag we correct).
    local value
    value="$(env_file_value "$GROUPING_AIRPLAY_ENV_FILE" \
        JASPER_AIRPLAY_BONDED_EXTRA_DELAY_SEC || true)"
    value="${value//[[:space:]]/}"
    value="${value%\"}"
    value="${value#\"}"
    value="${value%\'}"
    value="${value#\'}"
    if [[ "$value" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        printf '%s\n' "$value"
    else
        printf '0.0\n'
    fi
}

derive_audio_backend_latency_offset() {
    local config
    local sample_rate
    local chunksize
    local target_level
    local fanin_output_buffer
    local outputd_content_bridge
    local outputd_dac_buffer
    local bonded_extra_sec

    config="$(camilla_config_path)"
    if [[ ! -r "$config" ]]; then
        echo "jasper-apply-airplay-mode: Camilla config missing at $config; using latency offset 0.0" >&2
        printf '0.000000'
        return
    fi

    sample_rate="$(camilla_devices_int "$config" samplerate || true)"
    chunksize="$(camilla_devices_int "$config" chunksize || true)"
    target_level="$(camilla_devices_int "$config" target_level || true)"

    if [[ -z "$sample_rate" || -z "$chunksize" ]]; then
        echo "jasper-apply-airplay-mode: could not read samplerate/chunksize from $config; using latency offset 0.0" >&2
        printf '0.000000'
        return
    fi

    # CamillaDSP defaults target_level to chunksize when target_level is
    # absent. The AirPlay offset compensates only the added fixed backend
    # delay above that implicit one-chunk baseline.
    if [[ -z "$target_level" ]]; then
        target_level="$chunksize"
    fi

    # Fan-in output queue (between jasper-fanin and CamillaDSP/AEC).
    # This is downstream of shairport's private input lane, so it is
    # also invisible to shairport's snd_pcm_delay().
    fanin_output_buffer="$(fanin_output_buffer_frames)"

    # outputd's optional content bridge intentionally holds post-Camilla
    # content at a target fill before the DAC-paced final mix. This is
    # invisible to shairport's private lane and must be compensated when
    # lab mode enables the bridge.
    outputd_content_bridge="$(outputd_content_bridge_latency_frames)"

    # outputd's DAC buffer is downstream of shairport's private lane
    # and of CamillaDSP. shairport cannot observe it via
    # snd_pcm_delay(), so account for the branch-owned output owner
    # explicitly.
    outputd_dac_buffer="$(outputd_dac_buffer_frames)"

    # Bonded-leader-only extra delay (seconds): the Snapcast round-trip
    # playout buffer. 0.0 unless jasper-grouping-reconcile wrote it for an
    # active bonded leader, so solo + follower offsets are unchanged.
    bonded_extra_sec="$(bonded_extra_delay_sec)"

    awk -v sample_rate="$sample_rate" \
        -v chunksize="$chunksize" \
        -v target_level="$target_level" \
        -v fanin_output_buffer="$fanin_output_buffer" \
        -v outputd_content_bridge="$outputd_content_bridge" \
        -v outputd_dac_buffer="$outputd_dac_buffer" \
        -v bonded_extra_sec="$bonded_extra_sec" '
        BEGIN {
            if (sample_rate <= 0) {
                printf "0.000000"
                exit
            }
            # Total invisible-to-shairport delay budget in frames:
            #   (target_level - chunksize)   ← CamillaDSP playback buffer
            #                                   above its implicit one-chunk
            #                                   baseline.
            #   + fanin_output_buffer        ← jasper-fanin output queue
            #                                   between the private AirPlay
            #                                   lane and CamillaDSP/AEC.
            #   + outputd_content_bridge     ← optional jasper-outputd
            #                                   content bridge target fill.
            #   + outputd_dac_buffer         ← jasper-outputd direct-DAC
            #                                   playback queue.
            #
            # NB: any single-quote (apostrophe) in this comment block would
            # close the surrounding awk single-quoted string and break
            # the script — bash 2026-05-25 lesson, do not paraphrase.
            # shairport feeds this many frames early so audio still emerges
            # from the speaker at the AirPlay-scheduled time.
            invisible_frames = (target_level - chunksize) + fanin_output_buffer + outputd_content_bridge + outputd_dac_buffer
            # bonded_extra_sec is a wall-clock buffer (the Snapcast round-
            # trip on a bonded leader), added in seconds; 0 on solo.
            offset = -((invisible_frames / sample_rate) + bonded_extra_sec)
            if ((offset > -0.0000005) && (offset < 0.0000005)) {
                offset = 0
            }
            printf "%.6f", offset
        }
    '
}

# Source the airplay_mode.env file if it exists. Default the variable
# AFTER sourcing so an explicit-but-empty value still falls back to the
# safe default.
if [[ -f "$ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$ENV_FILE" 2>/dev/null || true
fi
renderer_device="shairport_substream"
# Also source jasper.env (mode 0640, readable by root only — this
# script runs with the leading `+` privilege escalation from
# shairport-sync.service's ExecStartPre, so root-read is fine).
if [[ -r "$JASPER_ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$JASPER_ENV_FILE" 2>/dev/null || true
fi
if [[ -r "$SPEAKER_NAME_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$SPEAKER_NAME_FILE" 2>/dev/null || true
fi
mode="${JASPER_AIRPLAY_FREE_RUNNING:-no}"

airplay_name="${JASPER_SPEAKER_NAME:-JTS}"

case "$mode" in
    yes|YES|true|TRUE|1)
        disable_sync="yes"
        human="free-running (music-only, no A/V or multi-room sync)"
        ;;
    no|NO|false|FALSE|0)
        disable_sync="no"
        human="synced (matches AirPlay sender clock; needed for video A/V sync or multi-room)"
        ;;
    *)
        echo "jasper-apply-airplay-mode: invalid JASPER_AIRPLAY_FREE_RUNNING='$mode'; defaulting to no" >&2
        disable_sync="no"
        human="synced (defaulted from invalid value)"
        ;;
esac

latency_offset="$(derive_audio_backend_latency_offset)"
airplay_name_sed="$(printf '%s' "$airplay_name" | sed -e 's/[\/&]/\\&/g')"

tmp="${TARGET}.tmp.$$"
trap 'rm -f "$tmp"' EXIT

sed -e "s/__DISABLE_SYNCHRONIZATION__/${disable_sync}/g" \
    -e "s/__AIRPLAY_NAME__/${airplay_name_sed}/g" \
    -e "s/__AUDIO_BACKEND_LATENCY_OFFSET_SECONDS__/${latency_offset}/g" \
    -e "s/__RENDERER_DEVICE__/${renderer_device}/g" \
    "$TEMPLATE" > "$tmp"

# Validate the substitution actually happened — refuse to install a
# conf that still contains a placeholder (something went wrong with
# the template or the sed). shairport would otherwise fail to parse it
# and crash-loop.
if grep -qE "__DISABLE_SYNCHRONIZATION__|__AIRPLAY_NAME__|__AUDIO_BACKEND_LATENCY_OFFSET_SECONDS__|__RENDERER_DEVICE__" "$tmp"; then
    echo "jasper-apply-airplay-mode: placeholder still present in rendered conf — refusing to install" >&2
    exit 2
fi

chmod 0644 "$tmp"
mv -f "$tmp" "$TARGET"
trap - EXIT

echo "jasper-apply-airplay-mode: $TARGET rendered for mode $human, name '$airplay_name', renderer device '$renderer_device', latency offset ${latency_offset}s" >&2
