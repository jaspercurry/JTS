#!/usr/bin/env bash
# jasper-apply-airplay-mode — render /etc/shairport-sync.conf from the
# template at /etc/shairport-sync.conf.template, substituting:
#   - disable_synchronization based on /var/lib/jasper/airplay_mode.env
#   - AirPlay device name based on JASPER_AIRPLAY_DEVICE_NAME (in
#     /etc/jasper/jasper.env)
#   - audio_backend_latency_offset_in_seconds derived from the active
#     CamillaDSP config's samplerate/chunksize/target_level PLUS the
#     pcm.jasper_renderer_mix dmix buffer in /etc/asound.conf
#   - output_device based on JASPER_AUDIO_TOPOLOGY (in
#     /var/lib/jasper/audio_topology.env, owned by
#     deploy/bin/jasper-audio-topology). Default `dmix` topology renders
#     `jasper_renderer_in`; `fanin` topology renders `shairport_substream`.
#
# Invoked from three places:
#   1. shairport-sync.service ExecStartPre (so every restart picks up
#      the current mode).
#   2. install.sh (so a fresh install lands with the conf rendered).
#   3. jasper-airplay-mode CLI and the /airplay/ web UI, after they
#      update the env file and before they restart shairport.
#
# Env input:
#   JASPER_AIRPLAY_FREE_RUNNING — "yes" / "no". Default: "no".
#   JASPER_AIRPLAY_DEVICE_NAME  — display name shown in AirPlay pickers.
#                                 Default: jasper-derive-device-name output.
#   JASPER_CAMILLA_STATEFILE    — CamillaDSP statefile path.
#                                 Default: /var/lib/camilladsp/statefile.yml.
#   JASPER_CAMILLA_DEFAULT_CONFIG — fallback CamillaDSP config path.
#                                   Default: /etc/camilladsp/v1.yml.
#   JASPER_ASOUNDRC             — ALSA system-wide config path used to
#                                 source the renderer-side dmix buffer
#                                 size. Default: /etc/asound.conf.
# File outputs:
#   /etc/shairport-sync.conf — atomic write via /etc/shairport-sync.conf.tmp.
#
# Exits 0 on success. Logs to stderr.

set -euo pipefail

TEMPLATE="${JASPER_SHAIRPORT_TEMPLATE:-/etc/shairport-sync.conf.template}"
TARGET="${JASPER_SHAIRPORT_CONF:-/etc/shairport-sync.conf}"
ENV_FILE="${JASPER_AIRPLAY_MODE_ENV:-/var/lib/jasper/airplay_mode.env}"
JASPER_ENV_FILE="${JASPER_ENV_FILE:-/etc/jasper/jasper.env}"
DERIVE_HELPER="${JASPER_DERIVE_DEVICE_NAME:-/usr/local/sbin/jasper-derive-device-name}"
CAMILLA_STATEFILE="${JASPER_CAMILLA_STATEFILE:-/var/lib/camilladsp/statefile.yml}"
CAMILLA_DEFAULT_CONFIG="${JASPER_CAMILLA_DEFAULT_CONFIG:-/etc/camilladsp/v1.yml}"
ASOUNDRC="${JASPER_ASOUNDRC:-/etc/asound.conf}"
TOPOLOGY_ENV="${JASPER_AUDIO_TOPOLOGY_ENV:-/var/lib/jasper/audio_topology.env}"

if [[ ! -f "$TEMPLATE" ]]; then
    echo "jasper-apply-airplay-mode: template missing at $TEMPLATE" >&2
    exit 1
fi

camilla_config_path() {
    local configured=""
    if [[ -r "$CAMILLA_STATEFILE" ]]; then
        configured="$(
            awk '
                /^[[:space:]]*config_path[[:space:]]*:/ {
                    sub(/^[^:]*:[[:space:]]*/, "")
                    sub(/[[:space:]]*$/, "")
                    print
                    exit
                }
            ' "$CAMILLA_STATEFILE"
        )"
    fi

    if [[ -n "$configured" && -r "$configured" ]]; then
        printf '%s\n' "$configured"
    else
        printf '%s\n' "$CAMILLA_DEFAULT_CONFIG"
    fi
}

camilla_devices_int() {
    local config="$1"
    local key="$2"
    awk -v key="$key" '
        /^[[:space:]]*devices:[[:space:]]*($|#)/ {
            in_devices = 1
            next
        }
        in_devices && /^[^[:space:]#][^:]*:[[:space:]]*($|#)/ {
            exit
        }
        in_devices {
            line = $0
            sub(/[[:space:]]*#.*/, "", line)
            pattern = "^[[:space:]]*" key "[[:space:]]*:[[:space:]]*"
            if (line ~ pattern) {
                sub(pattern, "", line)
                sub(/[[:space:]]*$/, "", line)
                if (line ~ /^[0-9]+$/) {
                    print line
                    exit
                }
            }
        }
    ' "$config"
}

# Read the buffer_size (in frames) from the pcm.jasper_renderer_mix
# dmix block in the asoundrc.
#
# The renderer-side dmix (added in PR #214, 2026-05-22) sits between
# all renderers and hw:Loopback,0,0. Its buffer is INVISIBLE to
# shairport's snd_pcm_delay() because shairport queries the dmix
# slave (the loopback ring), not the dmix's own internal queue. So
# this script must explicitly add it to the latency offset that
# shairport uses for AirPlay packet scheduling. Without this
# accounting, shairport miscalculates packet arrival times by
# buffer_size / sample_rate seconds, drops packets as "out of date,"
# and produces audible artifacts at steady state.
#
# Returns the integer frame count on stdout, or empty if the file
# isn't readable or the block can't be found (callers must treat
# empty as 0, which corresponds to the pre-PR-#214 topology — no
# dmix, no compensation needed).
asoundrc_renderer_dmix_buffer_frames() {
    local asoundrc="$1"
    [[ -r "$asoundrc" ]] || return 0
    awk '
        /^pcm\.jasper_renderer_mix[[:space:]]*\{/ {
            in_block = 1
            next
        }
        in_block && /^pcm\./ {
            # Hit the next pcm definition without finding buffer_size.
            exit
        }
        in_block {
            for (i = 1; i <= NF; i++) {
                if ($i == "buffer_size") {
                    val = $(i + 1)
                    if (val ~ /^[0-9]+$/) {
                        print val
                        exit
                    }
                }
            }
        }
    ' "$asoundrc"
}

derive_audio_backend_latency_offset() {
    local config
    local sample_rate
    local chunksize
    local target_level
    local renderer_dmix_buffer

    config="$(camilla_config_path)"
    if [[ ! -r "$config" ]]; then
        echo "jasper-apply-airplay-mode: Camilla config missing at $config; using latency offset 0.0" >&2
        printf '0.000000'
        return
    fi

    sample_rate="$(camilla_devices_int "$config" samplerate || true)"
    chunksize="$(camilla_devices_int "$config" chunksize || true)"
    target_level="$(camilla_devices_int "$config" target_level || true)"

    if [[ -z "$sample_rate" || -z "$chunksize" ]]; then
        echo "jasper-apply-airplay-mode: could not read samplerate/chunksize from $config; using latency offset 0.0" >&2
        printf '0.000000'
        return
    fi

    # CamillaDSP defaults target_level to chunksize when target_level is
    # absent. The AirPlay offset compensates only the added fixed backend
    # delay above that implicit one-chunk baseline.
    if [[ -z "$target_level" ]]; then
        target_level="$chunksize"
    fi

    # Renderer-side dmix buffer (PR #214, 2026-05-22). Empty when the
    # asoundrc lacks a pcm.jasper_renderer_mix block — pre-PR-#214 hosts
    # or hosts that haven't deployed the dmix shape yet. In that case we
    # treat the contribution as 0 (no compensation needed because the
    # dmix isn't in the chain).
    renderer_dmix_buffer="$(asoundrc_renderer_dmix_buffer_frames "$ASOUNDRC" || true)"
    if [[ -z "$renderer_dmix_buffer" ]]; then
        renderer_dmix_buffer=0
    fi

    awk -v sample_rate="$sample_rate" \
        -v chunksize="$chunksize" \
        -v target_level="$target_level" \
        -v renderer_dmix_buffer="$renderer_dmix_buffer" '
        BEGIN {
            if (sample_rate <= 0) {
                printf "0.000000"
                exit
            }
            # Total invisible-to-shairport delay budget in frames:
            #   (target_level - chunksize)   ← CamillaDSP playback buffer
            #                                   above its implicit one-chunk
            #                                   baseline.
            #   + renderer_dmix_buffer       ← jasper_renderer_mix dmix
            #                                   queue between shairport and
            #                                   the snd-aloop slave.
            # shairport feeds this many frames early so audio still emerges
            # from the speaker at the AirPlay-scheduled time.
            invisible_frames = (target_level - chunksize) + renderer_dmix_buffer
            offset = -(invisible_frames / sample_rate)
            if ((offset > -0.0000005) && (offset < 0.0000005)) {
                offset = 0
            }
            printf "%.6f", offset
        }
    '
}

# Source the airplay_mode.env file if it exists. Default the variable
# AFTER sourcing so an explicit-but-empty value still falls back to the
# safe default.
if [[ -f "$ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$ENV_FILE" 2>/dev/null || true
fi
# Tier 2A topology switch: read JASPER_AUDIO_TOPOLOGY to pick the
# shairport output_device. Absent file or unset value = dmix mode.
if [[ -f "$TOPOLOGY_ENV" ]]; then
    # shellcheck disable=SC1090
    source "$TOPOLOGY_ENV" 2>/dev/null || true
fi
case "${JASPER_AUDIO_TOPOLOGY:-dmix}" in
    fanin)
        renderer_device="shairport_substream"
        ;;
    dmix|"")
        renderer_device="jasper_renderer_in"
        ;;
    *)
        echo "jasper-apply-airplay-mode: invalid JASPER_AUDIO_TOPOLOGY='${JASPER_AUDIO_TOPOLOGY}'; defaulting to dmix" >&2
        renderer_device="jasper_renderer_in"
        ;;
esac
# Also source jasper.env (mode 0640, readable by root only — this
# script runs with the leading `+` privilege escalation from
# shairport-sync.service's ExecStartPre, so root-read is fine). Used
# to pick up JASPER_AIRPLAY_DEVICE_NAME if the operator set one.
if [[ -r "$JASPER_ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$JASPER_ENV_FILE" 2>/dev/null || true
fi
mode="${JASPER_AIRPLAY_FREE_RUNNING:-no}"

# Resolve device name: explicit env var wins; otherwise derive from
# hostname so two Pis on the same LAN don't both advertise as "JTS".
airplay_name="${JASPER_AIRPLAY_DEVICE_NAME:-}"
if [[ -z "$airplay_name" ]]; then
    if [[ -x "$DERIVE_HELPER" ]]; then
        airplay_name=$("$DERIVE_HELPER")
    else
        airplay_name="JTS"
    fi
fi

case "$mode" in
    yes|YES|true|TRUE|1)
        disable_sync="yes"
        human="free-running (music-only, no A/V or multi-room sync)"
        ;;
    no|NO|false|FALSE|0)
        disable_sync="no"
        human="synced (matches AirPlay sender clock; needed for video A/V sync or multi-room)"
        ;;
    *)
        echo "jasper-apply-airplay-mode: invalid JASPER_AIRPLAY_FREE_RUNNING='$mode'; defaulting to no" >&2
        disable_sync="no"
        human="synced (defaulted from invalid value)"
        ;;
esac

latency_offset="$(derive_audio_backend_latency_offset)"

tmp="${TARGET}.tmp.$$"
trap 'rm -f "$tmp"' EXIT

sed -e "s/__DISABLE_SYNCHRONIZATION__/${disable_sync}/g" \
    -e "s/__AIRPLAY_NAME__/${airplay_name}/g" \
    -e "s/__AUDIO_BACKEND_LATENCY_OFFSET_SECONDS__/${latency_offset}/g" \
    -e "s/__RENDERER_DEVICE__/${renderer_device}/g" \
    "$TEMPLATE" > "$tmp"

# Validate the substitution actually happened — refuse to install a
# conf that still contains a placeholder (something went wrong with
# the template or the sed). shairport would otherwise fail to parse it
# and crash-loop.
if grep -qE "__DISABLE_SYNCHRONIZATION__|__AIRPLAY_NAME__|__AUDIO_BACKEND_LATENCY_OFFSET_SECONDS__|__RENDERER_DEVICE__" "$tmp"; then
    echo "jasper-apply-airplay-mode: placeholder still present in rendered conf — refusing to install" >&2
    exit 2
fi

chmod 0644 "$tmp"
mv -f "$tmp" "$TARGET"
trap - EXIT

echo "jasper-apply-airplay-mode: $TARGET rendered for mode $human, name '$airplay_name', renderer device '$renderer_device', latency offset ${latency_offset}s" >&2
