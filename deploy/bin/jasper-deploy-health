#!/usr/bin/env python3
#
# SPDX-FileCopyrightText: 2026 Jasper Curry
#
# SPDX-License-Identifier: Apache-2.0

"""Lightweight deploy-time health probe for low-memory JTS boxes.

Full jasper-doctor is intentionally broad: it imports provider, wake,
integration, web, and hardware modules, and it can momentarily be too much
for a 1 GB full speaker immediately after a deploy restart. This probe is the
deploy gate's small answer to a smaller question: did the install leave the
core control/audio path running, progressing, and xrun-free?

Stdlib-only by design. It must stay cheap enough to run while the box is under
memory pressure, before we have evidence that the heavier Python stack is safe.
"""

from __future__ import annotations

import json
import os
import socket
import stat
import subprocess
import sys
import time
from pathlib import Path
from typing import Any


INSTALL_PROFILE_FILE = Path("/var/lib/jasper/install_profile")
SOURCE_INTENT_FILE = Path("/var/lib/jasper/source_intent.env")
GROUPING_ENV_FILE = Path("/var/lib/jasper/grouping.env")
FULL_INSTALL_PROFILE = "full"
STREAMBOX_INSTALL_PROFILE = "streambox"
LEGACY_STREAMBOX_INSTALL_PROFILES = frozenset({"endpoint", "satellite"})
AIRPLAY_UNIT = "shairport-sync.service"
AIRPLAY_INTENT_KEY = "JASPER_SOURCE_INTENT_SHAIRPORT_SYNC_SERVICE"
SPOTIFY_UNIT = "librespot.service"
SPOTIFY_INTENT_KEY = "JASPER_SOURCE_INTENT_LIBRESPOT_SERVICE"
BLUETOOTH_INTENT_KEY = "JASPER_BLUETOOTH_SOURCE_INTENT"
USBSINK_INTENT_KEY = "JASPER_SOURCE_INTENT_JASPER_USBSINK_SERVICE"
SOURCE_INTENT_PREFIX = "JASPER_SOURCE_INTENT_"
SOURCE_INTENT_ENABLED = "enabled"
SOURCE_INTENT_DISABLED = "disabled"
MAX_SOURCE_INTENT_BYTES = 64 * 1024
MAX_GROUPING_ENV_BYTES = 64 * 1024
RFKILL_CLASS_PATH = Path("/sys/class/rfkill")
UAC2_CARD_PATH = Path("/proc/asound/UAC2Gadget")
MAX_RFKILL_FIELD_BYTES = 32

# Fixed, import-cheap source contract for this stdlib-only probe. The intent
# keys preserve the existing unit-derived AirPlay/Spotify names; Bluetooth has
# no systemd intent unit, so its source-level key is explicit. USB Audio Input
# ships disabled; the other three ship enabled. Bluetooth is effective-On only
# when both audio services and its pairing agent are active.
SOURCE_INTENT_KEYS = {
    "airplay": AIRPLAY_INTENT_KEY,
    "spotify": SPOTIFY_INTENT_KEY,
    "bluetooth": BLUETOOTH_INTENT_KEY,
    "usbsink": USBSINK_INTENT_KEY,
}
SOURCE_INTENT_DEFAULTS = {
    "airplay": True,
    "spotify": True,
    "bluetooth": True,
    "usbsink": False,
}
SOURCE_REQUIRED_UNITS = {
    "airplay": (AIRPLAY_UNIT, "nqptp.service"),
    "spotify": (SPOTIFY_UNIT,),
    "bluetooth": (
        "bluealsa.service",
        "bluealsa-aplay.service",
        "bt-agent.service",
    ),
    "usbsink": ("jasper-usbsink.service",),
}

FULL_REQUIRED_ACTIVE_UNITS = (
    "nginx.service",
    "jasper-control.service",
    "jasper-fanin.service",
    "jasper-outputd.service",
    "jasper-camilla.service",
    "jasper-mux.service",
    "jasper-input.service",
)

STREAMBOX_REQUIRED_ACTIVE_UNITS = tuple(
    unit for unit in FULL_REQUIRED_ACTIVE_UNITS if unit != "jasper-input.service"
)

REQUIRED_ACTIVE_UNITS_BY_PROFILE = {
    FULL_INSTALL_PROFILE: FULL_REQUIRED_ACTIVE_UNITS,
    STREAMBOX_INSTALL_PROFILE: STREAMBOX_REQUIRED_ACTIVE_UNITS,
}

REQUIRED_ACTIVE_SOCKETS = (
    "jasper-web.socket",
    "jasper-system-web.socket",
)

OBSERVED_OPTIONAL_UNITS_BY_PROFILE = {
    FULL_INSTALL_PROFILE: (
        "jasper-voice.service",
        "jasper-aec-bridge.service",
    ),
    # Voice and AEC are intentionally disabled by park_streambox_brain_units.
    # Do not manufacture warnings for units this install profile cannot run.
    STREAMBOX_INSTALL_PROFILE: (),
}

FANIN_SOCKET = "/run/jasper-fanin/control.sock"
OUTPUTD_SOCKET = "/run/jasper-outputd/control.sock"
MAX_PROGRESS_AGE_MS = 2_000
MAX_STATUS_RESPONSE_BYTES = 256 * 1024
STATUS_RESPONSE_DEADLINE_SECONDS = 2.0
STATUS_RECV_TIMEOUT_SECONDS = 1.0


def _read_install_profile(path: Path | None = None) -> str:
    """Read the canonical persisted profile without importing JTS.

    This probe deliberately remains stdlib-only and runs under the system
    Python during low-memory deploys. Missing/unreadable/empty markers keep
    the pre-profile full-speaker fallback. Legacy field markers normalize to
    streambox; any other non-empty token fails closed.
    """

    marker = INSTALL_PROFILE_FILE if path is None else path
    try:
        lines = marker.read_text(encoding="utf-8").splitlines()
    except OSError:
        return FULL_INSTALL_PROFILE
    raw = lines[0].strip() if lines else ""
    if not raw:
        return FULL_INSTALL_PROFILE
    if raw in LEGACY_STREAMBOX_INSTALL_PROFILES:
        return STREAMBOX_INSTALL_PROFILE
    if raw in REQUIRED_ACTIVE_UNITS_BY_PROFILE:
        return raw
    raise RuntimeError(
        f"invalid install profile {raw!r} in {marker}; expected full or streambox"
    )


def _systemctl_is_active(unit: str) -> str:
    proc = subprocess.run(
        ["systemctl", "is-active", unit],
        capture_output=True,
        text=True,
        timeout=3,
    )
    return (proc.stdout or proc.stderr).strip() or f"rc={proc.returncode}"


def _read_regular_bounded_bytes(path: Path, max_bytes: int) -> bytes:
    """Descriptor-safe bounded read for privileged mutable-state probes."""
    flags = os.O_RDONLY | os.O_CLOEXEC | os.O_NOFOLLOW | os.O_NONBLOCK
    fd = os.open(path, flags)
    try:
        if not stat.S_ISREG(os.fstat(fd).st_mode):
            raise RuntimeError(f"{path} is not a regular file")
        chunks: list[bytes] = []
        total = 0
        while True:
            chunk = os.read(fd, min(64 * 1024, max_bytes + 1 - total))
            if not chunk:
                break
            chunks.append(chunk)
            total += len(chunk)
            if total > max_bytes:
                raise RuntimeError(f"{path} exceeds the {max_bytes}-byte cap")
        return b"".join(chunks)
    finally:
        os.close(fd)


def _source_expectations(path: Path | None = None) -> dict[str, bool]:
    """Return persisted active expectations for the fixed source set.

    This mirrors the tiny read-only subset of :mod:`jasper.source_intent` that
    a system-Python, stdlib-only deploy probe can safely use: the canonical
    path, a strict 64 KiB *byte* cap, last assignment wins, quotes are stripped,
    and an absent file/key means that source's shipped default. An unreadable,
    oversized, invalid-UTF-8, or malformed recognized value is ambiguous and
    fails the health check closed. Unrelated env keys remain outside this
    probe's ownership and are ignored. Unknown keys in the owned
    JASPER_SOURCE_INTENT_* namespace fail closed so a newly added source cannot
    silently escape this fixed deploy contract.
    """

    intent_file = SOURCE_INTENT_FILE if path is None else path
    try:
        raw_bytes = _read_regular_bounded_bytes(
            intent_file,
            MAX_SOURCE_INTENT_BYTES,
        )
    except FileNotFoundError:
        return dict(SOURCE_INTENT_DEFAULTS)
    except OSError as exc:
        raise RuntimeError(f"cannot read {intent_file}: {exc}") from exc
    try:
        text = raw_bytes.decode("utf-8")
    except UnicodeError as exc:
        raise RuntimeError(f"cannot decode {intent_file} as UTF-8: {exc}") from exc

    key_to_source = {key: source for source, key in SOURCE_INTENT_KEYS.items()}
    values: dict[str, str] = {}
    for raw in text.splitlines():
        stripped = raw.strip()
        if not stripped or stripped.startswith("#") or "=" not in stripped:
            continue
        key, _, candidate = stripped.partition("=")
        normalized_key = key.strip()
        source = key_to_source.get(normalized_key)
        if source is not None:
            values[source] = candidate.strip().strip("'\"")
        elif normalized_key.startswith(SOURCE_INTENT_PREFIX):
            raise RuntimeError(
                f"unrecognized source intent key {normalized_key!r}"
            )

    expected = dict(SOURCE_INTENT_DEFAULTS)
    for source, value in values.items():
        if value == SOURCE_INTENT_ENABLED:
            expected[source] = True
        elif value == SOURCE_INTENT_DISABLED:
            expected[source] = False
        else:
            key = SOURCE_INTENT_KEYS[source]
            raise RuntimeError(
                f"{key} is {value!r}, expected enabled or disabled"
            )
    return expected


def _read_bounded_env(path: Path, max_bytes: int) -> dict[str, str]:
    """Read a small systemd-style env file with last-assignment-wins."""
    try:
        raw_bytes = _read_regular_bounded_bytes(path, max_bytes)
    except (OSError, RuntimeError):
        return {}
    try:
        text = raw_bytes.decode("utf-8")
    except UnicodeError:
        return {}
    values: dict[str, str] = {}
    for raw in text.splitlines():
        stripped = raw.strip()
        if not stripped or stripped.startswith("#") or "=" not in stripped:
            continue
        key, _, value = stripped.partition("=")
        values[key.strip()] = value.strip().strip("'\"")
    return values


def _bonded_follower_active(path: Path | None = None) -> bool:
    """Whether runtime and persisted grouping agree this box is a follower.

    The config checks avoid treating a stale snapclient as a pair. The bounded
    runtime probes avoid treating a half-applied follower config as parked.
    """
    env = _read_bounded_env(
        GROUPING_ENV_FILE if path is None else path,
        MAX_GROUPING_ENV_BYTES,
    )
    if env.get("JASPER_GROUPING", "").lower() != "on":
        return False
    if env.get("JASPER_GROUPING_ROLE", "") != "follower":
        return False
    if not env.get("JASPER_GROUPING_BOND_ID", ""):
        return False
    if not env.get("JASPER_GROUPING_LEADER_ADDR", ""):
        return False
    return (
        _systemctl_is_active("jasper-snapclient.service") == "active"
        and _systemctl_is_active("jasper-snapserver.service") != "active"
    )


def _read_small_field(path: Path) -> str:
    try:
        with path.open("rb") as file:
            raw = file.read(MAX_RFKILL_FIELD_BYTES + 1)
    except OSError as exc:
        raise RuntimeError(f"cannot read {path}: {exc}") from exc
    if len(raw) > MAX_RFKILL_FIELD_BYTES:
        raise RuntimeError(f"{path} exceeds {MAX_RFKILL_FIELD_BYTES} bytes")
    try:
        return raw.decode("utf-8").strip()
    except UnicodeError as exc:
        raise RuntimeError(f"cannot decode {path} as UTF-8: {exc}") from exc


def _bluetooth_rfkill_state(
    root: Path | None = None,
) -> tuple[bool, bool, bool, bool]:
    """Return (present, any soft blocked, all soft blocked, any hard blocked)."""
    rfkill_root = RFKILL_CLASS_PATH if root is None else root
    present = False
    soft_states: list[bool] = []
    hard_blocked = False
    try:
        entries = sorted(rfkill_root.glob("rfkill*"))
    except OSError as exc:
        raise RuntimeError(f"cannot enumerate {rfkill_root}: {exc}") from exc
    for entry in entries:
        if _read_small_field(entry / "type") != "bluetooth":
            continue
        present = True
        soft_states.append(_read_small_field(entry / "soft") == "1")
        hard_blocked = hard_blocked or _read_small_field(entry / "hard") == "1"
    return (
        present,
        any(soft_states),
        all(soft_states) if soft_states else False,
        hard_blocked,
    )


def _bluez_powered() -> bool | None:
    try:
        proc = subprocess.run(
            ["bluetoothctl", "show"],
            capture_output=True,
            text=True,
            timeout=3,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if proc.returncode != 0:
        return None
    for raw in proc.stdout.splitlines():
        key, separator, value = raw.strip().partition(":")
        if separator and key == "Powered":
            if value.strip() == "yes":
                return True
            if value.strip() == "no":
                return False
    return None


def _bluetooth_radio_issues(desired: bool) -> list[str]:
    """Validate physical RF-kill and BlueZ power against persisted intent."""
    try:
        present, any_soft_blocked, all_soft_blocked, hard_blocked = (
            _bluetooth_rfkill_state()
        )
    except RuntimeError as exc:
        return [f"RF-kill state is unreadable: {exc}"]
    powered = _bluez_powered()
    issues: list[str] = []
    if desired:
        if not present:
            issues.append("no Bluetooth RF-kill radio is present")
        if any_soft_blocked:
            issues.append("Bluetooth radio is soft blocked")
        if hard_blocked:
            issues.append("Bluetooth radio is hard blocked")
        if powered is not True:
            issues.append("BlueZ Powered is not yes")
    else:
        if present and not all_soft_blocked:
            issues.append("Bluetooth radio is not soft blocked")
        if powered is True:
            issues.append("BlueZ Powered is still yes")
        elif present and powered is None:
            issues.append("BlueZ Powered state is unreadable")
    return issues


def _status_json(path: str) -> dict[str, Any]:
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
        deadline = time.monotonic() + STATUS_RESPONSE_DEADLINE_SECONDS
        sock.settimeout(
            min(STATUS_RECV_TIMEOUT_SECONDS, STATUS_RESPONSE_DEADLINE_SECONDS)
        )
        sock.connect(path)
        sock.sendall(b"STATUS\n")
        chunks: list[bytes] = []
        total_bytes = 0
        while True:
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                raise RuntimeError(
                    f"{path} response exceeded the "
                    f"{STATUS_RESPONSE_DEADLINE_SECONDS:g}s deadline"
                )
            recv_timeout = min(STATUS_RECV_TIMEOUT_SECONDS, remaining)
            sock.settimeout(recv_timeout)
            try:
                chunk = sock.recv(
                    min(65536, MAX_STATUS_RESPONSE_BYTES + 1 - total_bytes)
                )
            except (socket.timeout, TimeoutError) as exc:
                if recv_timeout < STATUS_RECV_TIMEOUT_SECONDS:
                    raise RuntimeError(
                        f"{path} response exceeded the "
                        f"{STATUS_RESPONSE_DEADLINE_SECONDS:g}s deadline"
                    ) from exc
                raise
            if not chunk:
                break
            total_bytes += len(chunk)
            if total_bytes > MAX_STATUS_RESPONSE_BYTES:
                raise RuntimeError(
                    f"{path} response exceeds the {MAX_STATUS_RESPONSE_BYTES}-byte cap"
                )
            chunks.append(chunk)
    payload = json.loads(b"".join(chunks).decode("utf-8", errors="replace"))
    if not isinstance(payload, dict):
        raise RuntimeError(f"{path} returned non-object JSON")
    return payload


def _nested_int(payload: dict[str, Any], path: tuple[str, ...]) -> int:
    cur: Any = payload
    for key in path:
        if not isinstance(cur, dict):
            raise RuntimeError(".".join(path) + " is not present")
        cur = cur.get(key)
    label = ".".join(path)
    if isinstance(cur, bool) or not isinstance(cur, int) or cur < 0:
        raise RuntimeError(label + f" is {cur!r}, not a nonnegative int")
    return cur


def _progress_age_ms(payload: dict[str, Any]) -> int:
    return _nested_int(payload, ("watchdog", "last_progress_age_ms"))


def _fanin_xrun_counts(payload: dict[str, Any]) -> tuple[int, int]:
    output_xruns = _nested_int(payload, ("output", "xrun_count"))
    inputs = payload.get("inputs")
    if not isinstance(inputs, list) or not inputs:
        raise RuntimeError("inputs is missing, malformed, or empty")
    input_xruns = 0
    for index, inp in enumerate(inputs):
        if not isinstance(inp, dict):
            raise RuntimeError(f"inputs.{index} is not an object")
        input_xruns += _nested_int(inp, ("xrun_count",))
    return output_xruns, input_xruns


def _usb_source_issues(
    desired: bool,
    fanin_status: dict[str, Any],
    *,
    card_path: Path | None = None,
) -> list[str]:
    """Validate USB's host-visible and direct-capture derived state.

    The service-state check lives in ``SOURCE_REQUIRED_UNITS``. This check
    closes the other two boundaries owned by the coordinator: the UAC2 card
    advertised to the host and fan-in's direct lane that consumes it.
    """

    card_present = (UAC2_CARD_PATH if card_path is None else card_path).is_dir()
    direct_entry: dict[str, Any] | None = None
    inputs = fanin_status.get("inputs")
    if isinstance(inputs, list):
        for raw in inputs:
            if (
                isinstance(raw, dict)
                and raw.get("label") == "usbsink"
                and raw.get("source") == "direct"
            ):
                direct_entry = raw
                break

    if not desired:
        issues: list[str] = []
        if card_present:
            issues.append("UAC2 card is still advertised")
        if direct_entry is not None:
            issues.append("fan-in direct USB lane is still armed")
        return issues

    issues = []
    if not card_present:
        issues.append("UAC2 card is not advertised")
    if direct_entry is None:
        issues.append("fan-in direct USB lane is absent")
        return issues
    direct = direct_entry.get("direct")
    if not isinstance(direct, dict):
        issues.append("fan-in direct USB status is malformed")
        return issues
    if direct.get("present") is not True:
        issues.append("fan-in direct USB device is not present")
    health = direct.get("health")
    if health not in {"idle", "capturing"}:
        issues.append(f"fan-in direct USB health is {health!r}")
    return issues


def _line(status: str, name: str, detail: str) -> None:
    print(f"{status:<4} {name:<28} {detail}")


def main() -> int:
    failures = 0
    warnings = 0
    try:
        profile = _read_install_profile()
    except RuntimeError as exc:
        print("low-memory deploy health")
        _line("FAIL", "install profile", str(exc))
        print("deploy health failed: 1 failure(s), 0 warning(s)")
        return 1

    print(f"low-memory deploy health (profile={profile})")

    parked_follower = _bonded_follower_active()
    required_units = REQUIRED_ACTIVE_UNITS_BY_PROFILE[profile]
    if parked_follower:
        # The follower consumes its leader's Snapcast stream directly. The
        # local source arbiter is deliberately stopped with every local source.
        required_units = tuple(
            unit for unit in required_units if unit != "jasper-mux.service"
        )
        _line("OK", "local source policy", "parked (bonded follower)")
    try:
        source_expectations = _source_expectations()
    except RuntimeError as exc:
        failures += 1
        _line("FAIL", "source intent", str(exc))
        source_expectations = None

    for unit in required_units:
        state = _systemctl_is_active(unit)
        if state == "active":
            _line("OK", unit, state)
        else:
            failures += 1
            _line("FAIL", unit, state)

    # Source units are checked separately from the always-required core so a
    # persisted household disable is a healthy inactive state, while drift in
    # either direction still fails the deploy surface. If parsing failed, skip
    # every source probe rather than guessing a desired state.
    if source_expectations is not None:
        for source, units in SOURCE_REQUIRED_UNITS.items():
            for unit in units:
                expected_active = (
                    False if parked_follower else source_expectations[source]
                )
                state = _systemctl_is_active(unit)
                expected_state = "active" if expected_active else "inactive"
                if state == expected_state:
                    detail = state
                    if parked_follower and not expected_active:
                        detail += " (parked on bonded follower)"
                    elif not expected_active:
                        detail += " (disabled by persisted source intent)"
                    _line("OK", unit, detail)
                else:
                    failures += 1
                    policy = (
                        "bonded-follower parking policy"
                        if parked_follower
                        else "persisted source intent"
                    )
                    _line(
                        "FAIL",
                        unit,
                        f"{state}; expected {expected_state} from {policy}",
                    )

        if not parked_follower:
            radio_issues = _bluetooth_radio_issues(
                source_expectations["bluetooth"]
            )
            if radio_issues:
                failures += 1
                _line("FAIL", "Bluetooth radio", "; ".join(radio_issues))
            else:
                desired = (
                    "on" if source_expectations["bluetooth"] else "off"
                )
                _line("OK", "Bluetooth radio", f"matches desired {desired}")

    for socket_unit in REQUIRED_ACTIVE_SOCKETS:
        state = _systemctl_is_active(socket_unit)
        if state == "active":
            _line("OK", socket_unit, state)
        else:
            failures += 1
            _line("FAIL", socket_unit, state)

    for unit in OBSERVED_OPTIONAL_UNITS_BY_PROFILE[profile]:
        state = _systemctl_is_active(unit)
        if state == "active":
            _line("OK", unit, state)
        else:
            warnings += 1
            _line("WARN", unit, state)

    try:
        fanin = _status_json(FANIN_SOCKET)
        output_xruns, input_xruns = _fanin_xrun_counts(fanin)
        time.sleep(1.0)
        fanin_later = _status_json(FANIN_SOCKET)
        later_output_xruns, later_input_xruns = _fanin_xrun_counts(fanin_later)
        output_xrun_delta = later_output_xruns - output_xruns
        input_xrun_delta = later_input_xruns - input_xruns
        age = _progress_age_ms(fanin_later)
        if (
            output_xrun_delta == 0
            and input_xrun_delta == 0
            and age <= MAX_PROGRESS_AGE_MS
        ):
            _line(
                "OK",
                "jasper-fanin STATUS",
                (
                    f"output_xruns={later_output_xruns} input_xruns={later_input_xruns} "
                    "xrun_delta=0 progress_age_ms="
                    f"{age}"
                ),
            )
        else:
            failures += 1
            _line(
                "FAIL",
                "jasper-fanin STATUS",
                (
                    f"output_xruns={later_output_xruns} input_xruns={later_input_xruns} "
                    f"output_xrun_delta={output_xrun_delta} "
                    f"input_xrun_delta={input_xrun_delta} "
                    f"progress_age_ms={age}"
                ),
            )

        if source_expectations is not None:
            usb_desired = (
                False if parked_follower else source_expectations["usbsink"]
            )
            usb_issues = _usb_source_issues(usb_desired, fanin_later)
            if usb_issues:
                failures += 1
                _line("FAIL", "USB Audio Input", "; ".join(usb_issues))
            else:
                desired = "on" if usb_desired else "off"
                _line("OK", "USB Audio Input", f"matches desired {desired}")
    except Exception as exc:  # noqa: BLE001
        failures += 1
        _line("FAIL", "jasper-fanin STATUS", str(exc))

    try:
        outputd = _status_json(OUTPUTD_SOCKET)
        backend = outputd.get("backend")
        content_xruns = _nested_int(outputd, ("content", "xrun_count"))
        dac_xruns = _nested_int(outputd, ("dac", "xrun_count"))
        content_empty = _nested_int(outputd, ("content", "empty_periods"))
        content_eagain = _nested_int(outputd, ("content", "eagain_count"))
        age = _progress_age_ms(outputd)
        if (
            backend == "alsa"
            and content_xruns == 0
            and dac_xruns == 0
            and content_empty == 0
            and content_eagain == 0
            and age <= MAX_PROGRESS_AGE_MS
        ):
            _line(
                "OK",
                "jasper-outputd STATUS",
                f"backend=alsa xruns=0/0 empty=0 eagain=0 progress_age_ms={age}",
            )
        else:
            failures += 1
            _line(
                "FAIL",
                "jasper-outputd STATUS",
                (
                    f"backend={backend!r} xruns={content_xruns}/{dac_xruns} "
                    f"empty={content_empty} eagain={content_eagain} "
                    f"progress_age_ms={age}"
                ),
            )
    except Exception as exc:  # noqa: BLE001
        failures += 1
        _line("FAIL", "jasper-outputd STATUS", str(exc))

    if failures:
        print(f"deploy health failed: {failures} failure(s), {warnings} warning(s)")
        return 1
    print(f"deploy health passed: 0 failure(s), {warnings} warning(s)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
