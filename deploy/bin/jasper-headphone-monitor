#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Jasper Curry
#
# SPDX-License-Identifier: Apache-2.0

# Watch the Apple dongle's Headphone mixer control and ACTIVELY
# self-heal it back to 100% when something drives it down.
#
# Usage: jasper-headphone-monitor [card|auto] [control]
#
# Why this exists. The dongle's UAC firmware reports a hardware
# default of -20 dB (80/120 = 67%) on every USB (re-)enumeration,
# and Trixie's `alsa-utils 1.2.14-1` ships a broken
# 90-alsa-restore.rules that silently no-ops on hotplug
# (Debian #1093057), so nothing automatically re-pins the control.
# Our own custom udev rule covers the hotplug path; this monitor
# is belt-and-suspenders for any other source of drift (manual
# amixer, a quirk we haven't anticipated, etc). Polls at 1 Hz, logs
# every observed change, and resets to 100% if the value isn't
# 100% — converting silent drift into a self-healing event with a
# timestamped audit trail.
#
# The first poll logs the current value as "initial"; subsequent
# polls log only on change. Resets are also logged so the journal
# shows what self-healing happened and when.

set -uo pipefail

CONFIGURED_CARD="${1:-auto}"
CONTROL="${2:-Headphone}"
APPLE_DONGLE_REGEX="usb-c to 3.5mm"

detect_apple_cards() {
    aplay -L 2>/dev/null \
        | grep -B1 -iE "$APPLE_DONGLE_REGEX" \
        | grep -oE 'CARD=[^,]+' \
        | sed 's/CARD=//' \
        || true
}

resolve_cards() {
    if [[ -n "$CONFIGURED_CARD" && "$CONFIGURED_CARD" != "auto" ]]; then
        printf '%s\n' "$CONFIGURED_CARD"
        return 0
    fi
    detect_apple_cards
}

event_state() {
    printf '%s' "$1" | tr ' ' '_'
}

read_state() {
    local card="$1"
    # Output line like:  [100%] [0.00dB] [on]
    # Grabs the first channel only — both channels of a stereo pair
    # are slaved to the same setting on this hardware, so reporting
    # one is enough.
    amixer -c "$card" sget "$CONTROL" 2>/dev/null \
        | grep -oE '\[[-0-9.]+%\] \[[-0-9.]+dB\] \[(on|off)\]' \
        | head -1
}

# Reset to 100% if the observed state isn't already 100%. Reset
# failures (amixer non-zero exit) are logged but the monitor keeps
# running — a transient amixer error isn't worth crashing the
# watcher.
maybe_reset() {
    local card="$1" state="$2"
    if [[ "$state" != *"[100%]"* ]]; then
        echo "event=apple_dongle.headphone_monitor.drift card=${card} control=${CONTROL} state=$(event_state "$state") action=reset_to_100"
        if ! amixer -c "$card" sset "$CONTROL" 100% unmute >/dev/null 2>&1; then
            echo "event=apple_dongle.headphone_monitor.reset_failed card=${card} control=${CONTROL} reason=amixer_nonzero"
        fi
    fi
}

echo "event=apple_dongle.headphone_monitor.start configured_card=${CONFIGURED_CARD} control=${CONTROL}"
declare -A last_by_card=()
absent_logged=0
declare -A unreadable_by_card=()
while true; do
    mapfile -t cards < <(resolve_cards)
    if [[ "${#cards[@]}" -eq 0 ]]; then
        if [[ "$absent_logged" != "1" ]]; then
            echo "event=apple_dongle.headphone_monitor.absent configured_card=${CONFIGURED_CARD} control=${CONTROL}"
            absent_logged=1
        fi
        last_by_card=()
        unreadable_by_card=()
        sleep 5
        continue
    fi

    absent_logged=0
    for card in "${cards[@]}"; do
        [[ -n "$card" ]] || continue
        if [[ -z "${last_by_card[$card]+x}" ]]; then
            echo "event=apple_dongle.headphone_monitor.detected card=${card} control=${CONTROL}"
            unreadable_by_card["$card"]=0
        fi

        cur=$(read_state "$card")
        if [[ -z "$cur" ]]; then
            if [[ "${unreadable_by_card[$card]:-0}" != "1" ]]; then
                echo "event=apple_dongle.headphone_monitor.unreadable card=${card} control=${CONTROL}"
                unreadable_by_card["$card"]=1
            fi
            last_by_card["$card"]=""
            continue
        fi
        unreadable_by_card["$card"]=0
        last="${last_by_card[$card]:-}"
        if [[ -n "$cur" && "$cur" != "$last" ]]; then
            if [[ -z "$last" ]]; then
                echo "event=apple_dongle.headphone_monitor.state card=${card} control=${CONTROL} state=$(event_state "$cur") initial=1"
                # If we start up to a non-100% state (daemon restart
                # while drift was already in effect), self-heal too.
                maybe_reset "$card" "$cur"
            else
                echo "event=apple_dongle.headphone_monitor.change card=${card} control=${CONTROL} from=$(event_state "$last") to=$(event_state "$cur")"
                maybe_reset "$card" "$cur"
            fi
            last_by_card["$card"]="$cur"
        fi
    done
    sleep 1
done
