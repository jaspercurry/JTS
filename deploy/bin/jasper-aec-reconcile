#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Jasper Curry
#
# SPDX-License-Identifier: Apache-2.0

# Reconcile JTS mic/AEC state with the audio hardware currently present.
#
# This is intentionally a small policy layer around /etc/jasper/jasper.env
# and systemd. It keeps a stale JASPER_MIC_DEVICE=udp:PORT from stranding
# jasper-voice when the XVF Array is unplugged, while leaving a narrow config
# hook for microphone variants via JASPER_MIC_DEVICE_CANDIDATES.

set -euo pipefail

ENV_FILE="${JASPER_ENV_FILE:-/etc/jasper/jasper.env}"
MODE_FILE="${JASPER_AEC_MODE_FILE:-/var/lib/jasper/aec_mode.env}"
VOICE_PROVIDER_FILE="${JASPER_VOICE_PROVIDER_FILE:-/var/lib/jasper/voice_provider.env}"
VOICE_PROVIDER_IDS_FILE="${JASPER_VOICE_PROVIDER_IDS_FILE:-/var/lib/jasper/voice_provider_ids}"
# Persistent NEGATIVE marker for the mic-presence gate
# (docs/HANDOFF-hotplug-resilience.md "Layer 1"). This reconciler is the
# SINGLE WRITER: created on every "no usable mic, park voice" path,
# removed on every "mic present, (re)start voice" path. jasper-voice.service
# gates ExecStart on its ABSENCE (ConditionPathExists=!<this path>), so a
# no-mic box never start-crash-loops. PERSISTENT (/var/lib/jasper, not /run)
# so a no-mic box stays gated across reboot before any reconcile runs;
# absence fails OPEN (voice runs). The path is duplicated as a literal in
# jasper-voice.service and jasper/voice/input_presence.py; agreement is
# pinned by tests/test_voice_input_gate.py.
VOICE_INPUT_ABSENT_MARKER="${JASPER_VOICE_INPUT_ABSENT_MARKER:-/var/lib/jasper/voice-input-absent}"
ASOUND_ROOT="${JASPER_ASOUND_ROOT:-/proc/asound}"
SYSTEMCTL="${JASPER_SYSTEMCTL:-systemctl}"
DEFAULT_MIC_DEVICE_CANDIDATES="Array,L16K6Ch"
DEFAULT_MIC_PROFILE_PYTHON="python3"
if [[ -x /opt/jasper/.venv/bin/python ]]; then
    DEFAULT_MIC_PROFILE_PYTHON="/opt/jasper/.venv/bin/python"
fi
MIC_PROFILE_PYTHON="${JASPER_MIC_PROFILE_PYTHON:-$DEFAULT_MIC_PROFILE_PYTHON}"
MIC_PROFILE_STATE_PATH="${JASPER_MIC_PROFILE_STATE_PATH:-/run/jasper-mic-profile/xvf3800.json}"
OUTPUTD_CONTROL_SOCKET="${JASPER_OUTPUTD_CONTROL_SOCKET:-/run/jasper-outputd/control.sock}"
REASON="manual"
CHECK_ONLY=0
OUTPUTD_RESTART_NEEDED=0
# Opt-in chip-ref observe mode (default 0). When set, the software-AEC3
# path additionally arms outputd's chip-ref writer FOR MEASUREMENT ONLY,
# so the Layer-0 SRO drift estimator gets fed real DAC-vs-XVF counters on
# DACs the reconciler will not trust for production chip-AEC until live
# measurement evidence is present. Set from the mode file near the bottom
# (mirrors the LEG_* globals).
CHIP_REF_OBSERVE=0
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE_LIB="${JASPER_ENV_FILE_LIB:-}"

# Shared quoting/env-file writer (jasper_env_quote_value /
# jasper_env_file_set). SCRIPT_DIR-relative sibling first, installed
# path as fallback: install.sh can run the REPO copy of a reconciler
# mid-install (install_alsa's --print-env) BEFORE install_systemd_units
# refreshes /usr/local/lib, so installed-first could pair a new script
# with a stale lib. Sibling-first keeps script and lib versions in
# lockstep wherever the script runs from; the installed copy under
# /usr/local/sbin has no ../lib/jasper-env-file.sh sibling, so it falls
# through to the installed lib. This deliberately diverges from
# load_asound_render_lib's installed-first order in
# jasper-audio-hardware-reconcile — see the rationale comment there
# (the render lib's functions are never exercised by a mid-install
# repo-script run, so its order is left alone).
load_env_file_lib() {
    if [[ -z "$ENV_FILE_LIB" ]]; then
        if [[ -r "${SCRIPT_DIR}/../lib/jasper-env-file.sh" ]]; then
            ENV_FILE_LIB="${SCRIPT_DIR}/../lib/jasper-env-file.sh"
        else
            ENV_FILE_LIB="/usr/local/lib/jasper/jasper-env-file.sh"
        fi
    fi
    if [[ ! -r "$ENV_FILE_LIB" ]]; then
        echo "jasper-aec-reconcile: missing env-file library: ${ENV_FILE_LIB}" >&2
        exit 66
    fi
    # shellcheck disable=SC1090
    source "$ENV_FILE_LIB"
}
load_env_file_lib

usage() {
    cat <<'EOF'
Usage: jasper-aec-reconcile [--reason TEXT] [--check-aec-ready]

Reconcile microphone/AEC systemd state:
  - auto + supported 6-channel XVF present -> JASPER_MIC_DEVICE=udp:PORT, AEC on
  - auto + direct mic present only -> JASPER_MIC_DEVICE=<mic>, AEC off
  - owned mic config + no mic present -> clear stale UDP, stop voice
  - custom JASPER_MIC_DEVICE -> leave voice config alone, keep AEC off

--check-aec-ready exits 0 only when AEC mode is auto and the configured
AEC mic is present with 6 channels. It performs no mutations and is used as
jasper-aec-bridge.service's ExecCondition.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --reason)
            [[ $# -ge 2 ]] || { usage >&2; exit 2; }
            REASON="$2"
            shift 2
            ;;
        --check-aec-ready)
            CHECK_ONLY=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

log() {
    echo "jasper-aec-reconcile[$REASON]: $*" >&2
}

clear_mic_profile_state() {
    JASPER_XVF_PRESENT=0
    JASPER_XVF_VARIANT=""
    JASPER_XVF_DISPLAY_NAME=""
    JASPER_XVF_GEOMETRY=""
    JASPER_XVF_ALSA_CARD=""
    JASPER_XVF_CAPTURE_CHANNELS=""
    JASPER_XVF_CHIP_BEAM_PLAN=""
    JASPER_XVF_CHIP_AEC_SUPPORTED=0
    JASPER_XVF_RECOMMENDED_PROFILE=""
    JASPER_XVF_REASON="$1"
}

observe_mic_profile_state() {
    local payload args
    args=(-m jasper.cli.xvf_profile --asound-root "$ASOUND_ROOT" --env)
    if [[ "$CHECK_ONLY" != "1" ]]; then
        args+=(--state-path "$MIC_PROFILE_STATE_PATH" --write-state)
    fi
    if ! command -v "$MIC_PROFILE_PYTHON" >/dev/null 2>&1; then
        log "mic profile resolver unavailable at ${MIC_PROFILE_PYTHON}; using legacy XVF defaults"
        clear_mic_profile_state "mic profile resolver unavailable"
        return 0
    fi
    if payload="$("$MIC_PROFILE_PYTHON" "${args[@]}")"; then
        # Output is produced by jasper.cli.xvf_profile with shlex.quote.
        eval "$payload"
        log "mic_profile variant=${JASPER_XVF_VARIANT:-unknown} geometry=${JASPER_XVF_GEOMETRY:-unknown} card=${JASPER_XVF_ALSA_CARD:-unknown} chip_beam_plan=${JASPER_XVF_CHIP_BEAM_PLAN:-none} chip_aec_supported=${JASPER_XVF_CHIP_AEC_SUPPORTED:-0}"
    else
        log "mic profile resolver failed; using legacy XVF defaults"
        clear_mic_profile_state "mic profile resolver failed"
    fi
}

load_env_file() {
    local file="$1"
    if [[ -f "$file" ]]; then
        set -a
        # Runtime-only env files (/etc/jasper/jasper.env and the
        # wizard-owned /var/lib/jasper/*.env) — they don't exist in the
        # repo, so shellcheck can never follow them. Directives bind to
        # the next command, so this must sit on the `source` line itself.
        # shellcheck source=/dev/null
        source "$file"
        set +a
    fi
}

ensure_mode_file() {
    if [[ -f "$MODE_FILE" ]]; then
        # File exists. Seed any missing keys so an older deploy's
        # mode file picks up the new leg defaults on next reconcile.
        # Existing values for already-present keys are left alone.
        if ! grep -q '^JASPER_WAKE_LEG_RAW=' "$MODE_FILE"; then
            printf 'JASPER_WAKE_LEG_RAW=1\n' >> "$MODE_FILE"
        fi
        if ! grep -q '^JASPER_WAKE_LEG_DTLN=' "$MODE_FILE"; then
            printf 'JASPER_WAKE_LEG_DTLN=0\n' >> "$MODE_FILE"
        fi
        if ! grep -q '^JASPER_WAKE_LEG_CHIP_AEC=' "$MODE_FILE"; then
            printf 'JASPER_WAKE_LEG_CHIP_AEC=0\n' >> "$MODE_FILE"
        fi
        if ! grep -q '^JASPER_AEC_CHIP_REF_OBSERVE=' "$MODE_FILE"; then
            printf 'JASPER_AEC_CHIP_REF_OBSERVE=0\n' >> "$MODE_FILE"
        fi
        if ! grep -q '^JASPER_AUDIO_INPUT_PROFILE=' "$MODE_FILE"; then
            printf 'JASPER_AUDIO_INPUT_PROFILE=%s\n' \
                "$(infer_audio_input_profile_from_mode_file)" >> "$MODE_FILE"
        fi
        return
    fi
    # Only create an absent dir; never re-mode /var/lib/jasper (0770 root:jasper)
    # on a boot/udev reconcile — re-moding it to 0755 strips the group-write bit
    # the non-root daemons need (same trap as #827).
    local mode_file_dir
    mode_file_dir="$(dirname "$MODE_FILE")"
    [[ -d "$mode_file_dir" ]] || install -d -m 0755 "$mode_file_dir"
    printf 'JASPER_AUDIO_INPUT_PROFILE=auto\nJASPER_AEC_MODE=auto\nJASPER_WAKE_LEG_RAW=1\nJASPER_WAKE_LEG_DTLN=0\nJASPER_WAKE_LEG_CHIP_AEC=0\nJASPER_AEC_CHIP_REF_OBSERVE=0\n' > "$MODE_FILE"
    chmod 0644 "$MODE_FILE"
}

# Atomic single-key env upsert. Quoting + write semantics live in the
# shared lib (see load_env_file_lib above) so this script and
# jasper-audio-hardware-reconcile cannot drift — bash %q quoting is NOT
# usable here (bash 5.2 backslash-escapes commas, corrupting ALSA
# specs like plughw:CARD=Array,DEV=0 and breaking read-back
# idempotence).
set_env_var() {
    # /etc/jasper/jasper.env is non-secret runtime config. jasper-control
    # fresh-reads it for /state after this reconciler mutates AEC/profile
    # keys, so keep the file group-readable (install migration owns group).
    jasper_env_file_set "$1" "$2" "$3" 0640 0755
}

write_mic_profile_env() {
    set_env_var "$ENV_FILE" JASPER_XVF_PRESENT "${JASPER_XVF_PRESENT:-0}"
    set_env_var "$ENV_FILE" JASPER_XVF_VARIANT "${JASPER_XVF_VARIANT:-}"
    set_env_var "$ENV_FILE" JASPER_XVF_DISPLAY_NAME "${JASPER_XVF_DISPLAY_NAME:-}"
    set_env_var "$ENV_FILE" JASPER_XVF_GEOMETRY "${JASPER_XVF_GEOMETRY:-}"
    set_env_var "$ENV_FILE" JASPER_XVF_ALSA_CARD "${JASPER_XVF_ALSA_CARD:-}"
    set_env_var "$ENV_FILE" JASPER_XVF_CAPTURE_CHANNELS "${JASPER_XVF_CAPTURE_CHANNELS:-}"
    set_env_var "$ENV_FILE" JASPER_XVF_CHIP_BEAM_PLAN "${JASPER_XVF_CHIP_BEAM_PLAN:-}"
    set_env_var "$ENV_FILE" JASPER_XVF_CHIP_AEC_SUPPORTED "${JASPER_XVF_CHIP_AEC_SUPPORTED:-0}"
    set_env_var "$ENV_FILE" JASPER_XVF_RECOMMENDED_PROFILE "${JASPER_XVF_RECOMMENDED_PROFILE:-}"
    set_env_var "$ENV_FILE" JASPER_XVF_REASON "${JASPER_XVF_REASON:-}"
}

mark_outputd_restart_if_changed() {
    local key="$1"
    local desired="$2"
    local current="${!key-}"
    if [[ "$current" != "$desired" ]]; then
        OUTPUTD_RESTART_NEEDED=1
    fi
}

normalize_mode() {
    local mode="${1:-auto}"
    mode="$(printf '%s' "$mode" | tr '[:upper:]' '[:lower:]')"
    case "$mode" in
        auto|"")
            echo "auto"
            ;;
        disabled|disable|off|false|0|no)
            echo "disabled"
            ;;
        *)
            log "unknown JASPER_AEC_MODE=${mode}; treating as disabled"
            echo "disabled"
            ;;
    esac
}

# Normalize the JASPER_WAKE_LEG_* booleans to "1" or "0". The wizard
# only writes "1" / "0", but operators editing aec_mode.env by hand
# might use yes/no/true/false. Default is supplied by the caller —
# RAW defaults on, DTLN defaults off.
normalize_bool() {
    local value="${1:-}"
    value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
    case "$value" in
        1|on|true|yes|y|enabled|enable)
            echo "1"
            ;;
        0|off|false|no|n|disabled|disable|"")
            echo "0"
            ;;
        *)
            log "unknown bool ${value}; treating as 0"
            echo "0"
            ;;
    esac
}

normalize_audio_input_profile() {
    local profile="${1:-custom}"
    profile="$(printf '%s' "$profile" | tr '[:upper:]' '[:lower:]' | tr '-' '_')"
    case "$profile" in
        auto|automatic)
            echo "auto"
            ;;
        xvf_chip_aec|xvf_chip|chip_aec|chip|hardware_aec)
            echo "xvf_chip_aec"
            ;;
        xvf_chip_aec_testing|xvf_chip_aec_trial|chip_aec_testing|chip_aec_trial|hardware_aec_testing)
            echo "xvf_chip_aec_testing"
            ;;
        xvf_software_aec3|xvf_software|software_aec3|aec3|software)
            echo "xvf_software_aec3"
            ;;
        direct_mic|direct|raw|off|disabled)
            echo "direct_mic"
            ;;
        custom|manual|"")
            echo "custom"
            ;;
        *)
            log "unknown JASPER_AUDIO_INPUT_PROFILE=${profile}; treating as custom"
            echo "custom"
            ;;
    esac
}

normalize_output_dac_id() {
    local dac_id="${1:-unknown}"
    dac_id="$(printf '%s' "$dac_id" | tr '[:upper:]' '[:lower:]' | tr '-' '_')"
    dac_id="${dac_id//\'/}"
    dac_id="${dac_id//\"/}"
    if [[ -z "$dac_id" ]]; then
        dac_id="unknown"
    fi
    echo "$dac_id"
}

CHIP_AEC_DAC_GATE_DAC=""
CHIP_AEC_DAC_GATE_TESTING=""
CHIP_AEC_DAC_GATE_OK=0
CHIP_AEC_DAC_GATE_STATUS="needs_calibration"
CHIP_AEC_DAC_GATE_SOURCE="unresolved"
CHIP_AEC_DAC_GATE_DETAIL=""
CHIP_AEC_DAC_GATE_ACTION="use_software_aec3_or_enable_testing"

refresh_chip_aec_dac_gate() {
    local dac_id testing payload args
    dac_id="$(normalize_output_dac_id "${1:-unknown}")"
    testing="${2:-0}"
    if [[ "$CHIP_AEC_DAC_GATE_DAC" == "$dac_id" \
        && "$CHIP_AEC_DAC_GATE_TESTING" == "$testing" ]]; then
        return
    fi
    CHIP_AEC_DAC_GATE_DAC="$dac_id"
    CHIP_AEC_DAC_GATE_TESTING="$testing"
    CHIP_AEC_DAC_GATE_OK=0
    CHIP_AEC_DAC_GATE_STATUS="needs_calibration"
    CHIP_AEC_DAC_GATE_SOURCE="policy_unavailable"
    CHIP_AEC_DAC_GATE_DETAIL=""
    CHIP_AEC_DAC_GATE_ACTION="use_software_aec3_or_enable_testing"
    if ! command -v "$MIC_PROFILE_PYTHON" >/dev/null 2>&1; then
        CHIP_AEC_DAC_GATE_DETAIL="chip-AEC policy unavailable: python not found at ${MIC_PROFILE_PYTHON}"
        return
    fi
    args=(-m jasper.cli.chip_aec_policy
        --dac-id "$dac_id"
        --outputd-socket "$OUTPUTD_CONTROL_SOCKET"
        --shell-env)
    if [[ "$testing" == "1" ]]; then
        args+=(--testing-requested)
    fi
    if ! payload="$("$MIC_PROFILE_PYTHON" "${args[@]}")"; then
        CHIP_AEC_DAC_GATE_DETAIL="chip-AEC policy resolver failed"
        return
    fi
    # Output is produced by jasper.cli.chip_aec_policy with shlex.quote.
    eval "$payload"
    CHIP_AEC_DAC_GATE_DAC="${JASPER_CHIP_AEC_DAC_GATE_DAC:-$dac_id}"
    CHIP_AEC_DAC_GATE_OK="${JASPER_CHIP_AEC_DAC_GATE_PERMITTED:-0}"
    CHIP_AEC_DAC_GATE_STATUS="${JASPER_CHIP_AEC_DAC_GATE_STATUS:-needs_calibration}"
    CHIP_AEC_DAC_GATE_SOURCE="${JASPER_CHIP_AEC_DAC_GATE_SOURCE:-unknown}"
    CHIP_AEC_DAC_GATE_DETAIL="${JASPER_CHIP_AEC_DAC_GATE_DETAIL:-}"
    CHIP_AEC_DAC_GATE_ACTION="${JASPER_CHIP_AEC_DAC_GATE_ACTION:-use_software_aec3_or_enable_testing}"
}

chip_aec_dac_supported() {
    refresh_chip_aec_dac_gate "${1:-unknown}" "${2:-0}"
    [[ "$CHIP_AEC_DAC_GATE_OK" == "1" ]]
}

chip_aec_dac_detail() {
    refresh_chip_aec_dac_gate "${1:-unknown}" "${2:-0}"
    echo "$CHIP_AEC_DAC_GATE_DETAIL"
}

log_chip_aec_dac_gate_if_dynamic() {
    refresh_chip_aec_dac_gate "${1:-unknown}" "${2:-0}"
    if [[ "$CHIP_AEC_DAC_GATE_OK" == "1" ]]; then
        log "chip-AEC DAC gate permits output_dac=$(normalize_output_dac_id "${1:-unknown}") status=${CHIP_AEC_DAC_GATE_STATUS} source=${CHIP_AEC_DAC_GATE_SOURCE}: ${CHIP_AEC_DAC_GATE_DETAIL}"
    fi
}

write_chip_aec_gate_env() {
    set_env_var "$ENV_FILE" JASPER_AEC_CHIP_AEC_TESTING_REQUESTED "$CHIP_AEC_TESTING_REQUESTED"
    set_env_var "$ENV_FILE" JASPER_AEC_CHIP_AEC_DAC_ID "$CHIP_AEC_DAC_GATE_DAC"
    set_env_var "$ENV_FILE" JASPER_AEC_CHIP_AEC_DAC_STATUS "$CHIP_AEC_DAC_GATE_STATUS"
    set_env_var "$ENV_FILE" JASPER_AEC_CHIP_AEC_DAC_SOURCE "$CHIP_AEC_DAC_GATE_SOURCE"
    set_env_var "$ENV_FILE" JASPER_AEC_CHIP_AEC_DAC_DETAIL "$CHIP_AEC_DAC_GATE_DETAIL"
    set_env_var "$ENV_FILE" JASPER_AEC_CHIP_AEC_DAC_ACTION "$CHIP_AEC_DAC_GATE_ACTION"
}

chip_aec_mic_supported() {
    [[ "${JASPER_XVF_CHIP_AEC_SUPPORTED:-0}" == "1" ]] \
        && [[ -n "${JASPER_XVF_CHIP_BEAM_PLAN:-}" ]]
}

chip_aec_mic_detail() {
    if chip_aec_mic_supported; then
        echo "supported beam_plan=${JASPER_XVF_CHIP_BEAM_PLAN}"
    else
        echo "${JASPER_XVF_REASON:-mic has no validated production chip-AEC beam plan}"
    fi
}

mode_file_value() {
    local key="$1"
    local default="$2"
    local line
    if [[ -f "$MODE_FILE" ]]; then
        line="$(grep -E "^${key}=" "$MODE_FILE" | tail -n 1 || true)"
        if [[ -n "$line" ]]; then
            printf '%s\n' "${line#*=}"
            return
        fi
    fi
    printf '%s\n' "$default"
}

infer_audio_input_profile_from_values() {
    local mode="$1"
    local raw="$2"
    local dtln="$3"
    local chip_aec="$4"
    if [[ "$mode" != "auto" ]]; then
        echo "direct_mic"
    elif [[ "$chip_aec" == "1" ]]; then
        echo "xvf_chip_aec"
    elif [[ "$raw" == "1" && "$dtln" == "0" ]]; then
        echo "xvf_software_aec3"
    else
        echo "custom"
    fi
}

infer_audio_input_profile_from_mode_file() {
    local mode raw dtln chip_aec
    mode="$(normalize_mode "$(mode_file_value JASPER_AEC_MODE auto)")"
    raw="$(normalize_bool "$(mode_file_value JASPER_WAKE_LEG_RAW 1)")"
    dtln="$(normalize_bool "$(mode_file_value JASPER_WAKE_LEG_DTLN 0)")"
    chip_aec="$(normalize_bool "$(mode_file_value JASPER_WAKE_LEG_CHIP_AEC 0)")"
    infer_audio_input_profile_from_values "$mode" "$raw" "$dtln" "$chip_aec"
}

apply_audio_input_profile() {
    local detail
    case "$AUDIO_INPUT_PROFILE" in
        auto)
            AEC_MODE="auto"
            if aec_ready "$AEC_MIC_DEVICE" \
                && chip_aec_mic_supported \
                && chip_aec_dac_supported "$AUDIO_DAC_ID" "0"; then
                log_chip_aec_dac_gate_if_dynamic "$AUDIO_DAC_ID" "0"
                LEG_RAW="0"
                LEG_DTLN="0"
                LEG_CHIP_AEC="1"
            elif aec_ready "$AEC_MIC_DEVICE"; then
                if ! chip_aec_mic_supported; then
                    detail="$(chip_aec_mic_detail)"
                else
                    detail="$(chip_aec_dac_detail "$AUDIO_DAC_ID" "0")"
                fi
                log "chip-AEC unavailable for output_dac=${AUDIO_DAC_ID}: ${detail}; using software AEC3"
                LEG_RAW="1"
                LEG_DTLN="0"
                LEG_CHIP_AEC="0"
            else
                LEG_RAW="1"
                LEG_DTLN="0"
                LEG_CHIP_AEC="0"
            fi
            ;;
        xvf_chip_aec)
            AEC_MODE="auto"
            if chip_aec_mic_supported && chip_aec_dac_supported "$AUDIO_DAC_ID" "0"; then
                log_chip_aec_dac_gate_if_dynamic "$AUDIO_DAC_ID" "0"
                LEG_RAW="0"
                LEG_DTLN="0"
                LEG_CHIP_AEC="1"
            else
                if ! chip_aec_mic_supported; then
                    detail="$(chip_aec_mic_detail)"
                else
                    detail="$(chip_aec_dac_detail "$AUDIO_DAC_ID" "0")"
                fi
                log "requested xvf_chip_aec but output_dac=${AUDIO_DAC_ID} is not calibrated for chip AEC: ${detail}; using software AEC3"
                LEG_RAW="1"
                LEG_DTLN="0"
                LEG_CHIP_AEC="0"
            fi
            ;;
        xvf_chip_aec_testing)
            AEC_MODE="auto"
            if chip_aec_mic_supported && chip_aec_dac_supported "$AUDIO_DAC_ID" "1"; then
                log_chip_aec_dac_gate_if_dynamic "$AUDIO_DAC_ID" "1"
                LEG_RAW="0"
                LEG_DTLN="0"
                LEG_CHIP_AEC="1"
            else
                if ! chip_aec_mic_supported; then
                    detail="$(chip_aec_mic_detail)"
                else
                    detail="$(chip_aec_dac_detail "$AUDIO_DAC_ID" "1")"
                fi
                log "requested xvf_chip_aec_testing but chip-AEC cannot be armed for output_dac=${AUDIO_DAC_ID}: ${detail}; using software AEC3"
                LEG_RAW="1"
                LEG_DTLN="0"
                LEG_CHIP_AEC="0"
            fi
            ;;
        xvf_software_aec3)
            AEC_MODE="auto"
            LEG_RAW="1"
            LEG_DTLN="0"
            LEG_CHIP_AEC="0"
            ;;
        direct_mic)
            AEC_MODE="disabled"
            LEG_RAW="0"
            LEG_DTLN="0"
            LEG_CHIP_AEC="0"
            ;;
        custom)
            ;;
    esac
}

# Map wake-leg booleans to the underlying env vars that
# jasper-aec-bridge and jasper-voice each read at startup. When the
# bridge isn't going to run (bridge_running="0"), clear them all —
# they're meaningless without a bridge emitting on the UDP ports,
# and a stale JASPER_MIC_DEVICE_RAW=udp:9877 leaves the voice
# secondary UdpMicCapture spinning on a port nobody talks to.
#
# Single-chip mutual exclusion (chip-AEC): the XVF chip can emit EITHER
# the software legs (raw :9877 / DTLN :9878 alongside AEC3 :9876) OR the
# chip-AEC beams, not both — Option-A means in chip-AEC mode the bridge
# forwards the chip-AEC beam into :9876 (session + Tier-1 heartbeat
# carrier) and emits the fixed 150°/210° ASR beams on :9887/:9888 for
# scoring. So when chip-AEC is on we clear raw/DTLN, and vice versa.
#
# The booleans themselves stay preserved in $MODE_FILE — that's the
# user's wizard-managed intent. We just don't *apply* them when the
# bridge is down. When the user re-enables AEC, the legs they had
# configured come back automatically on the next reconcile pass.
write_leg_env() {
    local bridge_running="$1"
    local leg_raw="$2"
    local leg_dtln="$3"
    local leg_chip_aec="$4"
    local raw_udp dtln_udp dtln_flag chip_150_udp chip_210_udp chip_flag
    local ref_source outputd_chip_ref_pcm outputd_ref_target observe_flag
    local outputd_chip_ref_rate outputd_chip_ref_period outputd_chip_ref_buffer
    local bridge_ref_host bridge_ref_port producer_was_active
    producer_was_active=0
    if [[ -n "${JASPER_OUTPUTD_CHIP_REF_PCM-}" || -n "${JASPER_OUTPUTD_REFERENCE_UDP_TARGET-}" ]]; then
        producer_was_active=1
    fi
    if [[ "$bridge_running" == "1" && "$leg_chip_aec" == "1" ]]; then
        # Chip-AEC production mode (Option-A): score the fixed 150°/210°
        # beams on :9887/:9888; the chip-AEC beam is forwarded into :9876
        # as the session/heartbeat carrier. raw/DTLN are NOT emitted by
        # the bridge in this mode, so clear them (single-chip exclusion).
        #
        chip_150_udp="udp:${AEC_UDP_PORT_CHIP_AEC_150}"
        chip_210_udp="udp:${AEC_UDP_PORT_CHIP_AEC_210}"
        chip_flag="1"
        # Production chip-AEC, not observe mode: the chip-ref writer is
        # armed because the chip IS the mic path here.
        observe_flag="0"
        raw_udp=""
        dtln_udp=""
        dtln_flag="0"
        ref_source="outputd_udp"
        bridge_ref_host="127.0.0.1"
        bridge_ref_port="${AEC_OUTPUTD_REF_UDP_PORT}"
        outputd_chip_ref_pcm="${OUTPUTD_CHIP_REF_PCM}"
        outputd_ref_target="${bridge_ref_host}:${bridge_ref_port}"
        outputd_chip_ref_rate="${OUTPUTD_CHIP_REF_SAMPLE_RATE}"
        outputd_chip_ref_period="${OUTPUTD_CHIP_REF_PERIOD_FRAMES}"
        outputd_chip_ref_buffer="${OUTPUTD_CHIP_REF_BUFFER_FRAMES}"
    elif [[ "$bridge_running" == "1" ]]; then
        # Software-leg mode: raw/DTLN as configured, chip beams cleared.
        # The far-end reference still comes from outputd's final speaker
        # monitor so software AEC, chip-AEC, corpus, and diagnostics all
        # consume the same reference contract.
        if [[ "$leg_raw" == "1" ]]; then
            raw_udp="udp:${AEC_UDP_PORT_RAW}"
        else
            raw_udp=""
        fi
        if [[ "$leg_dtln" == "1" ]]; then
            dtln_udp="udp:${AEC_UDP_PORT_DTLN}"
            dtln_flag="1"
        else
            dtln_udp=""
            dtln_flag="0"
        fi
        chip_150_udp=""
        chip_210_udp=""
        chip_flag="0"
        ref_source="outputd_udp"
        bridge_ref_host="127.0.0.1"
        bridge_ref_port="${AEC_OUTPUTD_REF_UDP_PORT}"
        # Chip-ref observe mode (opt-in, default off): arm outputd's
        # chip-ref writer FOR MEASUREMENT ONLY so the Layer-0 SRO drift
        # estimator reads real DAC-vs-XVF counters. The mic path stays
        # software AEC3 (chip_flag=0, raw/DTLN as configured above) — this
        # ONLY adds the chip-ref producer, breaking the bootstrap deadlock
        # where the reconciler will not arm chip-AEC until drift is
        # measured, but drift can only be measured while the writer runs.
        # Gated on the XVF USB-IN PCM being known (OUTPUTD_CHIP_REF_PCM
        # non-empty); otherwise observe no-ops and the writer stays off.
        if [[ "$CHIP_REF_OBSERVE" == "1" && -n "${OUTPUTD_CHIP_REF_PCM}" ]]; then
            outputd_chip_ref_pcm="${OUTPUTD_CHIP_REF_PCM}"
            observe_flag="1"
        else
            outputd_chip_ref_pcm=""
            observe_flag="0"
        fi
        outputd_ref_target="${bridge_ref_host}:${bridge_ref_port}"
        outputd_chip_ref_rate="${OUTPUTD_CHIP_REF_SAMPLE_RATE}"
        outputd_chip_ref_period="${OUTPUTD_CHIP_REF_PERIOD_FRAMES}"
        outputd_chip_ref_buffer="${OUTPUTD_CHIP_REF_BUFFER_FRAMES}"
    else
        raw_udp=""
        dtln_udp=""
        dtln_flag="0"
        chip_150_udp=""
        chip_210_udp=""
        chip_flag="0"
        observe_flag="0"
        ref_source="alsa"
        bridge_ref_host="127.0.0.1"
        bridge_ref_port="${AEC_OUTPUTD_REF_UDP_PORT}"
        outputd_chip_ref_pcm=""
        outputd_ref_target=""
        outputd_chip_ref_rate="${OUTPUTD_CHIP_REF_SAMPLE_RATE}"
        outputd_chip_ref_period="${OUTPUTD_CHIP_REF_PERIOD_FRAMES}"
        outputd_chip_ref_buffer="${OUTPUTD_CHIP_REF_BUFFER_FRAMES}"
    fi
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE_RAW "$raw_udp"
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE_DTLN "$dtln_udp"
    set_env_var "$ENV_FILE" JASPER_AEC_DTLN_ENABLED "$dtln_flag"
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE_CHIP_AEC_150 "$chip_150_udp"
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE_CHIP_AEC_210 "$chip_210_udp"
    set_env_var "$ENV_FILE" JASPER_AEC_CHIP_AEC_ENABLED "$chip_flag"
    set_env_var "$ENV_FILE" JASPER_AEC_REF_SOURCE "$ref_source"
    set_env_var "$ENV_FILE" JASPER_AEC_OUTPUTD_REF_UDP_HOST "$bridge_ref_host"
    set_env_var "$ENV_FILE" JASPER_AEC_OUTPUTD_REF_UDP_PORT "$bridge_ref_port"

    if [[ "$observe_flag" == "1" ]]; then
        log "chip-ref observe mode: arming chip-ref writer for drift measurement; mic path stays software AEC3"
    fi

    mark_outputd_restart_if_changed JASPER_OUTPUTD_CHIP_REF_PCM "$outputd_chip_ref_pcm"
    mark_outputd_restart_if_changed JASPER_OUTPUTD_REFERENCE_UDP_TARGET "$outputd_ref_target"
    mark_outputd_restart_if_changed JASPER_OUTPUTD_CHIP_REF_OBSERVE "$observe_flag"
    if [[ "$chip_flag" == "1" || "$producer_was_active" == "1" ]]; then
        mark_outputd_restart_if_changed JASPER_OUTPUTD_CHIP_REF_SAMPLE_RATE "$outputd_chip_ref_rate"
        mark_outputd_restart_if_changed JASPER_OUTPUTD_CHIP_REF_PERIOD_FRAMES "$outputd_chip_ref_period"
        mark_outputd_restart_if_changed JASPER_OUTPUTD_CHIP_REF_BUFFER_FRAMES "$outputd_chip_ref_buffer"
    fi
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_CHIP_REF_PCM "$outputd_chip_ref_pcm"
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_REFERENCE_UDP_TARGET "$outputd_ref_target"
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_CHIP_REF_OBSERVE "$observe_flag"
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_CHIP_REF_SAMPLE_RATE "$outputd_chip_ref_rate"
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_CHIP_REF_PERIOD_FRAMES "$outputd_chip_ref_period"
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_CHIP_REF_BUFFER_FRAMES "$outputd_chip_ref_buffer"
}

card_id_from_spec() {
    local spec="$1"
    if [[ "$spec" =~ CARD=([^,]+) ]]; then
        echo "${BASH_REMATCH[1]}"
    elif [[ "$spec" =~ ^(hw|plughw):([^,]+) ]]; then
        echo "${BASH_REMATCH[2]}"
    else
        echo "$spec"
    fi
}

card_stream_file() {
    local spec="$1"
    local card
    card="$(card_id_from_spec "$spec")"
    echo "${ASOUND_ROOT}/${card}/stream0"
}

mic_present() {
    local spec="$1"
    [[ -f "$(card_stream_file "$spec")" ]]
}

mic_channels() {
    local spec="$1"
    local stream channels
    stream="$(card_stream_file "$spec")"
    if [[ ! -f "$stream" ]]; then
        echo 0
        return
    fi
    # /proc/asound/<card>/stream0 has separate Playback and Capture
    # blocks, each with its own "Channels:" line. We need the Capture
    # one — the XVF chip's Playback endpoint is 2-ch even when Capture
    # is 6-ch on the 6-ch firmware. Pinning to ^Capture: prevents a
    # silent fallback to direct-mic when AEC should be enabled.
    channels="$(awk '/^Capture:/{cap=1} cap && /Channels:[[:space:]]*[0-9]+/{print; exit}' "$stream" \
        | grep -oE "[0-9]+" \
        | head -1)"
    echo "${channels:-0}"
}

aec_ready() {
    local mic="$1"
    [[ "$(mic_channels "$mic")" == "6" ]]
}

# When the chip is flashed from the 2-ch firmware to the 6-ch firmware
# (the BRINGUP path), ALSA assigns mixer slots for the new ch2-5 with
# default values of off / 0 dB. `alsactl restore` then persists that
# state across reboot — silencing the raw mics in the kernel
# independently of the chip's own configuration, with no surface that
# would let the operator notice. Force the capture channels open
# whenever we confirm the chip is on 6-ch firmware. Idempotent; safe
# to run on every reconcile pass.
#
# Canonical reference for these mixer names + the rationale: the
# `jasper.mics.xvf3800` Python profile. This reconciler is bash and
# can't import Python; if the names or channel count change in the
# profile, update them here too. The doctor's `check_xvf_mixer_state`
# reads from the profile and flags drift if the two get out of sync.
ensure_capture_mixer_open() {
    local spec="$1"
    local card
    card="$(card_id_from_spec "$spec")"
    amixer -c "$card" cset name='Headset Capture Switch' \
        on,on,on,on,on,on >/dev/null 2>&1 || true
    amixer -c "$card" cset name='Headset Capture Volume' \
        60,60,60,60,60,60 >/dev/null 2>&1 || true
    alsactl store >/dev/null 2>&1 || true
}

split_candidates() {
    local raw="$1"
    raw="${raw//,/ }"
    # shellcheck disable=SC2206
    MIC_CANDIDATES=($raw)
}

mic_candidates_contains() {
    local needle="$1"
    local candidate
    for candidate in "${MIC_CANDIDATES[@]}"; do
        [[ "$candidate" == "$needle" ]] && return 0
    done
    return 1
}

prepend_mic_candidate() {
    local candidate="$1"
    [[ -n "$candidate" ]] || return 0
    mic_candidates_contains "$candidate" && return 0
    MIC_CANDIDATES=("$candidate" "${MIC_CANDIDATES[@]}")
}

profile_managed_mic_resolution() {
    # `custom` is the escape hatch for operator-managed mic routing. Every
    # selectable product profile is reconciler-owned: the detected mic
    # profile supplies the concrete ALSA card, so swapping XVF variants cannot
    # leave an old card id pinned in /etc/jasper/jasper.env.
    [[ "${AUDIO_INPUT_PROFILE:-custom}" != "custom" ]]
}

derive_profile_managed_aec_mic_device() {
    local detected_card old_card
    profile_managed_mic_resolution || return 0
    detected_card="${JASPER_XVF_ALSA_CARD:-}"
    [[ -n "$detected_card" ]] || return 0
    mic_present "$detected_card" || return 0

    old_card="${AEC_MIC_DEVICE:-}"
    AEC_MIC_DEVICE="$detected_card"
    prepend_mic_candidate "$detected_card"
    if [[ -n "$old_card" && "$old_card" != "$detected_card" ]]; then
        log "event=aec_reconcile.aec_mic_device_rederived profile=${AUDIO_INPUT_PROFILE} old=${old_card} new=${detected_card} variant=${JASPER_XVF_VARIANT:-unknown} reason=detected_xvf_profile_wins"
    elif [[ -z "$old_card" ]]; then
        log "event=aec_reconcile.aec_mic_device_derived profile=${AUDIO_INPUT_PROFILE} new=${detected_card} variant=${JASPER_XVF_VARIANT:-unknown}"
    fi
}

first_candidate() {
    if [[ ${#MIC_CANDIDATES[@]} -gt 0 ]]; then
        echo "${MIC_CANDIDATES[0]}"
    else
        echo "$AEC_MIC_DEVICE"
    fi
}

first_present_candidate() {
    local candidate
    for candidate in "${MIC_CANDIDATES[@]}"; do
        if mic_present "$candidate"; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

is_candidate_value() {
    local value="$1"
    local candidate
    for candidate in "${MIC_CANDIDATES[@]}"; do
        [[ "$value" == "$candidate" ]] && return 0
    done
    return 1
}

is_owned_mic_value() {
    local value="$1"
    local udp_device="$2"
    [[ -z "$value" ]] && return 0
    [[ "$value" == "$udp_device" ]] && return 0
    [[ "$value" == udp:* ]] && return 0
    [[ "$value" =~ ^hw:[0-9]+,1$ ]] && return 0
    is_candidate_value "$value" && return 0
    return 1
}

run_systemctl() {
    "$SYSTEMCTL" "$@" || true
}

reset_failed_units() {
    local unit
    for unit in "$@"; do
        # `reset-failed` is intentionally unconditional: besides clearing
        # a failed state, systemd also clears the unit's start-rate
        # counters. A controlled deploy/reconcile/toggle sequence can
        # otherwise accumulate enough clean restarts to hit
        # StartLimitAction=reboot even though no service is unhealthy.
        run_systemctl reset-failed "$unit"
    done
}

stop_disable_aec() {
    run_systemctl stop jasper-aec-bridge.service jasper-aec-init.service
    run_systemctl disable jasper-aec-bridge.service jasper-aec-init.service
    reset_failed_units jasper-aec-bridge.service jasper-aec-init.service
}

enable_start_aec() {
    run_systemctl enable jasper-aec-init.service jasper-aec-bridge.service
    reset_failed_units jasper-aec-init.service jasper-aec-bridge.service
    # `restart` not `start`: jasper-aec-init is Type=oneshot with
    # RemainAfterExit=yes, so `start` is a no-op once it's run
    # successfully. Any chip-side param changes from a code deploy
    # (HPF cutoff, SHF_BYPASS, future tuning) would silently NOT
    # re-apply until the next reboot. `restart` forces re-execution.
    # Discovered 2026-05-15 after a deploy left chip params at their
    # previous boot-time values despite code expecting newer ones.
    run_systemctl restart jasper-aec-init.service
    run_systemctl restart jasper-aec-bridge.service
}

# Mic-presence gate marker writers (docs/HANDOFF-hotplug-resilience.md
# "Layer 1"). mark = "no usable mic, voice is parked"; clear = "a mic is
# present". jasper-voice.service's ConditionPathExists=!<marker> reads the
# absence. Both best-effort: a marker write failing must never abort a
# reconcile pass (the daemon's exit-66 backstop still parks a no-mic start).
# Do NOT re-mode the parent dir here — same trap as ensure_mode_file (#827).
mark_voice_input_absent() {
    local reason="${1:-no usable microphone present}"
    # The parent dir (/var/lib/jasper) is guaranteed by ensure_mode_file,
    # which runs earlier in every non-check-only pass; we deliberately do
    # NOT create or re-mode it here (re-moding 0770 root:jasper -> 0755
    # strips the group-write bit the non-root daemons need — the #827
    # trap). If the dir is somehow absent the write fails soft below and
    # the daemon's exit-66 backstop still parks voice.
    if printf 'reason=%s\n' "$reason" > "$VOICE_INPUT_ABSENT_MARKER" 2>/dev/null; then
        chmod 0644 "$VOICE_INPUT_ABSENT_MARKER" 2>/dev/null || true
        log "voice input absent: marked ${VOICE_INPUT_ABSENT_MARKER} (${reason}); jasper-voice gated off until a mic appears"
    else
        log "voice input absent: failed to write ${VOICE_INPUT_ABSENT_MARKER} (${reason}); relying on daemon exit-66 park"
    fi
}

clear_voice_input_absent() {
    if [[ -e "$VOICE_INPUT_ABSENT_MARKER" ]]; then
        rm -f "$VOICE_INPUT_ABSENT_MARKER" 2>/dev/null || true
        log "voice input present: cleared ${VOICE_INPUT_ABSENT_MARKER}; jasper-voice gate open"
    fi
}

restart_voice() {
    # A mic is present (this is only called from the mic-present paths),
    # so open the presence gate before (re)starting. Done even on the
    # provider-unset branch below: the mic axis is genuinely satisfied;
    # the separate `disable --now` parks voice on the provider axis.
    clear_voice_input_absent
    if ! voice_provider_configured; then
        log "voice provider unset or invalid; leaving jasper-voice parked"
        run_systemctl disable --now jasper-voice.service
        reset_failed_units jasper-voice.service
        return
    fi
    reset_failed_units jasper-voice.service
    run_systemctl enable jasper-voice.service
    run_systemctl restart jasper-voice.service
}

# Dumb-follower profile (HANDOFF-multiroom Increment 5): an ACTIVE
# bonded FOLLOWER parks jasper-voice AND the AEC stack — the leader owns
# the mic/wake/AI session, and the parked daemons free ~310 MB on a 1 GB
# Pi. The signal is the Python-validated derived flag the grouping
# reconciler writes into grouping-voice.env (exact line match, mirroring
# valid_voice_provider's posture) — bond-validity logic is NEVER
# re-derived in shell. Missing/unreadable file = not parked (fail-open:
# a broken read must never park a solo speaker's voice).
GROUPING_VOICE_ENV_FILE="${JASPER_GROUPING_VOICE_ENV_FILE:-/var/lib/jasper/grouping-voice.env}"

grouping_voice_parked() {
    [[ -r "$GROUPING_VOICE_ENV_FILE" ]] || return 1
    grep -Fxq "JASPER_GROUPING_VOICE_PARK=1" "$GROUPING_VOICE_ENV_FILE"
}

voice_provider_configured() {
    local line provider
    if [[ -f "$VOICE_PROVIDER_FILE" ]]; then
        line="$(grep -E '^JASPER_VOICE_PROVIDER=' "$VOICE_PROVIDER_FILE" | tail -n 1 || true)"
        provider="${line#JASPER_VOICE_PROVIDER=}"
        provider="${provider%%[[:space:]]*}"
        valid_voice_provider "$provider" && return 0
    fi
    valid_voice_provider "${JASPER_VOICE_PROVIDER:-}"
}

valid_voice_provider() {
    local provider="$1"
    # Install-time artifact generated from jasper.voice.catalog.
    # Keep this boot/hotplug safety gate shell-only: if the manifest is
    # missing or the provider is not an exact line, jasper-voice stays parked.
    [[ -n "$provider" && -r "$VOICE_PROVIDER_IDS_FILE" ]] || return 1
    grep -Fxq -- "$provider" "$VOICE_PROVIDER_IDS_FILE"
}

restart_outputd_if_needed() {
    if [[ "$OUTPUTD_RESTART_NEEDED" == "1" ]]; then
        reset_failed_units jasper-outputd.service
        run_systemctl restart jasper-outputd.service
    fi
}

stop_voice() {
    # Only ever reached when no candidate mic is present, so this is the
    # canonical "park voice for no mic" action: stamp the presence marker
    # so jasper-voice's ConditionPathExists gate keeps it from restarting
    # (or boot-starting) until a mic reappears and clears it.
    mark_voice_input_absent "no candidate microphone present"
    run_systemctl stop jasper-voice.service
    reset_failed_units jasper-voice.service
}

load_env_file "$ENV_FILE"
if [[ "$CHECK_ONLY" != "1" ]]; then
    ensure_mode_file
fi
load_env_file "$MODE_FILE"
observe_mic_profile_state

AEC_MODE="$(normalize_mode "${JASPER_AEC_MODE:-auto}")"
AUDIO_INPUT_PROFILE="$(normalize_audio_input_profile "${JASPER_AUDIO_INPUT_PROFILE:-custom}")"
AEC_MIC_DEVICE="${JASPER_AEC_MIC_DEVICE:-}"
AEC_UDP_PORT="${JASPER_AEC_UDP_PORT:-9876}"
AEC_UDP_PORT_RAW="${JASPER_AEC_UDP_PORT_RAW:-9877}"
AEC_UDP_PORT_DTLN="${JASPER_AEC_UDP_PORT_DTLN:-9878}"
AEC_UDP_PORT_CHIP_AEC_150="${JASPER_AEC_UDP_PORT_CHIP_AEC_150:-9887}"
AEC_UDP_PORT_CHIP_AEC_210="${JASPER_AEC_UDP_PORT_CHIP_AEC_210:-9888}"
AEC_OUTPUTD_REF_UDP_PORT="${JASPER_AEC_OUTPUTD_REF_UDP_PORT:-9891}"
OUTPUTD_CHIP_REF_SAMPLE_RATE="${JASPER_OUTPUTD_CHIP_REF_SAMPLE_RATE:-16000}"
OUTPUTD_CHIP_REF_PERIOD_FRAMES="${JASPER_OUTPUTD_CHIP_REF_PERIOD_FRAMES:-320}"
OUTPUTD_CHIP_REF_BUFFER_FRAMES="${JASPER_OUTPUTD_CHIP_REF_BUFFER_FRAMES:-1280}"
UDP_DEVICE="udp:${AEC_UDP_PORT}"
MIC_DEVICE_CANDIDATES_DEFAULT="$DEFAULT_MIC_DEVICE_CANDIDATES"
if [[ -n "${JASPER_XVF_ALSA_CARD:-}" ]]; then
    MIC_DEVICE_CANDIDATES_DEFAULT="${JASPER_XVF_ALSA_CARD},${DEFAULT_MIC_DEVICE_CANDIDATES}"
fi
split_candidates "${JASPER_MIC_DEVICE_CANDIDATES:-${AEC_MIC_DEVICE:-$MIC_DEVICE_CANDIDATES_DEFAULT}}"
if [[ "$CHECK_ONLY" != "1" ]]; then
    derive_profile_managed_aec_mic_device
fi
if [[ -z "$AEC_MIC_DEVICE" ]]; then
    if AEC_MIC_DEVICE="$(first_present_candidate)"; then
        :
    else
        AEC_MIC_DEVICE="$(first_candidate)"
    fi
fi
if profile_managed_mic_resolution && [[ -n "${JASPER_XVF_ALSA_CARD:-}" ]]; then
    OUTPUTD_CHIP_REF_PCM="plughw:CARD=${AEC_MIC_DEVICE},DEV=0"
else
    OUTPUTD_CHIP_REF_PCM="${JASPER_OUTPUTD_CHIP_REF_PCM:-plughw:CARD=${AEC_MIC_DEVICE},DEV=0}"
fi
CURRENT_MIC="${JASPER_MIC_DEVICE:-}"
# Additive wake-detection legs (see write_leg_env for the mapping).
# JASPER_AEC_MODE remains the master toggle; these only matter when
# the bridge is running. Defaults — RAW on (cheap, gives OR-fusion
# wake-rate recovery for ~5 MB), DTLN off (~75 MB + 25% one core,
# opt-in via /system/ wake-detection card).
LEG_RAW="$(normalize_bool "${JASPER_WAKE_LEG_RAW:-1}")"
LEG_DTLN="$(normalize_bool "${JASPER_WAKE_LEG_DTLN:-0}")"
# Chip-AEC beam legs — opt-in + mic-profile/DAC-conditional + mutually
# exclusive with raw/DTLN (see write_leg_env). Default off; only applied
# when the detected XVF profile has a validated production beam plan.
LEG_CHIP_AEC="$(normalize_bool "${JASPER_WAKE_LEG_CHIP_AEC:-0}")"
# Opt-in chip-ref observe mode (default off). Read like the LEG_* booleans
# (mode_file_value + normalize_bool) so a hand-edited yes/true also works.
# Only the software-AEC3 leg path in write_leg_env acts on it.
CHIP_REF_OBSERVE="$(normalize_bool "$(mode_file_value JASPER_AEC_CHIP_REF_OBSERVE 0)")"
AUDIO_DAC_ID="$(normalize_output_dac_id "${JASPER_AUDIO_DAC_ID:-unknown}")"
CHIP_AEC_TESTING_REQUESTED=0
if [[ "$AUDIO_INPUT_PROFILE" == "xvf_chip_aec_testing" ]]; then
    CHIP_AEC_TESTING_REQUESTED=1
fi
apply_audio_input_profile
if [[ "$AUDIO_INPUT_PROFILE" == "custom" && "$LEG_CHIP_AEC" == "1" ]]; then
    if ! chip_aec_mic_supported; then
        log "custom chip-AEC leg requested but mic cannot produce chip-AEC beams: $(chip_aec_mic_detail); clearing chip-AEC leg"
        LEG_CHIP_AEC="0"
    elif ! chip_aec_dac_supported "$AUDIO_DAC_ID" "0"; then
        log "custom chip-AEC leg requested but output_dac=${AUDIO_DAC_ID} is not approved for production chip-AEC: $(chip_aec_dac_detail "$AUDIO_DAC_ID" "0"); clearing chip-AEC leg"
        LEG_CHIP_AEC="0"
    fi
fi
refresh_chip_aec_dac_gate "$AUDIO_DAC_ID" "$CHIP_AEC_TESTING_REQUESTED"

if [[ "$CHECK_ONLY" == "1" ]]; then
    if [[ "$AEC_MODE" == "auto" ]] && aec_ready "$AEC_MIC_DEVICE"; then
        exit 0
    fi
    exit 1
fi

FALLBACK_MIC="$(first_candidate)"
PRESENT_MIC=""
if PRESENT_MIC="$(first_present_candidate)"; then
    :
else
    PRESENT_MIC=""
fi

log "profile=${AUDIO_INPUT_PROFILE} mode=${AEC_MODE} current_mic=${CURRENT_MIC:-<unset>} aec_mic=${AEC_MIC_DEVICE} candidates=${MIC_CANDIDATES[*]:-<none>} legs=raw:${LEG_RAW},dtln:${LEG_DTLN},chip_aec:${LEG_CHIP_AEC}"
write_mic_profile_env
if profile_managed_mic_resolution; then
    set_env_var "$ENV_FILE" JASPER_AEC_MIC_DEVICE "$AEC_MIC_DEVICE"
fi
write_chip_aec_gate_env

if grouping_voice_parked; then
    # Role park wins over every profile/mic shape below — including the
    # custom-mic early exit, which deliberately leaves voice untouched.
    # `disable --now` (not stop): voice must not boot-start its ~240 MB
    # of models for a few seconds on every reboot only to be re-parked
    # when this reconciler runs. restart_voice's un-park path already
    # re-enables. JASPER_MIC_DEVICE is left as-is: parking is role
    # state, not a mic decision, and the next solo/leader reconcile
    # resumes from an unchanged mic config.
    log "bonded follower (grouping-voice.env park flag): parking jasper-voice + AEC stack"
    run_systemctl disable --now jasper-voice.service
    reset_failed_units jasper-voice.service
    stop_disable_aec
    write_leg_env "0" "$LEG_RAW" "$LEG_DTLN" "$LEG_CHIP_AEC"
    restart_outputd_if_needed
    exit 0
fi

if ! is_owned_mic_value "$CURRENT_MIC" "$UDP_DEVICE"; then
    log "custom JASPER_MIC_DEVICE=${CURRENT_MIC}; leaving voice config untouched"
    # We don't manage custom mics, so we must not gate them: clear any
    # stale presence marker so jasper-voice can start and try the operator's
    # device. If it can't open, the daemon's exit-66 park (not a crash-loop)
    # is the safety net. Mirrors the "leave voice config untouched" contract.
    clear_voice_input_absent
    stop_disable_aec
    write_leg_env "0" "$LEG_RAW" "$LEG_DTLN" "$LEG_CHIP_AEC"
    restart_outputd_if_needed
    exit 0
fi

if [[ "$AEC_MODE" == "disabled" ]]; then
    if [[ -z "$PRESENT_MIC" ]]; then
        stop_voice
    fi
    stop_disable_aec
    write_leg_env "0" "$LEG_RAW" "$LEG_DTLN" "$LEG_CHIP_AEC"
    restart_outputd_if_needed
    if [[ -n "$PRESENT_MIC" ]]; then
        if [[ "$CURRENT_MIC" != "$PRESENT_MIC" ]]; then
            set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$PRESENT_MIC"
            log "AEC disabled; selected direct mic ${PRESENT_MIC}"
        else
            log "AEC disabled; direct mic already ${PRESENT_MIC}"
        fi
        restart_voice
    else
        if [[ "$CURRENT_MIC" == udp:* || -z "$CURRENT_MIC" ]]; then
            set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$FALLBACK_MIC"
            log "AEC disabled and no candidate mic present; cleared stale UDP to ${FALLBACK_MIC}"
        else
            log "AEC disabled and no candidate mic present"
        fi
    fi
    exit 0
fi

if aec_ready "$AEC_MIC_DEVICE"; then
    ensure_capture_mixer_open "$AEC_MIC_DEVICE"
    if [[ "$CURRENT_MIC" != "$UDP_DEVICE" ]]; then
        set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$UDP_DEVICE"
        log "6-channel ${AEC_MIC_DEVICE} present; selected AEC UDP mic ${UDP_DEVICE}"
    else
        log "6-channel ${AEC_MIC_DEVICE} present; AEC UDP mic already selected"
    fi
    write_leg_env "1" "$LEG_RAW" "$LEG_DTLN" "$LEG_CHIP_AEC"
    restart_outputd_if_needed
    enable_start_aec
    restart_voice
    exit 0
fi

if [[ -z "$PRESENT_MIC" ]]; then
    stop_voice
fi
stop_disable_aec
write_leg_env "0" "$LEG_RAW" "$LEG_DTLN" "$LEG_CHIP_AEC"
restart_outputd_if_needed
if [[ -n "$PRESENT_MIC" ]]; then
    if [[ "$CURRENT_MIC" != "$PRESENT_MIC" ]]; then
        set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$PRESENT_MIC"
        log "AEC mic not 6-channel; selected direct mic ${PRESENT_MIC}"
    else
        log "AEC mic not 6-channel; direct mic already ${PRESENT_MIC}"
    fi
    restart_voice
    exit 0
fi

if [[ "$CURRENT_MIC" == udp:* || -z "$CURRENT_MIC" || "$CURRENT_MIC" =~ ^hw:[0-9]+,1$ ]]; then
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$FALLBACK_MIC"
    log "no candidate mic present; cleared stale ${CURRENT_MIC:-<unset>} to ${FALLBACK_MIC}"
else
    log "no candidate mic present"
fi
