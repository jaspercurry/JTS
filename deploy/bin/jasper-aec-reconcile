#!/usr/bin/env bash
# Reconcile JTS mic/AEC state with the audio hardware currently present.
#
# This is intentionally a small policy layer around /etc/jasper/jasper.env
# and systemd. It keeps a stale JASPER_MIC_DEVICE=udp:PORT from stranding
# jasper-voice when the XVF Array is unplugged, while leaving a narrow config
# hook for future microphones via JASPER_MIC_DEVICE_CANDIDATES.

set -euo pipefail

ENV_FILE="${JASPER_ENV_FILE:-/etc/jasper/jasper.env}"
MODE_FILE="${JASPER_AEC_MODE_FILE:-/var/lib/jasper/aec_mode.env}"
ASOUND_ROOT="${JASPER_ASOUND_ROOT:-/proc/asound}"
SYSTEMCTL="${JASPER_SYSTEMCTL:-systemctl}"
REASON="manual"
CHECK_ONLY=0
OUTPUTD_RESTART_NEEDED=0

usage() {
    cat <<'EOF'
Usage: jasper-aec-reconcile [--reason TEXT] [--check-aec-ready]

Reconcile microphone/AEC systemd state:
  - auto + 6-channel Array present -> JASPER_MIC_DEVICE=udp:PORT, AEC on
  - auto + direct mic present only -> JASPER_MIC_DEVICE=<mic>, AEC off
  - owned mic config + no mic present -> clear stale UDP, stop voice
  - custom JASPER_MIC_DEVICE -> leave voice config alone, keep AEC off

--check-aec-ready exits 0 only when AEC mode is auto and the configured
AEC mic is present with 6 channels. It performs no mutations and is used as
jasper-aec-bridge.service's ExecCondition.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --reason)
            REASON="${2:-manual}"
            shift 2
            ;;
        --check-aec-ready)
            CHECK_ONLY=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

log() {
    echo "jasper-aec-reconcile[$REASON]: $*" >&2
}

load_env_file() {
    local file="$1"
    if [[ -f "$file" ]]; then
        # shellcheck disable=SC1090
        set -a
        source "$file"
        set +a
    fi
}

ensure_mode_file() {
    if [[ -f "$MODE_FILE" ]]; then
        # File exists. Seed any missing keys so an older deploy's
        # mode file picks up the new leg defaults on next reconcile.
        # Existing values for already-present keys are left alone.
        if ! grep -q '^JASPER_WAKE_LEG_RAW=' "$MODE_FILE"; then
            printf 'JASPER_WAKE_LEG_RAW=1\n' >> "$MODE_FILE"
        fi
        if ! grep -q '^JASPER_WAKE_LEG_DTLN=' "$MODE_FILE"; then
            printf 'JASPER_WAKE_LEG_DTLN=0\n' >> "$MODE_FILE"
        fi
        if ! grep -q '^JASPER_WAKE_LEG_CHIP_AEC=' "$MODE_FILE"; then
            printf 'JASPER_WAKE_LEG_CHIP_AEC=0\n' >> "$MODE_FILE"
        fi
        return
    fi
    install -d -m 0755 "$(dirname "$MODE_FILE")"
    printf 'JASPER_AEC_MODE=auto\nJASPER_WAKE_LEG_RAW=1\nJASPER_WAKE_LEG_DTLN=0\nJASPER_WAKE_LEG_CHIP_AEC=0\n' > "$MODE_FILE"
    chmod 0644 "$MODE_FILE"
}

quote_env_value() {
    printf '%q' "$1"
}

set_env_var() {
    local file="$1"
    local key="$2"
    local value="$3"
    local dir tmp quoted

    dir="$(dirname "$file")"
    install -d -m 0755 "$dir"
    tmp="$(mktemp "${dir}/.${key}.XXXXXX")"
    quoted="$(quote_env_value "$value")"

    if [[ -f "$file" ]]; then
        awk -v key="$key" -v line="${key}=${quoted}" '
            $0 ~ "^[[:space:]]*" key "=" {
                if (!done) {
                    print line
                    done = 1
                }
                next
            }
            { print }
            END {
                if (!done) {
                    print line
                }
            }
        ' "$file" > "$tmp"
    else
        printf '%s=%s\n' "$key" "$quoted" > "$tmp"
    fi

    chmod 0600 "$tmp"
    mv "$tmp" "$file"
}

mark_outputd_restart_if_changed() {
    local key="$1"
    local desired="$2"
    local current="${!key-}"
    if [[ "$current" != "$desired" ]]; then
        OUTPUTD_RESTART_NEEDED=1
    fi
}

normalize_mode() {
    local mode="${1:-auto}"
    mode="$(printf '%s' "$mode" | tr '[:upper:]' '[:lower:]')"
    case "$mode" in
        auto|"")
            echo "auto"
            ;;
        disabled|disable|off|false|0|no)
            echo "disabled"
            ;;
        *)
            log "unknown JASPER_AEC_MODE=${mode}; treating as disabled"
            echo "disabled"
            ;;
    esac
}

# Normalize the JASPER_WAKE_LEG_* booleans to "1" or "0". The wizard
# only writes "1" / "0", but operators editing aec_mode.env by hand
# might use yes/no/true/false. Default is supplied by the caller —
# RAW defaults on, DTLN defaults off.
normalize_bool() {
    local value="${1:-}"
    value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
    case "$value" in
        1|on|true|yes|y|enabled|enable)
            echo "1"
            ;;
        0|off|false|no|n|disabled|disable|"")
            echo "0"
            ;;
        *)
            log "unknown bool ${value}; treating as 0"
            echo "0"
            ;;
    esac
}

# Map wake-leg booleans to the underlying env vars that
# jasper-aec-bridge and jasper-voice each read at startup. When the
# bridge isn't going to run (bridge_running="0"), clear them all —
# they're meaningless without a bridge emitting on the UDP ports,
# and a stale JASPER_MIC_DEVICE_RAW=udp:9877 leaves the voice
# secondary UdpMicCapture spinning on a port nobody talks to.
#
# Single-chip mutual exclusion (chip-AEC): the XVF chip can emit EITHER
# the software legs (raw :9877 / DTLN :9878 alongside AEC3 :9876) OR the
# chip-AEC beams, not both — Option-A means in chip-AEC mode the bridge
# forwards the chip-AEC beam into :9876 (session + Tier-1 heartbeat
# carrier) and emits the fixed 150°/210° ASR beams on :9887/:9888 for
# scoring. So when chip-AEC is on we clear raw/DTLN, and vice versa.
#
# The booleans themselves stay preserved in $MODE_FILE — that's the
# user's wizard-managed intent. We just don't *apply* them when the
# bridge is down. When the user re-enables AEC, the legs they had
# configured come back automatically on the next reconcile pass.
write_leg_env() {
    local bridge_running="$1"
    local leg_raw="$2"
    local leg_dtln="$3"
    local leg_chip_aec="$4"
    local raw_udp dtln_udp dtln_flag chip_150_udp chip_210_udp chip_flag
    local ref_source outputd_chip_ref_pcm outputd_ref_target
    local outputd_chip_ref_rate outputd_chip_ref_period outputd_chip_ref_buffer
    local bridge_ref_host bridge_ref_port producer_was_active
    producer_was_active=0
    if [[ -n "${JASPER_OUTPUTD_CHIP_REF_PCM-}" || -n "${JASPER_OUTPUTD_REFERENCE_UDP_TARGET-}" ]]; then
        producer_was_active=1
    fi
    if [[ "$bridge_running" == "1" && "$leg_chip_aec" == "1" ]]; then
        # Chip-AEC production mode (Option-A): score the fixed 150°/210°
        # beams on :9887/:9888; the chip-AEC beam is forwarded into :9876
        # as the session/heartbeat carrier. raw/DTLN are NOT emitted by
        # the bridge in this mode, so clear them (single-chip exclusion).
        #
        chip_150_udp="udp:${AEC_UDP_PORT_CHIP_AEC_150}"
        chip_210_udp="udp:${AEC_UDP_PORT_CHIP_AEC_210}"
        chip_flag="1"
        raw_udp=""
        dtln_udp=""
        dtln_flag="0"
        ref_source="outputd_udp"
        bridge_ref_host="127.0.0.1"
        bridge_ref_port="${AEC_OUTPUTD_REF_UDP_PORT}"
        outputd_chip_ref_pcm="${OUTPUTD_CHIP_REF_PCM}"
        outputd_ref_target="${bridge_ref_host}:${bridge_ref_port}"
        outputd_chip_ref_rate="${OUTPUTD_CHIP_REF_SAMPLE_RATE}"
        outputd_chip_ref_period="${OUTPUTD_CHIP_REF_PERIOD_FRAMES}"
        outputd_chip_ref_buffer="${OUTPUTD_CHIP_REF_BUFFER_FRAMES}"
    elif [[ "$bridge_running" == "1" ]]; then
        # Software-leg mode (today's default): raw/DTLN as configured,
        # chip beams cleared.
        if [[ "$leg_raw" == "1" ]]; then
            raw_udp="udp:${AEC_UDP_PORT_RAW}"
        else
            raw_udp=""
        fi
        if [[ "$leg_dtln" == "1" ]]; then
            dtln_udp="udp:${AEC_UDP_PORT_DTLN}"
            dtln_flag="1"
        else
            dtln_udp=""
            dtln_flag="0"
        fi
        chip_150_udp=""
        chip_210_udp=""
        chip_flag="0"
        ref_source="alsa"
        bridge_ref_host="127.0.0.1"
        bridge_ref_port="${AEC_OUTPUTD_REF_UDP_PORT}"
        outputd_chip_ref_pcm=""
        outputd_ref_target=""
        outputd_chip_ref_rate="${OUTPUTD_CHIP_REF_SAMPLE_RATE}"
        outputd_chip_ref_period="${OUTPUTD_CHIP_REF_PERIOD_FRAMES}"
        outputd_chip_ref_buffer="${OUTPUTD_CHIP_REF_BUFFER_FRAMES}"
    else
        raw_udp=""
        dtln_udp=""
        dtln_flag="0"
        chip_150_udp=""
        chip_210_udp=""
        chip_flag="0"
        ref_source="alsa"
        bridge_ref_host="127.0.0.1"
        bridge_ref_port="${AEC_OUTPUTD_REF_UDP_PORT}"
        outputd_chip_ref_pcm=""
        outputd_ref_target=""
        outputd_chip_ref_rate="${OUTPUTD_CHIP_REF_SAMPLE_RATE}"
        outputd_chip_ref_period="${OUTPUTD_CHIP_REF_PERIOD_FRAMES}"
        outputd_chip_ref_buffer="${OUTPUTD_CHIP_REF_BUFFER_FRAMES}"
    fi
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE_RAW "$raw_udp"
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE_DTLN "$dtln_udp"
    set_env_var "$ENV_FILE" JASPER_AEC_DTLN_ENABLED "$dtln_flag"
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE_CHIP_AEC_150 "$chip_150_udp"
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE_CHIP_AEC_210 "$chip_210_udp"
    set_env_var "$ENV_FILE" JASPER_AEC_CHIP_AEC_ENABLED "$chip_flag"
    set_env_var "$ENV_FILE" JASPER_AEC_REF_SOURCE "$ref_source"
    set_env_var "$ENV_FILE" JASPER_AEC_OUTPUTD_REF_UDP_HOST "$bridge_ref_host"
    set_env_var "$ENV_FILE" JASPER_AEC_OUTPUTD_REF_UDP_PORT "$bridge_ref_port"

    mark_outputd_restart_if_changed JASPER_OUTPUTD_CHIP_REF_PCM "$outputd_chip_ref_pcm"
    mark_outputd_restart_if_changed JASPER_OUTPUTD_REFERENCE_UDP_TARGET "$outputd_ref_target"
    if [[ "$chip_flag" == "1" || "$producer_was_active" == "1" ]]; then
        mark_outputd_restart_if_changed JASPER_OUTPUTD_CHIP_REF_SAMPLE_RATE "$outputd_chip_ref_rate"
        mark_outputd_restart_if_changed JASPER_OUTPUTD_CHIP_REF_PERIOD_FRAMES "$outputd_chip_ref_period"
        mark_outputd_restart_if_changed JASPER_OUTPUTD_CHIP_REF_BUFFER_FRAMES "$outputd_chip_ref_buffer"
    fi
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_CHIP_REF_PCM "$outputd_chip_ref_pcm"
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_REFERENCE_UDP_TARGET "$outputd_ref_target"
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_CHIP_REF_SAMPLE_RATE "$outputd_chip_ref_rate"
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_CHIP_REF_PERIOD_FRAMES "$outputd_chip_ref_period"
    set_env_var "$ENV_FILE" JASPER_OUTPUTD_CHIP_REF_BUFFER_FRAMES "$outputd_chip_ref_buffer"
}

card_id_from_spec() {
    local spec="$1"
    if [[ "$spec" =~ CARD=([^,]+) ]]; then
        echo "${BASH_REMATCH[1]}"
    elif [[ "$spec" =~ ^(hw|plughw):([^,]+) ]]; then
        echo "${BASH_REMATCH[2]}"
    else
        echo "$spec"
    fi
}

card_stream_file() {
    local spec="$1"
    local card
    card="$(card_id_from_spec "$spec")"
    echo "${ASOUND_ROOT}/${card}/stream0"
}

mic_present() {
    local spec="$1"
    [[ -f "$(card_stream_file "$spec")" ]]
}

mic_channels() {
    local spec="$1"
    local stream channels
    stream="$(card_stream_file "$spec")"
    if [[ ! -f "$stream" ]]; then
        echo 0
        return
    fi
    # /proc/asound/<card>/stream0 has separate Playback and Capture
    # blocks, each with its own "Channels:" line. We need the Capture
    # one — the XVF chip's Playback endpoint is 2-ch even when Capture
    # is 6-ch on the 6-ch firmware. Pinning to ^Capture: prevents a
    # silent fallback to direct-mic when AEC should be enabled.
    channels="$(awk '/^Capture:/{cap=1} cap && /Channels:[[:space:]]*[0-9]+/{print; exit}' "$stream" \
        | grep -oE "[0-9]+" \
        | head -1)"
    echo "${channels:-0}"
}

aec_ready() {
    local mic="$1"
    [[ "$(mic_channels "$mic")" == "6" ]]
}

# When the chip is flashed from the 2-ch firmware to the 6-ch firmware
# (the BRINGUP path), ALSA assigns mixer slots for the new ch2-5 with
# default values of off / 0 dB. `alsactl restore` then persists that
# state across reboot — silencing the raw mics in the kernel
# independently of the chip's own configuration, with no surface that
# would let the operator notice. Force the capture channels open
# whenever we confirm the chip is on 6-ch firmware. Idempotent; safe
# to run on every reconcile pass.
#
# Canonical reference for these mixer names + the rationale: the
# `jasper.mics.xvf3800` Python profile. This reconciler is bash and
# can't import Python; if the names or channel count change in the
# profile, update them here too. The doctor's `check_xvf_mixer_state`
# reads from the profile and flags drift if the two get out of sync.
ensure_capture_mixer_open() {
    local spec="$1"
    local card
    card="$(card_id_from_spec "$spec")"
    amixer -c "$card" cset name='Headset Capture Switch' \
        on,on,on,on,on,on >/dev/null 2>&1 || true
    amixer -c "$card" cset name='Headset Capture Volume' \
        60,60,60,60,60,60 >/dev/null 2>&1 || true
    alsactl store >/dev/null 2>&1 || true
}

split_candidates() {
    local raw="$1"
    raw="${raw//,/ }"
    # shellcheck disable=SC2206
    MIC_CANDIDATES=($raw)
}

first_candidate() {
    if [[ ${#MIC_CANDIDATES[@]} -gt 0 ]]; then
        echo "${MIC_CANDIDATES[0]}"
    else
        echo "$AEC_MIC_DEVICE"
    fi
}

first_present_candidate() {
    local candidate
    for candidate in "${MIC_CANDIDATES[@]}"; do
        if mic_present "$candidate"; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

is_candidate_value() {
    local value="$1"
    local candidate
    for candidate in "${MIC_CANDIDATES[@]}"; do
        [[ "$value" == "$candidate" ]] && return 0
    done
    return 1
}

is_owned_mic_value() {
    local value="$1"
    local udp_device="$2"
    [[ -z "$value" ]] && return 0
    [[ "$value" == "$udp_device" ]] && return 0
    [[ "$value" == udp:* ]] && return 0
    [[ "$value" =~ ^hw:[0-9]+,1$ ]] && return 0
    is_candidate_value "$value" && return 0
    return 1
}

run_systemctl() {
    "$SYSTEMCTL" "$@" || true
}

reset_failed_units() {
    local unit
    for unit in "$@"; do
        # `reset-failed` is intentionally unconditional: besides clearing
        # a failed state, systemd also clears the unit's start-rate
        # counters. A controlled deploy/reconcile/toggle sequence can
        # otherwise accumulate enough clean restarts to hit
        # StartLimitAction=reboot even though no service is unhealthy.
        run_systemctl reset-failed "$unit"
    done
}

stop_disable_aec() {
    run_systemctl stop jasper-aec-bridge.service jasper-aec-init.service
    run_systemctl disable jasper-aec-bridge.service jasper-aec-init.service
    reset_failed_units jasper-aec-bridge.service jasper-aec-init.service
}

enable_start_aec() {
    run_systemctl enable jasper-aec-init.service jasper-aec-bridge.service
    reset_failed_units jasper-aec-init.service jasper-aec-bridge.service
    # `restart` not `start`: jasper-aec-init is Type=oneshot with
    # RemainAfterExit=yes, so `start` is a no-op once it's run
    # successfully. Any chip-side param changes from a code deploy
    # (HPF cutoff, SHF_BYPASS, future tuning) would silently NOT
    # re-apply until the next reboot. `restart` forces re-execution.
    # Discovered 2026-05-15 after a deploy left chip params at their
    # previous boot-time values despite code expecting newer ones.
    run_systemctl restart jasper-aec-init.service
    run_systemctl restart jasper-aec-bridge.service
}

restart_voice() {
    reset_failed_units jasper-voice.service
    run_systemctl restart jasper-voice.service
}

restart_outputd_if_needed() {
    if [[ "$OUTPUTD_RESTART_NEEDED" == "1" ]]; then
        reset_failed_units jasper-outputd.service
        run_systemctl restart jasper-outputd.service
    fi
}

stop_voice() {
    run_systemctl stop jasper-voice.service
    reset_failed_units jasper-voice.service
}

load_env_file "$ENV_FILE"
if [[ "$CHECK_ONLY" != "1" ]]; then
    ensure_mode_file
fi
load_env_file "$MODE_FILE"

AEC_MODE="$(normalize_mode "${JASPER_AEC_MODE:-auto}")"
AEC_MIC_DEVICE="${JASPER_AEC_MIC_DEVICE:-Array}"
AEC_UDP_PORT="${JASPER_AEC_UDP_PORT:-9876}"
AEC_UDP_PORT_RAW="${JASPER_AEC_UDP_PORT_RAW:-9877}"
AEC_UDP_PORT_DTLN="${JASPER_AEC_UDP_PORT_DTLN:-9878}"
AEC_UDP_PORT_CHIP_AEC_150="${JASPER_AEC_UDP_PORT_CHIP_AEC_150:-9887}"
AEC_UDP_PORT_CHIP_AEC_210="${JASPER_AEC_UDP_PORT_CHIP_AEC_210:-9888}"
AEC_OUTPUTD_REF_UDP_PORT="${JASPER_AEC_OUTPUTD_REF_UDP_PORT:-9891}"
OUTPUTD_CHIP_REF_PCM="${JASPER_OUTPUTD_CHIP_REF_PCM:-plughw:CARD=Array,DEV=0}"
OUTPUTD_CHIP_REF_SAMPLE_RATE="${JASPER_OUTPUTD_CHIP_REF_SAMPLE_RATE:-16000}"
OUTPUTD_CHIP_REF_PERIOD_FRAMES="${JASPER_OUTPUTD_CHIP_REF_PERIOD_FRAMES:-320}"
OUTPUTD_CHIP_REF_BUFFER_FRAMES="${JASPER_OUTPUTD_CHIP_REF_BUFFER_FRAMES:-1280}"
UDP_DEVICE="udp:${AEC_UDP_PORT}"
split_candidates "${JASPER_MIC_DEVICE_CANDIDATES:-$AEC_MIC_DEVICE}"
CURRENT_MIC="${JASPER_MIC_DEVICE:-}"
# Additive wake-detection legs (see write_leg_env for the mapping).
# JASPER_AEC_MODE remains the master toggle; these only matter when
# the bridge is running. Defaults — RAW on (cheap, gives OR-fusion
# wake-rate recovery for ~5 MB), DTLN off (~75 MB + 25% one core,
# opt-in via /system/ wake-detection card).
LEG_RAW="$(normalize_bool "${JASPER_WAKE_LEG_RAW:-1}")"
LEG_DTLN="$(normalize_bool "${JASPER_WAKE_LEG_DTLN:-0}")"
# Chip-AEC beam legs (XVF3800 fixed 150°/210° hardware-AEC ASR beams) —
# opt-in + hardware-conditional + mutually exclusive with raw/DTLN (see
# write_leg_env). Default off; only applied on the 6-channel-present
# (bridge-running) path, so it's structurally gated on the firmware.
LEG_CHIP_AEC="$(normalize_bool "${JASPER_WAKE_LEG_CHIP_AEC:-0}")"

if [[ "$CHECK_ONLY" == "1" ]]; then
    if [[ "$AEC_MODE" == "auto" ]] && aec_ready "$AEC_MIC_DEVICE"; then
        exit 0
    fi
    exit 1
fi

FALLBACK_MIC="$(first_candidate)"
PRESENT_MIC=""
if PRESENT_MIC="$(first_present_candidate)"; then
    :
else
    PRESENT_MIC=""
fi

log "mode=${AEC_MODE} current_mic=${CURRENT_MIC:-<unset>} aec_mic=${AEC_MIC_DEVICE} candidates=${MIC_CANDIDATES[*]:-<none>} legs=raw:${LEG_RAW},dtln:${LEG_DTLN},chip_aec:${LEG_CHIP_AEC}"

if ! is_owned_mic_value "$CURRENT_MIC" "$UDP_DEVICE"; then
    log "custom JASPER_MIC_DEVICE=${CURRENT_MIC}; leaving voice config untouched"
    stop_disable_aec
    write_leg_env "0" "$LEG_RAW" "$LEG_DTLN" "$LEG_CHIP_AEC"
    restart_outputd_if_needed
    exit 0
fi

if [[ "$AEC_MODE" == "disabled" ]]; then
    stop_disable_aec
    write_leg_env "0" "$LEG_RAW" "$LEG_DTLN" "$LEG_CHIP_AEC"
    restart_outputd_if_needed
    if [[ -n "$PRESENT_MIC" ]]; then
        if [[ "$CURRENT_MIC" != "$PRESENT_MIC" ]]; then
            set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$PRESENT_MIC"
            log "AEC disabled; selected direct mic ${PRESENT_MIC}"
        else
            log "AEC disabled; direct mic already ${PRESENT_MIC}"
        fi
        restart_voice
    else
        if [[ "$CURRENT_MIC" == udp:* || -z "$CURRENT_MIC" ]]; then
            set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$FALLBACK_MIC"
            log "AEC disabled and no candidate mic present; cleared stale UDP to ${FALLBACK_MIC}"
        else
            log "AEC disabled and no candidate mic present"
        fi
        stop_voice
    fi
    exit 0
fi

if aec_ready "$AEC_MIC_DEVICE"; then
    ensure_capture_mixer_open "$AEC_MIC_DEVICE"
    if [[ "$CURRENT_MIC" != "$UDP_DEVICE" ]]; then
        set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$UDP_DEVICE"
        log "6-channel ${AEC_MIC_DEVICE} present; selected AEC UDP mic ${UDP_DEVICE}"
    else
        log "6-channel ${AEC_MIC_DEVICE} present; AEC UDP mic already selected"
    fi
    write_leg_env "1" "$LEG_RAW" "$LEG_DTLN" "$LEG_CHIP_AEC"
    restart_outputd_if_needed
    enable_start_aec
    restart_voice
    exit 0
fi

stop_disable_aec
write_leg_env "0" "$LEG_RAW" "$LEG_DTLN" "$LEG_CHIP_AEC"
restart_outputd_if_needed
if [[ -n "$PRESENT_MIC" ]]; then
    if [[ "$CURRENT_MIC" != "$PRESENT_MIC" ]]; then
        set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$PRESENT_MIC"
        log "AEC mic not 6-channel; selected direct mic ${PRESENT_MIC}"
    else
        log "AEC mic not 6-channel; direct mic already ${PRESENT_MIC}"
    fi
    restart_voice
    exit 0
fi

if [[ "$CURRENT_MIC" == udp:* || -z "$CURRENT_MIC" || "$CURRENT_MIC" =~ ^hw:[0-9]+,1$ ]]; then
    set_env_var "$ENV_FILE" JASPER_MIC_DEVICE "$FALLBACK_MIC"
    log "no candidate mic present; cleared stale ${CURRENT_MIC:-<unset>} to ${FALLBACK_MIC}"
else
    log "no candidate mic present"
fi
stop_voice
