#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Jasper Curry
#
# SPDX-License-Identifier: Apache-2.0

# Pin the Apple USB-C dongle Headphone mixer control to 100%.
#
# Usage: jasper-dac-init [card|auto] [control]
#
# The service may be enabled on non-Apple-DAC systems. In auto mode it
# detects the Apple dongle at runtime and exits cleanly when absent.

set -uo pipefail

CONFIGURED_CARD="${1:-auto}"
CONTROL="${2:-Headphone}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
APPLE_DONGLE_LIB="${JASPER_APPLE_DONGLE_LIB:-}"
if [[ -z "$APPLE_DONGLE_LIB" ]]; then
    if [[ -r "${SCRIPT_DIR}/../lib/jasper-apple-dongle.sh" ]]; then
        APPLE_DONGLE_LIB="${SCRIPT_DIR}/../lib/jasper-apple-dongle.sh"
    else
        APPLE_DONGLE_LIB="/usr/local/lib/jasper/jasper-apple-dongle.sh"
    fi
fi
# shellcheck disable=SC1090  # runtime path is repo-sibling or installed fallback
if [[ ! -r "$APPLE_DONGLE_LIB" ]] || ! source "$APPLE_DONGLE_LIB"; then
    echo "event=apple_dongle.dac_init.failed reason=common_lib_unavailable" >&2
    exit 1
fi

mapfile -t CARDS < <(resolve_cards)
if [[ "${#CARDS[@]}" -eq 0 ]]; then
    echo "event=apple_dongle.dac_init.skip reason=not_detected configured_card=${CONFIGURED_CARD} control=${CONTROL}"
    exit 0
fi

failed=0
for CARD in "${CARDS[@]}"; do
    [[ -n "$CARD" ]] || continue
    if amixer -c "$CARD" -- sset "$CONTROL" 100% unmute >/dev/null 2>&1; then
        echo "event=apple_dongle.dac_init.pinned card=${CARD} control=${CONTROL} value=100"
    else
        echo "event=apple_dongle.dac_init.failed card=${CARD} control=${CONTROL} reason=amixer_nonzero" >&2
        failed=1
    fi
done

exit "$failed"
