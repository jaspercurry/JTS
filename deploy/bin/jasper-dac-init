#!/usr/bin/env bash
# Pin the Apple USB-C dongle Headphone mixer control to 100%.
#
# Usage: jasper-dac-init [card|auto] [control]
#
# The service may be enabled on non-Apple-DAC systems. In auto mode it
# detects the Apple dongle at runtime and exits cleanly when absent.

set -uo pipefail

CONFIGURED_CARD="${1:-auto}"
CONTROL="${2:-Headphone}"
APPLE_DONGLE_REGEX="usb-c to 3.5mm"

detect_apple_cards() {
    aplay -L 2>/dev/null \
        | grep -B1 -iE "$APPLE_DONGLE_REGEX" \
        | grep -oE 'CARD=[^,]+' \
        | sed 's/CARD=//' \
        || true
}

resolve_cards() {
    if [[ -n "$CONFIGURED_CARD" && "$CONFIGURED_CARD" != "auto" ]]; then
        printf '%s\n' "$CONFIGURED_CARD"
        return 0
    fi
    detect_apple_cards
}

mapfile -t CARDS < <(resolve_cards)
if [[ "${#CARDS[@]}" -eq 0 ]]; then
    echo "event=apple_dongle.dac_init.skip reason=not_detected configured_card=${CONFIGURED_CARD} control=${CONTROL}"
    exit 0
fi

failed=0
for CARD in "${CARDS[@]}"; do
    [[ -n "$CARD" ]] || continue
    if amixer -c "$CARD" -- sset "$CONTROL" 100% unmute >/dev/null 2>&1; then
        echo "event=apple_dongle.dac_init.pinned card=${CARD} control=${CONTROL} value=100"
    else
        echo "event=apple_dongle.dac_init.failed card=${CARD} control=${CONTROL} reason=amixer_nonzero" >&2
        failed=1
    fi
done

exit "$failed"
