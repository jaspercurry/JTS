#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Jasper Curry
#
# SPDX-License-Identifier: Apache-2.0

# Reconcile JTS output-DAC role with the ALSA hardware currently present.
#
# This is the output-hardware counterpart to jasper-aec-reconcile:
# run once at install/boot, and run again from udev on sound-card
# add/remove/change. It is intentionally small and idempotent.

set -euo pipefail

ENV_FILE="${JASPER_ENV_FILE:-/etc/jasper/jasper.env}"
OUTPUTD_ENV_FILE="${JASPER_OUTPUTD_ENV_FILE:-/var/lib/jasper/outputd.env}"
FANIN_ENV_FILE="${JASPER_FANIN_ENV_FILE:-/var/lib/jasper/fanin.env}"
USBSINK_ENV_FILE="${JASPER_USBSINK_ENV_FILE:-/var/lib/jasper/usbsink.env}"
ASOUND_SOURCE_TEMPLATE="${JASPER_ASOUND_SOURCE_TEMPLATE:-/etc/jasper/asoundrc.jasper.source}"
ASOUND_TEMPLATE="${JASPER_ASOUND_TEMPLATE:-/etc/jasper/asoundrc.jasper.template}"
RENDER_ASOUND_CONF="${JASPER_RENDER_ASOUND_CONF:-/usr/local/sbin/jasper-render-asound-conf}"
SYSTEMCTL="${JASPER_SYSTEMCTL:-systemctl}"
APLAY="${JASPER_APLAY:-aplay}"
DEFAULT_OUTPUT_HARDWARE_PYTHON="python3"
if [[ -x /opt/jasper/.venv/bin/python ]]; then
    DEFAULT_OUTPUT_HARDWARE_PYTHON="/opt/jasper/.venv/bin/python"
fi
OUTPUT_HARDWARE_PYTHON="${JASPER_OUTPUT_HARDWARE_PYTHON:-$DEFAULT_OUTPUT_HARDWARE_PYTHON}"
OUTPUT_HARDWARE_STATE_PATH="${JASPER_OUTPUT_HARDWARE_STATE_PATH:-/run/jasper-output-hardware/output_hardware.json}"
OUTPUT_TOPOLOGY_PATH="${JASPER_OUTPUT_TOPOLOGY_PATH:-/var/lib/jasper/output_topology.json}"
CAMILLA_STATEFILE="${JASPER_CAMILLA_STATEFILE:-/var/lib/camilladsp/outputd-statefile.yml}"
CAMILLA2_STATEFILE="${JASPER_CAMILLA2_STATEFILE:-/var/lib/camilladsp/crossover-statefile.yml}"
REASON="manual"
PRINT_ENV=0
NO_RESTART=0
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ASOUND_RENDER_LIB="${JASPER_ASOUND_RENDER_LIB:-}"
ENV_FILE_LIB="${JASPER_ENV_FILE_LIB:-}"

# Shared quoting helper (jasper_env_quote_value) — single
# implementation for both reconcilers so the PR #534 bash-%q
# comma-corruption bug class cannot fork again.
# SCRIPT_DIR-relative sibling first, installed path as fallback:
# install.sh runs THIS script from the repo mid-install (install_alsa's
# --print-env) BEFORE install_systemd_units refreshes /usr/local/lib,
# so installed-first could pair the new script with a stale lib.
# Sibling-first keeps script and lib versions in lockstep; the
# installed copy under /usr/local/sbin has no ../lib sibling and falls
# through to the installed lib. Deliberately diverges from
# load_asound_render_lib below (left installed-first): the mid-install
# --print-env run exits before any asound rendering, and install.sh's
# own rendering sources that lib straight from REPO_DIR at the top of
# the file — so the render lib has no new-script/stale-lib exposure
# worth churning its order for.
load_env_file_lib() {
    if [[ -z "$ENV_FILE_LIB" ]]; then
        if [[ -r "${SCRIPT_DIR}/../lib/jasper-env-file.sh" ]]; then
            ENV_FILE_LIB="${SCRIPT_DIR}/../lib/jasper-env-file.sh"
        else
            ENV_FILE_LIB="/usr/local/lib/jasper/jasper-env-file.sh"
        fi
    fi
    if [[ ! -r "$ENV_FILE_LIB" ]]; then
        echo "jasper-audio-hardware-reconcile: missing env-file library: ${ENV_FILE_LIB}" >&2
        exit 66
    fi
    # shellcheck disable=SC1090
    source "$ENV_FILE_LIB"
}

load_asound_render_lib() {
    if [[ -z "$ASOUND_RENDER_LIB" ]]; then
        if [[ -r /usr/local/lib/jasper/jasper-asound-render.sh ]]; then
            ASOUND_RENDER_LIB="/usr/local/lib/jasper/jasper-asound-render.sh"
        else
            ASOUND_RENDER_LIB="${SCRIPT_DIR}/../lib/jasper-asound-render.sh"
        fi
    fi
    if [[ ! -r "$ASOUND_RENDER_LIB" ]]; then
        echo "jasper-audio-hardware-reconcile: missing asound render library: ${ASOUND_RENDER_LIB}" >&2
        exit 66
    fi
    # The path varies at runtime (installed /usr/local/lib vs in-repo
    # fallback above), but both resolve to the same library — the
    # directive points at the repo copy so shellcheck can actually
    # analyze it. Outside the repo root the directive degrades to
    # info-level SC1091 ("not following"), below the CI gate's
    # warning severity.
    # shellcheck source=deploy/lib/jasper-asound-render.sh
    source "$ASOUND_RENDER_LIB"
}

usage() {
    cat <<'EOF'
Usage: jasper-audio-hardware-reconcile [--reason TEXT] [--print-env] [--no-restart]

Detect the current final-output DAC role and reconcile owned JTS state:
  - DAC8x/DAC8x Studio present -> outputd_dac targets it; Apple mixer helpers disabled
  - Apple USB-C dongle present -> outputd_dac targets Apple; Apple helpers enabled
  - no recognized output DAC -> Apple helpers disabled; unknown/fallback id recorded

--print-env prints shell-quoted role variables for install.sh and performs no mutations.
--no-restart updates files/service enablement but does not restart outputd/voice.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --reason)
            [[ $# -ge 2 ]] || { usage >&2; exit 2; }
            REASON="$2"
            shift 2
            ;;
        --print-env)
            PRINT_ENV=1
            shift
            ;;
        --no-restart)
            NO_RESTART=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

load_env_file_lib
load_asound_render_lib

# Quoting is the shared lib's jasper_env_quote_value (sourced by
# load_env_file_lib above); this thin alias keeps print_env readable.
quote_env_value() {
    jasper_env_quote_value "$1"
}

log_event() {
    local name="$1"
    shift
    echo "event=audio_hardware_reconcile.${name} reason=${REASON} $*" >&2
}

find_card() {
    local regex="$1"
    "$APLAY" -L 2>/dev/null \
        | grep -B1 -iE "$regex" \
        | grep -oE 'CARD=[^,]+' \
        | head -1 \
        | sed 's/CARD=//' \
        || true
}

observe_output_hardware_state() {
    local should_write="${1:-0}"
    local payload profile_id profile_status
    local action="observed"
    local args=()
    if [[ "$should_write" == "1" ]]; then
        args+=(--write)
        action="written"
    fi
    if ! command -v "$OUTPUT_HARDWARE_PYTHON" >/dev/null 2>&1; then
        log_event "state_${action}_skip" "reason=python_unavailable path=${OUTPUT_HARDWARE_STATE_PATH}"
        return 0
    fi
    if ! payload="$(
        JASPER_APLAY="$APLAY" \
        JASPER_OUTPUT_HARDWARE_STATE_PATH="$OUTPUT_HARDWARE_STATE_PATH" \
        "$OUTPUT_HARDWARE_PYTHON" -m jasper.output_hardware "${args[@]}" 2>/dev/null
    )"; then
        log_event "state_${action}_failed" "path=${OUTPUT_HARDWARE_STATE_PATH}"
        return 0
    fi
    OBSERVED_OUTPUT_PAYLOAD="$payload"
    profile_id="$(printf '%s' "$payload" | sed -n 's/.*"profile_id": *"\([^"]*\)".*/\1/p')"
    profile_status="$(printf '%s' "$payload" | sed -n 's/.*"status": *"\([^"]*\)".*/\1/p')"
    OBSERVED_OUTPUT_PROFILE_ID="$profile_id"
    OBSERVED_OUTPUT_PROFILE_STATUS="$profile_status"
    log_event "state_${action}" \
        "path=${OUTPUT_HARDWARE_STATE_PATH} profile_id=${profile_id:-unknown} status=${profile_status:-unknown}"
}

env_file_value() {
    local key="$1"
    if [[ ! -f "$ENV_FILE" ]]; then
        return 0
    fi
    awk -v key="$key" '
        $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
            value = $0
            sub("^[[:space:]]*" key "[[:space:]]*=[[:space:]]*", "", value)
            found = value
            seen = 1
        }
        END {
            if (seen) {
                print found
            }
        }
    ' "$ENV_FILE" \
        | sed -E "s/^[[:space:]]+//; s/[[:space:]]+$//; s/^[\"']//; s/[\"']$//"
}

set_env_var() {
    local key="$1" value="$2"
    jasper_env_file_set "$ENV_FILE" "$key" "$value" 0640 0750
}

set_env_var_if_changed() {
    local key="$1" value="$2"
    local current
    if [[ ! -f "$ENV_FILE" ]]; then
        set_env_var "$key" "$value"
        return 0
    fi
    if ! grep -qE "^[[:space:]]*${key}[[:space:]]*=" "$ENV_FILE"; then
        set_env_var "$key" "$value"
        return 0
    fi
    current="$(env_file_value "$key")"
    if [[ "$current" == "$value" ]]; then
        return 1
    fi
    set_env_var "$key" "$value"
    return 0
}

env_file_value_from() {
    local file="$1" key="$2"
    if [[ ! -f "$file" ]]; then
        return 0
    fi
    awk -v key="$key" '
        $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
            value = $0
            sub("^[[:space:]]*" key "[[:space:]]*=[[:space:]]*", "", value)
            found = value
            seen = 1
        }
        END {
            if (seen) {
                print found
            }
        }
    ' "$file" \
        | sed -E "s/^[[:space:]]+//; s/[[:space:]]+$//; s/^[\"']//; s/[\"']$//"
}

set_env_file_var() {
    local file="$1" key="$2" value="$3"
    jasper_env_file_set "$file" "$key" "$value" 0640 0750
}

set_env_file_var_if_changed() {
    local file="$1" key="$2" value="$3"
    local current
    if [[ ! -f "$file" ]]; then
        set_env_file_var "$file" "$key" "$value"
        return 0
    fi
    if ! grep -qE "^[[:space:]]*${key}[[:space:]]*=" "$file"; then
        set_env_file_var "$file" "$key" "$value"
        return 0
    fi
    current="$(env_file_value_from "$file" "$key")"
    if [[ "$current" == "$value" ]]; then
        return 1
    fi
    set_env_file_var "$file" "$key" "$value"
    return 0
}

repair_generated_env_permissions() {
    jasper_env_file_repair_permissions "$OUTPUTD_ENV_FILE" 0640 0750
    jasper_env_file_repair_permissions "$FANIN_ENV_FILE" 0640 0750
    jasper_env_file_repair_permissions "$USBSINK_ENV_FILE" 0640 0750
}

APPLE_DONGLE_CARD=""
APPLE_DONGLE_PRESENT=0
APPLE_DONGLE_SERVICE_CARD="auto"
DAC8X_OUTPUT_CARD=""
DAC8X_STUDIO_OUTPUT_CARD=""
DONGLE_CARD="A"
OUTPUT_DAC_CARD="A"
OUTPUT_DAC_ID="A"
OUTPUT_DAC_RECOGNIZED=0
OUTPUTD_ACTIVE_MODE=0
OUTPUTD_ACTIVE_CHANNELS=""
OBSERVED_OUTPUT_PROFILE_ID=""
OBSERVED_OUTPUT_PROFILE_STATUS=""
OBSERVED_OUTPUT_PAYLOAD=""
DUAL_APPLE_DAC_A_PCM=""
DUAL_APPLE_DAC_B_PCM=""
DUAL_APPLE_ORDER_SOURCE=""

detect_roles() {
    APPLE_DONGLE_CARD="$(find_card 'usb-c to 3.5mm')"
    if [[ -n "$APPLE_DONGLE_CARD" ]]; then
        DONGLE_CARD="$APPLE_DONGLE_CARD"
        APPLE_DONGLE_PRESENT=1
        APPLE_DONGLE_SERVICE_CARD="$APPLE_DONGLE_CARD"
    fi

    DAC8X_STUDIO_OUTPUT_CARD="$(find_card 'hifiberry.*dac8x.*studio|dac8x.*studio')"
    DAC8X_OUTPUT_CARD="$(find_card 'snd_rpi_hifiberry_dac8x|hifiberry.*dac8x|dac8x')"
    if [[ -n "$DAC8X_STUDIO_OUTPUT_CARD" ]]; then
        OUTPUT_DAC_CARD="$DAC8X_STUDIO_OUTPUT_CARD"
        OUTPUT_DAC_ID="hifiberry_dac8x_studio"
        OUTPUT_DAC_RECOGNIZED=1
    elif [[ -n "$DAC8X_OUTPUT_CARD" ]]; then
        OUTPUT_DAC_CARD="$DAC8X_OUTPUT_CARD"
        OUTPUT_DAC_ID="hifiberry_dac8x"
        OUTPUT_DAC_RECOGNIZED=1
    elif [[ "$APPLE_DONGLE_PRESENT" == "1" ]]; then
        OUTPUT_DAC_CARD="$APPLE_DONGLE_CARD"
        OUTPUT_DAC_ID="apple_usb_c_dongle"
        OUTPUT_DAC_RECOGNIZED=1
    fi
}

apply_observed_composite_policy() {
    if [[ "$OBSERVED_OUTPUT_PROFILE_ID" != "dual_apple_usb_c_dac_4ch" ]]; then
        return
    fi
    if [[ "$OBSERVED_OUTPUT_PROFILE_STATUS" != "ready" ]]; then
        OUTPUT_DAC_ID="dual_apple_usb_c_dac_4ch"
        OUTPUT_DAC_CARD=""
        OUTPUT_DAC_RECOGNIZED=0
        APPLE_DONGLE_PRESENT=1
        APPLE_DONGLE_SERVICE_CARD="auto"
        log_event "dual_apple_detected" \
            "status=${OBSERVED_OUTPUT_PROFILE_STATUS:-unknown} action=park_until_ready"
        return
    fi
    local parsed
    if ! parsed="$(
        printf '%s' "$OBSERVED_OUTPUT_PAYLOAD" | JASPER_OUTPUT_TOPOLOGY_PATH="$OUTPUT_TOPOLOGY_PATH" "$OUTPUT_HARDWARE_PYTHON" -c '
import json, sys
from jasper.output_hardware import OutputHardwareState, dual_apple_runtime_mapping

state = OutputHardwareState.from_mapping(json.load(sys.stdin))
mapping = dual_apple_runtime_mapping(state)
if not mapping.ok:
    print(mapping.reason, file=sys.stderr)
    raise SystemExit(1)
print(mapping.order_source)
for child in mapping.child_devices:
    print(child.pcm or "")
'
    )"; then
        OUTPUT_DAC_ID="dual_apple_usb_c_dac_4ch"
        OUTPUT_DAC_CARD=""
        OUTPUT_DAC_RECOGNIZED=0
        APPLE_DONGLE_PRESENT=1
        APPLE_DONGLE_SERVICE_CARD="auto"
        log_event "dual_apple_detected" \
            "status=ready action=park_unstable_child_order topology_path=${OUTPUT_TOPOLOGY_PATH}"
        return
    fi
    DUAL_APPLE_ORDER_SOURCE="$(printf '%s\n' "$parsed" | sed -n '1p')"
    DUAL_APPLE_DAC_A_PCM="$(printf '%s\n' "$parsed" | sed -n '2p')"
    DUAL_APPLE_DAC_B_PCM="$(printf '%s\n' "$parsed" | sed -n '3p')"
    local graph_status
    # The dual-Apple composite caps at 4 (two stereo children); the composite
    # sink is rigidly 4-channel in outputd regardless, so the dual branch only
    # needs the gate's pass/fail, not the returned width.
    if ! graph_status="$(active_graph_status 4)"; then
        OUTPUT_DAC_ID="dual_apple_usb_c_dac_4ch"
        OUTPUT_DAC_CARD=""
        OUTPUT_DAC_RECOGNIZED=0
        APPLE_DONGLE_PRESENT=1
        APPLE_DONGLE_SERVICE_CARD="auto"
        DUAL_APPLE_DAC_A_PCM=""
        DUAL_APPLE_DAC_B_PCM=""
        log_event "dual_apple_detected" \
            "status=ready action=park_until_active_graph reason=${graph_status:-unknown}"
        return
    fi
    OUTPUT_DAC_ID="dual_apple_usb_c_dac_4ch"
    OUTPUT_DAC_CARD="$DONGLE_CARD"
    OUTPUT_DAC_RECOGNIZED=1
    APPLE_DONGLE_PRESENT=1
    APPLE_DONGLE_SERVICE_CARD="auto"
    log_event "dual_apple_detected" \
        "status=ready action=outputd_dual_sink order_source=${DUAL_APPLE_ORDER_SOURCE} dac_a_pcm=$(jasper_asound_log_token "$DUAL_APPLE_DAC_A_PCM") dac_b_pcm=$(jasper_asound_log_token "$DUAL_APPLE_DAC_B_PCM")"
}

# Active-graph cutover gate. DRIVE WHAT WE USE, not the DAC's full channel count.
#
# $1 = the DAC's active-lane channel CAP — the resolved DacProfile's
# active_outputd_lane_channels (2 for single Apple, 4 for the dual-Apple
# composite, 8 for a HiFiBerry DAC8x single). On success prints the live
# endpoint config's ACTUAL playback width W (the number of physical outputs the
# speaker actually drives, in 2..cap) and returns 0 — ONLY when the current
# CamillaDSP graph, or the active-leader camilla#2 crossover graph paired with a
# camilla#1 program bake, is legal for the saved output topology, targets
# outputd's active playback lane, and its playback width is valid within the
# cap. A 100-output DAC powering a 2-way drives 2, not 100: outputd opens the
# DAC at W and the reconciler emits W as JASPER_OUTPUTD_ACTIVE_CHANNELS, so we
# never pump muted channels we are not using. Otherwise it prints a reason and
# returns non-zero so the caller fails closed: the composite shape parks, a
# coherent single stays ordinary stereo. This is the second, independent
# fail-closed layer (the asoundrc active lane is the first); never emit the wide
# env against a config that does not fit the cap.
active_graph_status() {
    local cap_channels="$1"
    if ! command -v "$OUTPUT_HARDWARE_PYTHON" >/dev/null 2>&1; then
        printf 'python_unavailable'
        return 1
    fi
    JASPER_CAMILLA_STATEFILE="$CAMILLA_STATEFILE" \
    JASPER_CAMILLA2_STATEFILE="$CAMILLA2_STATEFILE" \
    JASPER_OUTPUT_TOPOLOGY_PATH="$OUTPUT_TOPOLOGY_PATH" \
    JASPER_ACTIVE_GRAPH_CAP_CHANNELS="$cap_channels" \
    "$OUTPUT_HARDWARE_PYTHON" - <<'PY'
import os
import sys

try:
    cap_channels = int(os.environ["JASPER_ACTIVE_GRAPH_CAP_CHANNELS"])
except (KeyError, ValueError):
    print("active_graph_cap_channels_invalid")
    raise SystemExit(1)

try:
    from jasper.active_speaker.runtime_contract import (
        outputd_active_lane_decision,
    )

    decision = outputd_active_lane_decision(
        cap_channels,
        statefile_path=os.environ["JASPER_CAMILLA_STATEFILE"],
        crossover_statefile_path=os.environ["JASPER_CAMILLA2_STATEFILE"],
        topology_path=os.environ["JASPER_OUTPUT_TOPOLOGY_PATH"],
    )
except Exception as exc:
    detail = getattr(exc, "name", None) or type(exc).__name__
    print(f"active_graph_contract_unavailable:{type(exc).__name__}:{detail}")
    raise SystemExit(1)

if not decision.ok:
    print(decision.reason)
    raise SystemExit(1)

# Stdout payload on success is the ACTUAL driven width; the reconciler emits it
# as JASPER_OUTPUTD_ACTIVE_CHANNELS so outputd opens the DAC at exactly W.
print(decision.width)
PY
}

# Resolve a recognized single DAC's active-lane channel CAP via the Python
# DacProfile registry (active_outputd_lane_channels_for). Prints the cap
# (e.g. 8 for a HiFiBerry DAC8x — the most active outputs outputd will drive on
# this DAC) or nothing for a DAC with no active lane (Apple single dongle) or
# when Python is unavailable — both of which keep the DAC on the ordinary
# stereo single path. The cap is the upper bound; the ACTUAL driven width is the
# loaded config's playback width, validated against this cap by the gate.
active_lane_channels_for_dac() {
    local dac_id="$1"
    if [[ -z "$dac_id" ]] || ! command -v "$OUTPUT_HARDWARE_PYTHON" >/dev/null 2>&1; then
        return 0
    fi
    JASPER_DAC_ID_QUERY="$dac_id" "$OUTPUT_HARDWARE_PYTHON" - <<'PY' 2>/dev/null || true
import os

from jasper.audio_hardware.dac import active_outputd_lane_channels_for

width = active_outputd_lane_channels_for(os.environ["JASPER_DAC_ID_QUERY"])
if width:
    print(width)
PY
}

_fallback_latency_floor_actions() {
    printf 'unset JASPER_CAMILLA_CHUNKSIZE\n'
    printf 'unset JASPER_CAMILLA_TARGET_LEVEL\n'
    printf 'unset JASPER_OUTPUTD_PERIOD_FRAMES\n'
    printf 'unset JASPER_OUTPUTD_CONTENT_BUFFER_FRAMES\n'
    printf 'unset JASPER_OUTPUTD_DAC_BUFFER_FRAMES\n'
}

# Ask jasper.audio_runtime_plan for outputd.env latency-floor actions. This keeps
# precedence in one Python policy layer instead of duplicating "operator env >
# profile floor > packaged default" in bash and in jasper-doctor.
latency_floor_actions_for_dac() {
    local dac_id="$1"
    if ! command -v "$OUTPUT_HARDWARE_PYTHON" >/dev/null 2>&1; then
        _fallback_latency_floor_actions
        return 0
    fi
    if ! "$OUTPUT_HARDWARE_PYTHON" -m jasper.cli.audio_config \
        outputd-floor-actions \
        --profile-id "$dac_id" \
        --base-env "$ENV_FILE" \
        --outputd-env "$OUTPUTD_ENV_FILE" 2>/dev/null; then
        _fallback_latency_floor_actions
    fi
}

route_env_actions() {
    if ! command -v "$OUTPUT_HARDWARE_PYTHON" >/dev/null 2>&1; then
        return 1
    fi
    "$OUTPUT_HARDWARE_PYTHON" -m jasper.cli.audio_config \
        route-actions \
        --base-env "$ENV_FILE" 2>/dev/null
}

apply_route_env() {
    local changed=0
    local actions target kind key value file
    if ! actions="$(route_env_actions)"; then
        log_event "route_env_skip" "reason=audio_config_unavailable"
        return 1
    fi
    while read -r target kind key value; do
        [[ -n "${target:-}" ]] || continue
        if [[ "$target" == "summary" ]]; then
            continue
        fi
        case "$target" in
            fanin) file="$FANIN_ENV_FILE" ;;
            usbsink) file="$USBSINK_ENV_FILE" ;;
            *) continue ;;
        esac
        case "$kind" in
            set)
                if set_env_file_var_if_changed "$file" "$key" "$value"; then
                    changed=1
                fi
                ;;
            unset)
                if grep -qE "^[[:space:]]*${key}[[:space:]]*=" "$file" 2>/dev/null; then
                    jasper_env_file_unset "$file" "$key" 0640 0750
                    changed=1
                fi
                ;;
        esac
    done <<<"$actions"
    log_event "route_env" "fanin_env=${FANIN_ENV_FILE} usbsink_env=${USBSINK_ENV_FILE} changed=${changed}"
    if [[ "$changed" == "1" ]]; then
        return 0
    fi
    return 1
}

# Apply the active DAC latency-floor actions into the wizard-owned outputd.env.
# The decisions come from jasper.audio_runtime_plan; this function only performs
# the requested set/unset mutations and reports whether the file changed.
LATENCY_FLOOR_CHANGED=0
apply_latency_floor_env() {
    LATENCY_FLOOR_CHANGED=0
    local dac_id="$1"
    local actions kind key value
    local camilla_chunk="" camilla_target="" outputd_period="" outputd_content_buffer="" outputd_buffer=""
    actions="$(latency_floor_actions_for_dac "$dac_id")"
    while read -r kind key value; do
        [[ -n "${kind:-}" ]] || continue
        case "$kind" in
            summary)
                case "$key" in
                    JASPER_CAMILLA_CHUNKSIZE) camilla_chunk="$value" ;;
                    JASPER_CAMILLA_TARGET_LEVEL) camilla_target="$value" ;;
                    JASPER_OUTPUTD_PERIOD_FRAMES) outputd_period="$value" ;;
                    JASPER_OUTPUTD_CONTENT_BUFFER_FRAMES) outputd_content_buffer="$value" ;;
                    JASPER_OUTPUTD_DAC_BUFFER_FRAMES) outputd_buffer="$value" ;;
                esac
                ;;
            set)
                if set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "$key" "$value"; then
                    LATENCY_FLOOR_CHANGED=1
                fi
                ;;
            unset)
                if grep -qE "^[[:space:]]*${key}[[:space:]]*=" "$OUTPUTD_ENV_FILE" 2>/dev/null; then
                    jasper_env_file_unset "$OUTPUTD_ENV_FILE" "$key" 0640 0750
                    LATENCY_FLOOR_CHANGED=1
                fi
                ;;
        esac
    done <<<"$actions"
    log_event "latency_floor" \
        "output_dac_id=${dac_id} camilla_chunksize=${camilla_chunk:-default} camilla_target_level=${camilla_target:-default} outputd_period_frames=${outputd_period:-default} outputd_content_buffer_frames=${outputd_content_buffer:-default} outputd_dac_buffer_frames=${outputd_buffer:-default} changed=${LATENCY_FLOOR_CHANGED}"
}

print_env() {
    printf 'DONGLE_CARD=%s\n' "$(quote_env_value "$DONGLE_CARD")"
    printf 'APPLE_DONGLE_PRESENT=%s\n' "$(quote_env_value "$APPLE_DONGLE_PRESENT")"
    printf 'APPLE_DONGLE_SERVICE_CARD=%s\n' "$(quote_env_value "$APPLE_DONGLE_SERVICE_CARD")"
    printf 'OUTPUT_DAC_CARD=%s\n' "$(quote_env_value "$OUTPUT_DAC_CARD")"
    printf 'OUTPUT_DAC_ID=%s\n' "$(quote_env_value "$OUTPUT_DAC_ID")"
    printf 'OUTPUT_DAC_RECOGNIZED=%s\n' "$(quote_env_value "$OUTPUT_DAC_RECOGNIZED")"
}

render_asound_if_needed() {
    local tmp changed=1

    if [[ ! -f "$ASOUND_SOURCE_TEMPLATE" ]]; then
        log_event "asound_skip" "source_template=${ASOUND_SOURCE_TEMPLATE} missing=1"
        return 1
    fi

    # Only create an absent dir; never re-mode the existing /etc/jasper on every
    # recognized-DAC render (the installer owns its 0755) — same only-if-absent
    # discipline as the env writers (#827).
    [[ -d "$(dirname "$ASOUND_TEMPLATE")" ]] || install -d -m 0755 "$(dirname "$ASOUND_TEMPLATE")"
    tmp="$(mktemp "${ASOUND_TEMPLATE}.XXXXXX")"
    # Render to a temp and validate it BEFORE replacing the live template. A
    # card-less recognized DAC makes jasper_asound_render_template fail closed
    # (require_output_dac_card -> 64) — but set -e is suppressed here because
    # the caller invokes this function in a `&& render_changed=1` list, so an
    # ignored failure would fall straight through to the mv below and clobber
    # the working /etc/asound.conf source with the empty temp (silent failure on
    # the output path; defeats the helper's own fail-closed guard). Check the
    # return AND reject an empty render, then preserve the existing template and
    # fail loud rather than emit nothing.
    if ! jasper_asound_render_template "$ASOUND_SOURCE_TEMPLATE" "$tmp" || [[ ! -s "$tmp" ]]; then
        rm -f "$tmp"
        log_event "asound_render_failed" \
            "source_template=${ASOUND_SOURCE_TEMPLATE} output_dac_id=${OUTPUT_DAC_ID} output_dac_card=$(jasper_asound_log_token "$OUTPUT_DAC_CARD") preserved_existing=1"
        return 1
    fi
    chmod 0644 "$tmp"

    if [[ -f "$ASOUND_TEMPLATE" ]] && cmp -s "$tmp" "$ASOUND_TEMPLATE"; then
        changed=0
        rm -f "$tmp"
    else
        mv "$tmp" "$ASOUND_TEMPLATE"
        changed=1
    fi

    if [[ "$changed" == "1" ]]; then
        "$RENDER_ASOUND_CONF"
        log_event "asound_rendered" \
            "output_dac_id=${OUTPUT_DAC_ID} output_dac_card=${OUTPUT_DAC_CARD} outputd_active_mode=${OUTPUTD_ACTIVE_MODE} outputd_active_channels=$(jasper_asound_log_token "$OUTPUTD_ACTIVE_CHANNELS")"
        return 0
    fi
    return 1
}

gate_role_services() {
    if [[ ( "$OUTPUT_DAC_ID" == "apple_usb_c_dongle" || "$OUTPUT_DAC_ID" == "dual_apple_usb_c_dac_4ch" ) && "$APPLE_DONGLE_PRESENT" == "1" ]]; then
        "$SYSTEMCTL" enable jasper-dac-init.service jasper-headphone-monitor.service
        "$SYSTEMCTL" start jasper-dac-init.service || true
        "$SYSTEMCTL" restart jasper-headphone-monitor.service || true
        log_event "apple_services" "state=enabled output_dac_id=${OUTPUT_DAC_ID}"
    else
        "$SYSTEMCTL" disable --now jasper-dac-init.service jasper-headphone-monitor.service 2>/dev/null || true
        "$SYSTEMCTL" reset-failed jasper-dac-init.service jasper-headphone-monitor.service 2>/dev/null || true
        log_event "apple_services" "state=disabled output_dac_id=${OUTPUT_DAC_ID}"
    fi
}

park_output_audio() {
    if [[ "$NO_RESTART" == "1" ]]; then
        log_event "output_park_skip" "output_dac_id=${OUTPUT_DAC_ID} recognized=0 no_restart=1"
        return
    fi
    "$SYSTEMCTL" --no-block stop jasper-voice.service jasper-outputd.service 2>/dev/null || true
    "$SYSTEMCTL" reset-failed jasper-voice.service jasper-outputd.service 2>/dev/null || true
    log_event "output_parked" "output_dac_id=${OUTPUT_DAC_ID} output_dac_card=${OUTPUT_DAC_CARD} recognized=0"
}

restart_audio_if_needed() {
    local restart_needed="$1"
    if [[ "$restart_needed" != "1" || "$NO_RESTART" == "1" ]]; then
        return
    fi
    "$SYSTEMCTL" stop jasper-voice.service 2>/dev/null || true
    "$SYSTEMCTL" reset-failed jasper-outputd.service 2>/dev/null || true
    "$SYSTEMCTL" --no-block restart jasper-outputd.service 2>/dev/null || true
    "$SYSTEMCTL" --no-block restart jasper-aec-reconcile.service 2>/dev/null || true
    log_event "audio_restarted" "output_dac_id=${OUTPUT_DAC_ID} output_dac_card=${OUTPUT_DAC_CARD}"
}

restart_route_runtime_if_needed() {
    local restart_needed="$1"
    if [[ "$restart_needed" != "1" || "$NO_RESTART" == "1" ]]; then
        return
    fi
    "$SYSTEMCTL" reset-failed jasper-fanin.service jasper-usbsink.service jasper-usbsink-volume.service 2>/dev/null || true
    "$SYSTEMCTL" --no-block restart jasper-fanin.service 2>/dev/null || true
    "$SYSTEMCTL" --no-block try-restart jasper-usbsink.service jasper-usbsink-volume.service 2>/dev/null || true
    log_event "route_runtime_restarted" "fanin_env=${FANIN_ENV_FILE} usbsink_env=${USBSINK_ENV_FILE}"
}

start_outputd_if_recognized() {
    if [[ "$NO_RESTART" == "1" ]]; then
        log_event "outputd_start_skip" "output_dac_id=${OUTPUT_DAC_ID} output_dac_card=${OUTPUT_DAC_CARD} recognized=1 no_restart=1"
        return
    fi
    "$SYSTEMCTL" reset-failed jasper-outputd.service 2>/dev/null || true
    "$SYSTEMCTL" --no-block start jasper-outputd.service 2>/dev/null || true
    log_event "outputd_start_requested" "output_dac_id=${OUTPUT_DAC_ID} output_dac_card=${OUTPUT_DAC_CARD} recognized=1"
}

apply_audio_runtime_env() {
    local changed=0
    local active_channels="" active_mode=0 graph_status="" active_lane_cap=""
    if [[ "$OUTPUT_DAC_ID" == "dual_apple_usb_c_dac_4ch" && "$OUTPUT_DAC_RECOGNIZED" == "1" ]]; then
        OUTPUTD_ACTIVE_MODE=0
        OUTPUTD_ACTIVE_CHANNELS=""
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_BACKEND" "alsa" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_SINK" "dual_apple" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_CONTENT_PCM" "outputd_active_content_capture" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_DAC_PCM" "dual_apple_usb_c_dac_4ch" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_DUAL_DAC_A_PCM" "$DUAL_APPLE_DAC_A_PCM" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_DUAL_DAC_B_PCM" "$DUAL_APPLE_DAC_B_PCM" && changed=1
        # Composite width is fixed at 4 (two stereo children); clear the
        # single-sink width knob so a stale value from a prior active single
        # DAC cannot reach outputd (which rejects != 4 on the composite sink).
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_ACTIVE_CHANNELS" "" && changed=1
        # The 4-ch composite sink is already fenced off the stereo-only TTS
        # mixer / rate-match by its width (content_channels=4 != 2); clear the
        # active-lane marker so toggling here from a prior active single DAC
        # cannot leave a stale =1.
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_ACTIVE_LANE" "" && changed=1
        log_event "runtime_env" \
            "mode=dual_apple outputd_env=${OUTPUTD_ENV_FILE} changed=${changed}"
    elif [[ "$OUTPUT_DAC_RECOGNIZED" == "1" ]]; then
        # A coherent single DAC runs the active lane ONLY when it declares one
        # (DacProfile.active_outputd_lane_channels = the cap) AND an
        # legal active-speaker graph whose playback width fits within that cap
        # is the live CamillaDSP config. We DRIVE WHAT WE USE: the gate returns
        # the config's ACTUAL driven width W (2..cap), and we emit that as
        # JASPER_OUTPUTD_ACTIVE_CHANNELS so outputd opens the DAC at exactly W —
        # a DAC8x running a 2-way drives 2 outputs, not 8. Fail-closed: without
        # a confirmed in-cap active graph the DAC stays ordinary stereo
        # (byte-identical to the pre-active path), so a recognized DAC8x is a
        # normal stereo speaker until commissioning loads its active baseline.
        active_lane_cap="$(active_lane_channels_for_dac "$OUTPUT_DAC_ID")"
        if [[ -n "$active_lane_cap" ]]; then
            if active_channels="$(active_graph_status "$active_lane_cap")"; then
                active_mode=1
            else
                graph_status="$active_channels"
                active_channels=""
            fi
        fi
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_BACKEND" "alsa" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_SINK" "single_alsa" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_DAC_PCM" "outputd_dac" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_DUAL_DAC_A_PCM" "" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_DUAL_DAC_B_PCM" "" && changed=1
        if [[ "$active_mode" == "1" ]]; then
            OUTPUTD_ACTIVE_MODE=1
            OUTPUTD_ACTIVE_CHANNELS="$active_channels"
            set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_CONTENT_PCM" "outputd_active_content_capture" && changed=1
            set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_ACTIVE_CHANNELS" "$active_channels" && changed=1
            # Belt-and-suspenders for the latent outputd-TTS-mixer hazard: an
            # active 2-way speaker is ALSO 2-channel, so outputd's bare
            # content_channels==2 check would wrongly permit its post-crossover
            # TTS mixer / rate-match here. Mark the lane explicitly so outputd
            # fails those stereo-only features closed (full-range-to-tweeter
            # safety). Active-mode voice rides fanin, upstream of the crossover.
            set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_ACTIVE_LANE" "1" && changed=1
            log_event "runtime_env" \
                "mode=single_alsa_active active_channels=${active_channels} active_lane_cap=${active_lane_cap} outputd_env=${OUTPUTD_ENV_FILE} changed=${changed}"
        else
            OUTPUTD_ACTIVE_MODE=0
            OUTPUTD_ACTIVE_CHANNELS=""
            set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_CONTENT_PCM" "outputd_content_capture" && changed=1
            # Clear the width knob so outputd defaults to stereo; a stale active
            # width would otherwise mis-size the (stereo) content lane.
            set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_ACTIVE_CHANNELS" "" && changed=1
            # Leaving active mode: clear the active-lane marker so a stale =1
            # cannot keep the stereo-only TTS mixer / rate-match fenced off on
            # an ordinary passive stereo DAC.
            set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_ACTIVE_LANE" "" && changed=1
            log_event "runtime_env" \
                "mode=single_alsa outputd_env=${OUTPUTD_ENV_FILE} changed=${changed} active_graph=${graph_status:-none}"
        fi
    else
        OUTPUTD_ACTIVE_MODE=0
        OUTPUTD_ACTIVE_CHANNELS=""
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_BACKEND" "fake" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_SINK" "single_alsa" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_CONTENT_PCM" "outputd_content_capture" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_DAC_PCM" "outputd_dac" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_DUAL_DAC_A_PCM" "" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_DUAL_DAC_B_PCM" "" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_ACTIVE_CHANNELS" "" && changed=1
        set_env_file_var_if_changed "$OUTPUTD_ENV_FILE" "JASPER_OUTPUTD_ACTIVE_LANE" "" && changed=1
        log_event "runtime_env" \
            "mode=parked outputd_env=${OUTPUTD_ENV_FILE} changed=${changed}"
    fi
    if [[ "$changed" == "1" ]]; then
        return 0
    fi
    return 1
}

detect_roles
if [[ "$PRINT_ENV" == "1" ]]; then
    observe_output_hardware_state 0
    apply_observed_composite_policy
    print_env
    exit 0
fi
observe_output_hardware_state 1
apply_observed_composite_policy

env_changed=0
route_env_changed=0
set_env_var_if_changed "JASPER_AUDIO_DAC_ID" "$OUTPUT_DAC_ID" && env_changed=1
set_env_var_if_changed "JASPER_AUDIO_DAC_CARD" "$OUTPUT_DAC_CARD" && env_changed=1
apply_audio_runtime_env && env_changed=1
if apply_route_env; then
    env_changed=1
    route_env_changed=1
fi
# Emit the active DAC's codified latency floor (#27). For a recognized DAC this
# is its profile floor (or cleared when the profile declares none); for an
# unrecognized/parked DAC clear any stale floor with an empty id.
if [[ "$OUTPUT_DAC_RECOGNIZED" == "1" ]]; then
    apply_latency_floor_env "$OUTPUT_DAC_ID"
else
    apply_latency_floor_env ""
fi
if [[ "$LATENCY_FLOOR_CHANGED" == "1" ]]; then
    env_changed=1
fi
repair_generated_env_permissions

render_changed=0
render_asound_if_needed && render_changed=1
gate_role_services
if [[ "$OUTPUT_DAC_RECOGNIZED" == "1" ]]; then
    restart_needed=0
    if [[ "$render_changed" == "1" || "$env_changed" == "1" ]]; then
        restart_needed=1
    fi
    if [[ "$restart_needed" == "1" ]]; then
        restart_audio_if_needed "$restart_needed"
        restart_route_runtime_if_needed "$route_env_changed"
    else
        start_outputd_if_recognized
        restart_route_runtime_if_needed "$route_env_changed"
    fi
else
    restart_route_runtime_if_needed "$route_env_changed"
    park_output_audio
fi

log_event "complete" \
    "output_dac_id=${OUTPUT_DAC_ID} output_dac_card=${OUTPUT_DAC_CARD} outputd_active_mode=${OUTPUTD_ACTIVE_MODE} outputd_active_channels=$(jasper_asound_log_token "$OUTPUTD_ACTIVE_CHANNELS") recognized=${OUTPUT_DAC_RECOGNIZED} env_changed=${env_changed} render_changed=${render_changed}"
