#!/usr/bin/env bash
# jasper-audio-topology — switch the JTS audio chain between
# `dmix` (default) and `fanin` (Tier 2A) topologies.
#
# The two topologies (see docs/HANDOFF-fan-in-daemon.md):
#
#   dmix  — all renderers write to `pcm.jasper_renderer_in` (a plug
#           wrapper on a userspace dmix sitting in front of
#           `hw:Loopback,0,0`). CamillaDSP and the AEC bridge dsnoop
#           on `hw:Loopback,1,0`. This is the default after PR #214
#           (2026-05-22) and is what every fresh install lands on.
#
#   fanin — each renderer writes to its own snd-aloop substream
#           (`hw:Loopback,0,0..3`). The `jasper-fanin` Rust daemon
#           reads each substream's capture side, sums sample-wise,
#           writes the summed music stream to `hw:Loopback,0,7`.
#           CamillaDSP + AEC bridge dsnoop on `hw:Loopback,1,7`.
#           Saves ~85 ms of latency (the dmix layer's invisible
#           buffer) and is the Tier 2A target topology.
#
# Usage:
#   jasper-audio-topology              # show current state
#   jasper-audio-topology status       # same
#   jasper-audio-topology dmix         # switch to dmix
#   jasper-audio-topology fanin        # switch to fanin
#   jasper-audio-topology dmix  --dry-run    # preview the actions
#   jasper-audio-topology fanin --dry-run    # preview
#
# Single source of truth for the active mode:
#   /var/lib/jasper/audio_topology.env  (key: JASPER_AUDIO_TOPOLOGY)
#
# What gets changed on a flip:
#   1. /var/lib/jasper/audio_topology.env       — JASPER_AUDIO_TOPOLOGY
#                                                  + JASPER_LIBRESPOT_DEVICE
#                                                  + JASPER_BLUEALSA_DEVICE
#                                                  + JASPER_USBSINK_PLAYBACK_DEVICE
#   2. /etc/asound.conf                          — fanin variant copied in;
#                                                  dmix backup at
#                                                  /etc/asound.conf.dmix-mode-backup
#   3. /etc/shairport-sync.conf                  — regenerated by
#                                                  jasper-apply-airplay-mode
#                                                  (reads JASPER_AUDIO_TOPOLOGY)
#   4. systemctl daemon-reload                   — picks up new env-file
#                                                  values for renderer units
#   5. jasper-fanin.service                      — enabled+started (fanin)
#                                                  or stopped+disabled (dmix)
#   6. All renderer + DSP daemons restarted in dependency order.
#
# All operations are idempotent: re-running `jasper-audio-topology dmix`
# from dmix mode is a no-op.
#
# Logs `event=audio_topology.*` to stderr (captured by systemd-journald
# when invoked from a unit; visible directly in interactive use).

set -euo pipefail

# === Configuration =================================================

TOPOLOGY_ENV="${JASPER_AUDIO_TOPOLOGY_ENV:-/var/lib/jasper/audio_topology.env}"
ASOUND_CONF="${JASPER_ASOUND_CONF:-/etc/asound.conf}"
ASOUND_CONF_DMIX_BACKUP="${ASOUND_CONF}.dmix-mode-backup"
# Where install.sh drops the fanin-mode asoundrc template:
ASOUND_CONF_FANIN_TEMPLATE="${JASPER_FANIN_ASOUND_TEMPLATE:-/etc/jasper/audio-topology/fanin/asound.conf.template}"
APPLY_AIRPLAY_MODE="${JASPER_APPLY_AIRPLAY_MODE:-/usr/local/sbin/jasper-apply-airplay-mode}"

# Renderer daemons (stopped/started in this order).
RENDERERS=(librespot shairport-sync bluealsa-aplay jasper-usbsink)
# DSP daemons (stopped after renderers, started after fanin but
# before renderers — they hold the capture side of the loopback).
DSP_DAEMONS=(jasper-aec-bridge jasper-camilla)

VERIFY_SETTLE_SECONDS="${JASPER_AUDIO_TOPOLOGY_VERIFY_SECONDS:-2}"

# === Helpers =======================================================

usage() {
    sed -n '2,55p' "$0" | sed 's/^# \{0,1\}//'
}

log() {
    # Project convention: structured `event=<subsystem>.<action> key=value`
    # lines to stderr. systemd-journald captures it; jasper-trace.sh
    # filters on event= prefix.
    echo "event=audio_topology.$*" >&2
}

current_mode() {
    if [[ -f "$TOPOLOGY_ENV" ]]; then
        # shellcheck disable=SC1090
        (source "$TOPOLOGY_ENV" 2>/dev/null && echo "${JASPER_AUDIO_TOPOLOGY:-dmix}") || echo "dmix"
    else
        echo "dmix"
    fi
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        echo "jasper-audio-topology: must run as root (use sudo)" >&2
        exit 1
    fi
}

# Extract the __DONGLE_CARD__ value from a rendered asoundrc.
# Looks for `pcm "hw:CARD=NAME,DEV=0"` and captures NAME.
extract_dongle_card() {
    local conf="$1"
    awk '
        match($0, /hw:CARD=[^,]+,DEV=0/) {
            line = substr($0, RSTART, RLENGTH)
            sub(/^hw:CARD=/, "", line)
            sub(/,DEV=0$/, "", line)
            print line
            exit
        }
    ' "$conf"
}

print_status() {
    local mode
    mode="$(current_mode)"
    echo "active topology: $mode"
    echo
    echo "config files:"
    if [[ -f "$TOPOLOGY_ENV" ]]; then
        echo "  $TOPOLOGY_ENV:"
        sed 's/^/    /' "$TOPOLOGY_ENV"
    else
        echo "  $TOPOLOGY_ENV: absent (= dmix default)"
    fi
    echo "  $ASOUND_CONF: $(stat -c '%y' "$ASOUND_CONF" 2>/dev/null || echo 'MISSING')"
    if [[ -f "$ASOUND_CONF_DMIX_BACKUP" ]]; then
        echo "  $ASOUND_CONF_DMIX_BACKUP: $(stat -c '%y' "$ASOUND_CONF_DMIX_BACKUP")"
    else
        echo "  $ASOUND_CONF_DMIX_BACKUP: absent (no fanin switch performed yet)"
    fi
    echo
    echo "daemon states:"
    local daemons=(librespot shairport-sync bluealsa-aplay jasper-usbsink jasper-camilla jasper-aec-bridge jasper-fanin)
    for d in "${daemons[@]}"; do
        local state
        state="$(systemctl is-active "$d.service" 2>/dev/null || true)"
        local enabled
        enabled="$(systemctl is-enabled "$d.service" 2>/dev/null || true)"
        printf "  %-22s active=%-10s enabled=%s\n" "$d" "${state:-unknown}" "${enabled:-unknown}"
    done
    echo
    echo "(use 'jasper-audio-topology dmix|fanin' to switch; add --dry-run to preview)"
}

# Stop renderers + DSP daemons. Order matters: renderers release
# their hold on the dmix or substream FDs, then DSP daemons release
# the capture-side dsnoop.
stop_chain() {
    log "stop_chain.begin"
    for d in "${RENDERERS[@]}"; do
        systemctl stop "$d.service" 2>/dev/null || true
    done
    for d in "${DSP_DAEMONS[@]}"; do
        systemctl stop "$d.service" 2>/dev/null || true
    done
    systemctl stop jasper-fanin.service 2>/dev/null || true
    log "stop_chain.done"
}

# Start in dependency order: fanin first (writing to substream 7),
# then DSP daemons (which open the capture side), then renderers
# (which write to the dmix or per-renderer substream).
start_chain() {
    local mode="$1"
    log "start_chain.begin mode=$mode"
    if [[ "$mode" == "fanin" ]]; then
        systemctl enable --now jasper-fanin.service
    fi
    systemctl start jasper-camilla.service
    # AEC bridge is reconciler-managed; start it only if it was
    # previously enabled (the reconciler will manage its lifecycle
    # based on hardware presence + JASPER_AEC_MODE).
    if systemctl is-enabled jasper-aec-bridge.service >/dev/null 2>&1; then
        systemctl start jasper-aec-bridge.service 2>/dev/null || true
    fi
    for d in "${RENDERERS[@]}"; do
        # Best-effort restart — some renderers may not be installed
        # (e.g., usbsink off, bluealsa unavailable).
        if systemctl is-enabled "$d.service" >/dev/null 2>&1; then
            systemctl start "$d.service" 2>/dev/null || true
        fi
    done
    log "start_chain.done"
}

write_topology_env() {
    local mode="$1"
    local lib bla usb shp
    if [[ "$mode" == "fanin" ]]; then
        lib="librespot_substream"
        bla="bluealsa_substream"
        usb="usbsink_substream"
        shp="shairport_substream"
    else
        lib="jasper_renderer_in"
        bla="jasper_renderer_in"
        usb="jasper_renderer_in"
        shp="jasper_renderer_in"
    fi
    mkdir -p "$(dirname "$TOPOLOGY_ENV")"
    local tmp="$TOPOLOGY_ENV.tmp.$$"
    cat > "$tmp" <<EOF
# Generated by jasper-audio-topology. The single source of truth
# for the active JTS audio topology. Each renderer's systemd unit
# sources this via \`EnvironmentFile=-${TOPOLOGY_ENV}\`. See
# docs/HANDOFF-fan-in-daemon.md.
JASPER_AUDIO_TOPOLOGY=$mode
JASPER_LIBRESPOT_DEVICE=$lib
JASPER_BLUEALSA_DEVICE=$bla
JASPER_USBSINK_PLAYBACK_DEVICE=$usb
# JASPER_SHAIRPORT_DEVICE is informational only — shairport's
# output_device is set in /etc/shairport-sync.conf (regenerated by
# jasper-apply-airplay-mode based on JASPER_AUDIO_TOPOLOGY above).
# Kept here to document the active mode's full renderer-device set.
JASPER_SHAIRPORT_DEVICE=$shp
EOF
    chmod 0644 "$tmp"
    mv -f "$tmp" "$TOPOLOGY_ENV"
    log "write_topology_env mode=$mode"
}

switch_asoundrc() {
    local mode="$1"
    if [[ "$mode" == "fanin" ]]; then
        if [[ ! -f "$ASOUND_CONF" ]]; then
            echo "jasper-audio-topology: $ASOUND_CONF missing" >&2
            return 1
        fi
        if [[ ! -f "$ASOUND_CONF_FANIN_TEMPLATE" ]]; then
            echo "jasper-audio-topology: fanin template missing at $ASOUND_CONF_FANIN_TEMPLATE; re-run install.sh" >&2
            return 1
        fi
        # First switch to fanin → preserve a backup of the current
        # (= dmix) asoundrc. Subsequent switches reuse the same backup
        # so the dongle name doesn't drift if install.sh re-detects.
        if [[ ! -f "$ASOUND_CONF_DMIX_BACKUP" ]]; then
            cp -a "$ASOUND_CONF" "$ASOUND_CONF_DMIX_BACKUP"
            log "asoundrc.backup_created path=$ASOUND_CONF_DMIX_BACKUP"
        fi
        local dongle
        dongle="$(extract_dongle_card "$ASOUND_CONF_DMIX_BACKUP")"
        if [[ -z "$dongle" ]]; then
            echo "jasper-audio-topology: could not extract __DONGLE_CARD__ from $ASOUND_CONF_DMIX_BACKUP" >&2
            return 1
        fi
        local tmp="$ASOUND_CONF.tmp.$$"
        sed "s/__DONGLE_CARD__/$dongle/g" "$ASOUND_CONF_FANIN_TEMPLATE" > "$tmp"
        if grep -q '__DONGLE_CARD__' "$tmp"; then
            rm -f "$tmp"
            echo "jasper-audio-topology: __DONGLE_CARD__ still present in rendered asoundrc; aborting" >&2
            return 1
        fi
        chmod 0644 "$tmp"
        mv -f "$tmp" "$ASOUND_CONF"
        log "asoundrc.installed mode=fanin dongle=$dongle"
    else
        # Switching to dmix. If the backup exists, restore it.
        # Otherwise we've never been in fanin, so /etc/asound.conf
        # is already the dmix version → no-op.
        if [[ -f "$ASOUND_CONF_DMIX_BACKUP" ]]; then
            cp -a "$ASOUND_CONF_DMIX_BACKUP" "$ASOUND_CONF"
            log "asoundrc.restored mode=dmix"
        else
            log "asoundrc.noop_no_backup mode=dmix"
        fi
    fi
}

verify_health() {
    local mode="$1"
    sleep "$VERIFY_SETTLE_SECONDS"
    local errors=0

    if ! systemctl is-active jasper-camilla.service >/dev/null 2>&1; then
        echo "VERIFY FAIL: jasper-camilla.service not active" >&2
        errors=$((errors + 1))
    fi

    if [[ "$mode" == "fanin" ]]; then
        if ! systemctl is-active jasper-fanin.service >/dev/null 2>&1; then
            echo "VERIFY FAIL: jasper-fanin.service not active in fanin mode" >&2
            errors=$((errors + 1))
        fi
    fi

    # Sanity that the env file matches the requested mode.
    local active
    active="$(current_mode)"
    if [[ "$active" != "$mode" ]]; then
        echo "VERIFY FAIL: env file says '$active' but we requested '$mode'" >&2
        errors=$((errors + 1))
    fi

    if [[ $errors -gt 0 ]]; then
        log "verify.failed errors=$errors"
    else
        log "verify.ok mode=$mode"
    fi
    return "$errors"
}

# === Argument parsing ==============================================

dry_run=0
target_mode=""
for arg in "$@"; do
    case "$arg" in
        --dry-run) dry_run=1 ;;
        -h|--help) usage; exit 0 ;;
        status|"") target_mode="status" ;;
        dmix|fanin) target_mode="$arg" ;;
        *)
            echo "jasper-audio-topology: unknown argument: $arg" >&2
            usage
            exit 1
            ;;
    esac
done
[[ -z "$target_mode" ]] && target_mode="status"

if [[ "$target_mode" == "status" ]]; then
    print_status
    exit 0
fi

current="$(current_mode)"

if [[ "$current" == "$target_mode" ]]; then
    echo "Already in '$target_mode' mode; no action taken."
    exit 0
fi

if [[ "$dry_run" -eq 1 ]]; then
    echo "DRY RUN — would switch from '$current' → '$target_mode':"
    echo "  1. Stop renderers (${RENDERERS[*]}) + DSP daemons (${DSP_DAEMONS[*]})"
    echo "  2. systemctl stop jasper-fanin.service (idempotent)"
    echo "  3. Write $TOPOLOGY_ENV with:"
    echo "       JASPER_AUDIO_TOPOLOGY=$target_mode"
    if [[ "$target_mode" == "fanin" ]]; then
        echo "       JASPER_LIBRESPOT_DEVICE=librespot_substream"
        echo "       JASPER_BLUEALSA_DEVICE=bluealsa_substream"
        echo "       JASPER_USBSINK_PLAYBACK_DEVICE=usbsink_substream"
        echo "       JASPER_SHAIRPORT_DEVICE=shairport_substream"
    else
        echo "       JASPER_LIBRESPOT_DEVICE=jasper_renderer_in"
        echo "       JASPER_BLUEALSA_DEVICE=jasper_renderer_in"
        echo "       JASPER_USBSINK_PLAYBACK_DEVICE=jasper_renderer_in"
        echo "       JASPER_SHAIRPORT_DEVICE=jasper_renderer_in"
    fi
    echo "  4. Install $ASOUND_CONF for $target_mode topology"
    if [[ "$target_mode" == "fanin" && ! -f "$ASOUND_CONF_DMIX_BACKUP" ]]; then
        echo "       (first switch — will back up current asoundrc to $ASOUND_CONF_DMIX_BACKUP)"
    fi
    echo "  5. Re-render /etc/shairport-sync.conf via $APPLY_AIRPLAY_MODE"
    echo "  6. systemctl daemon-reload"
    if [[ "$target_mode" == "fanin" ]]; then
        echo "  7. systemctl enable --now jasper-fanin.service"
    else
        echo "  7. systemctl disable jasper-fanin.service"
    fi
    echo "  8. Start DSP daemons + renderers"
    echo "  9. Verify health (sleep ${VERIFY_SETTLE_SECONDS}s; check critical daemons)"
    echo
    echo "(no changes made; remove --dry-run to apply)"
    exit 0
fi

require_root

log "switch.start from=$current to=$target_mode"

stop_chain
write_topology_env "$target_mode"
if ! switch_asoundrc "$target_mode"; then
    log "switch.asoundrc_failed mode=$target_mode"
    echo "jasper-audio-topology: asoundrc switch failed; aborting" >&2
    # Best-effort restart of whatever was previously running.
    start_chain "$current"
    exit 1
fi
if ! "$APPLY_AIRPLAY_MODE"; then
    log "switch.apply_airplay_mode_failed mode=$target_mode"
    echo "jasper-audio-topology: shairport conf regeneration failed" >&2
    # Continue anyway — shairport may still start with stale conf;
    # operator will see the failure in journalctl.
fi
systemctl daemon-reload

if [[ "$target_mode" == "dmix" ]]; then
    systemctl disable jasper-fanin.service 2>/dev/null || true
fi

start_chain "$target_mode"

if verify_health "$target_mode"; then
    log "switch.complete mode=$target_mode"
    echo "Switched to '$target_mode' mode. Listen for ~30s to confirm audio."
    exit 0
else
    log "switch.complete_with_errors mode=$target_mode"
    echo "Switched to '$target_mode' mode, but health verification reported errors." >&2
    echo "Check: sudo journalctl -u jasper-camilla -u jasper-fanin --since '1 minute ago'" >&2
    exit 2
fi
