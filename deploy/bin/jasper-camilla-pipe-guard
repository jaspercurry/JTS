#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Jasper Curry
#
# SPDX-License-Identifier: Apache-2.0

# jasper-camilla-pipe-guard — break the dead-pipe reboot-loop chain.
#
# Runs as ExecStartPre= on jasper-camilla.service (the CORE music
# daemon, whose unit carries StartLimitAction=reboot — and whose
# OnFailure recovery handler can park it). Two dead-pipe classes,
# both repaired by re-pointing the statefile to the packaged base
# config BEFORE camilla launches, so the failing starts never happen:
#
#   1. PLAYBACK pipe — a BONDED pipe config (docs/HANDOFF-multiroom.md
#      §2 — playback File -> the snapserver FIFO), or a local transport-pipe
#      config (playback File -> jasper-outputd's local content pipe), whose
#      pipe is DEAD.
#
#   2. CAPTURE pipe — a transport-pipe config whose RawFile CAPTURE
#      source is a named pipe under /run (the fan-in camilla.pipe) that
#      is ABSENT. If the statefile is left pointing at a transport-pipe
#      config while the fan-in producer is gone, a camilla restart loads
#      the dangling config, cannot open the absent capture pipe, and
#      crash-loops to `failed`. A pure runtime statefile re-point when
#      the coupling reverts is not enough — a crash mid-transition
#      strands the dangling config, so the guard is the durable floor
#      that breaks this class permanently.
#
# Why ExecStartPre and not OnFailure=: StartLimitAction=reboot and
# OnFailure= both fire when the unit fails — a rescue would RACE the
# reboot. Prevention beats reaction.
#
# The measured failure modes (camilladsp 4.1.3 on jts3, 2026-06-11):
#   - File sink path ABSENT (snapserver stopped; its RuntimeDirectory
#     reaped) -> "Playback error: No such file or directory" + CLEAN
#     exit 0. With Restart=always + RestartSec=2 + StartLimitBurst=5/60s
#     that is a clean-exit loop -> StartLimitAction=reboot fires in
#     under a minute; if snapserver stays broken the boot reconcile
#     cannot fix it -> REBOOT LOOP on the household speaker.
#   - FIFO present, NO reader -> camilladsp blocks in open(2) and the
#     blocked open is not interrupted by SIGTERM (alive-but-silent).
#
# Repair target: the packaged base config (always installed,
# volume_limit-safe, identity EQ). Camilla then starts SOLO-SAFE —
# degraded (no room correction) but PLAYING and recoverable:
# grouping.env stays bonded, so the next jasper-grouping-reconcile run
# re-applies the bond when snapserver is healthy again, and the
# doctor's `grouping: leader pipe` check + /state runtime health show
# the degraded state in the meantime. Self-healing in both directions.
#
# FAIL-OPEN EVERYWHERE: this runs in the start path of the speaker's
# entire music chain. Any unexpected condition (unreadable statefile,
# missing base config, write failure) logs and exits 0 so camilla
# starts unmodified. The unit invokes it with `ExecStartPre=-` as a
# second belt: even a missing script cannot block camilla.
#
# Pure bash, no Python import cost (<5 ms in the solo steady state:
# one statefile read + one grep). Mirrors jasper-wifi-guardian's
# shape and test seams (env-overridable paths, structured
# `event=camilla_pipe_guard.<outcome>` lines on stderr).

set -uo pipefail

STATEFILE="${JASPER_CAMILLA_STATEFILE:-/var/lib/camilladsp/outputd-statefile.yml}"
BASE_CONFIG="${JASPER_CAMILLA_BASE_CONFIG:-/etc/camilladsp/outputd-cutover.yml}"
RUNTIME_SAFE_GRAPH="${JASPER_RUNTIME_SAFE_GRAPH:-/opt/jasper/.venv/bin/jasper-active-speaker}"
SNAPFIFO="${JASPER_GROUPING_SNAPFIFO:-/run/jasper-snapserver/snapfifo}"
# Seconds the reader-presence probe waits before declaring "no reader".
PROBE_TIMEOUT="${JASPER_PIPE_GUARD_PROBE_TIMEOUT:-0.5}"
# Capture-pipe roots: a RawFile capture whose filename lives under one of
# these and is ABSENT means the transport-pipe producer is gone and
# camilla would crash-loop on the dangling config. /run is the runtime
# tmpfs the transport pipe lives under (fan-in camilla.pipe); narrowing to
# /run keeps the guard from ever touching a persistent ALSA-or-file capture
# path.
CAPTURE_RUNTIME_ROOT="${JASPER_PIPE_GUARD_CAPTURE_ROOT:-/run/}"
# Playback-pipe roots: a File playback sink under this runtime root must have
# a live FIFO reader before Camilla starts. This covers the local
# transport-pipe outputd pipe without changing the older SnapFIFO-specific
# reason strings below.
PLAYBACK_RUNTIME_ROOT="${JASPER_PIPE_GUARD_PLAYBACK_ROOT:-/run/}"

log() {
    # log <outcome> [detail...]
    local outcome="$1"
    shift || true
    echo "event=camilla_pipe_guard.${outcome} ${*}" >&2
}

# repair_statefile <why> <config_path>
# Re-point STATEFILE to the runtime-contract-safe graph (base config for a
# full-range system; a guarded active startup graph for a saved roleful
# topology). A blocked decision intentionally leaves the statefile
# untouched. Echoes the structured outcome line. Returns 0 always
# (FAIL-OPEN: never block camilla's start path).
repair_statefile() {
    local why="$1" from="$2" repaired_to output
    if ! command -v "$RUNTIME_SAFE_GRAPH" >/dev/null 2>&1; then
        log skip reason=runtime_contract_unavailable "detail=$why"
        return 0
    fi
    # Ask the active-speaker runtime contract for the only legal persisted
    # graph. For ordinary full-range systems this is the packaged base
    # config; for saved roleful/protected topologies it must be a guarded
    # active startup graph. A blocked decision leaves the statefile
    # untouched: flat stereo is not a safe recovery target once a
    # tweeter/protected role is saved.
    if output="$(
        "$RUNTIME_SAFE_GRAPH" runtime-safe-graph \
            --statefile "$STATEFILE" \
            --flat-config "$BASE_CONFIG" \
            --write-statefile \
            --json 2>&1
    )"; then
        repaired_to="$(
            sed -n 's/^[[:space:]]*config_path:[[:space:]]*//p' "$STATEFILE" \
                | head -1 | tr -d '"' | tr -d "'"
        )"
        log repaired "reason=$why from=$from to=${repaired_to:-unknown}" \
            "detail=camilla starts on runtime-contract-safe graph; next reconcile re-applies the live lane when its pipe is healthy"
    else
        log skip reason=runtime_contract_blocked "detail=$why" \
            "message=$(printf '%s' "$output" | tr '\n' ' ' | cut -c1-240)"
    fi
    return 0
}

check_playback_pipe_or_repair() {
    local pipe_path="$1" absent_reason="$2" no_reader_reason="$3" \
        healthy_reason="$4" probe_unavailable_reason="$5" why
    if [ -p "$pipe_path" ]; then
        # Reader-presence probe: opening a FIFO for write returns instantly
        # iff a reader exists; with no reader it blocks (-> timeout). The
        # momentary write-open is harmless to FIFO readers designed for writers
        # that come and go. FAIL-OPEN if the timeout tool itself is unavailable.
        if ! command -v timeout >/dev/null 2>&1; then
            log ok "reason=$probe_unavailable_reason"
            exit 0
        fi
        if timeout "$PROBE_TIMEOUT" bash -c "exec 3> '$pipe_path'" 2>/dev/null; then
            log ok "reason=$healthy_reason"
            exit 0
        fi
        why="$no_reader_reason"
    else
        why="$absent_reason"
    fi

    repair_statefile "$why" "$config_path"
    exit 0
}

[ -r "$STATEFILE" ] || { log skip reason=no_statefile; exit 0; }

config_path=$(
    sed -n 's/^[[:space:]]*config_path:[[:space:]]*//p' "$STATEFILE" \
        | head -1 | tr -d '"' | tr -d "'"
)
[ -n "$config_path" ] || { log skip reason=no_config_path; exit 0; }
[ -r "$config_path" ] || { log skip reason=config_unreadable "path=$config_path"; exit 0; }

# --- CAPTURE-pipe check (THE INCIDENT class) ----------------------------
# A lean / transport-pipe config captures from a RawFile named pipe under
# /run. If that pipe is ABSENT (the producer — usbsink lean lane or fan-in
# coupling — reverted to the aloop lane), camilla cannot open it and
# crash-loops to `failed`. Read the config's CAPTURE filename; if it is a
# runtime pipe under /run that does not exist, repair to the base config.
# Runs BEFORE the playback solo-config early-exit, because the incident
# config is solo on the PLAYBACK side — only its CAPTURE source is dead.
capture_filename=$(
    awk '
        /^[[:space:]]*capture:[[:space:]]*$/ { in_cap = 1; next }
        # A new top-level (or sibling) "<key>:" block ends the capture map.
        in_cap && /^[[:space:]]*[a-zA-Z_]+:[[:space:]]*$/ { in_cap = 0 }
        in_cap && /^[[:space:]]*filename:[[:space:]]*/ {
            sub(/^[[:space:]]*filename:[[:space:]]*/, "")
            gsub(/["'\'']/, "")
            print
            exit
        }
    ' "$config_path"
)
if [ -n "$capture_filename" ]; then
    case "$capture_filename" in
        "${CAPTURE_RUNTIME_ROOT}"*)
            if [ ! -e "$capture_filename" ]; then
                repair_statefile capture_pipe_absent "$config_path"
                exit 0
            fi
            ;;
    esac
fi

# Pipe-shaped = the config's playback block has a filename.
playback_filename=$(
    awk '
        /^[[:space:]]*playback:[[:space:]]*$/ { in_play = 1; next }
        # A new top-level (or sibling) "<key>:" block ends the playback map.
        in_play && /^[[:space:]]*[a-zA-Z_]+:[[:space:]]*$/ { in_play = 0 }
        in_play && /^[[:space:]]*filename:[[:space:]]*/ {
            sub(/^[[:space:]]*filename:[[:space:]]*/, "")
            gsub(/["'\'']/, "")
            print
            exit
        }
    ' "$config_path"
)

if [ -z "$playback_filename" ]; then
    log ok reason=solo_config
    exit 0
fi

# Bonded pipe config. Healthy only if the FIFO exists AND has a reader.
if [ "$playback_filename" = "$SNAPFIFO" ]; then
    check_playback_pipe_or_repair \
        "$SNAPFIFO" fifo_absent no_reader pipe_healthy pipe_exists_probe_unavailable
fi

# Local transport-pipe config. Healthy only if outputd has already created and
# opened its local content pipe for reading.
case "$playback_filename" in
    "${PLAYBACK_RUNTIME_ROOT}"*)
        check_playback_pipe_or_repair \
            "$playback_filename" playback_pipe_absent playback_pipe_no_reader \
            playback_pipe_healthy playback_pipe_exists_probe_unavailable
        ;;
esac

log ok reason=non_runtime_playback_pipe
exit 0
