GEMINI_API_KEY=
JASPER_VOICE_PROVIDER=gemini
JASPER_GEMINI_MODEL=gemini-3.1-flash-live-preview
# Pin the TTS voice so it's consistent across sessions. Choices:
# Aoede, Charon, Fenrir, Kore, Puck, Leda, Orus, Zephyr (per Gemini
# 3.1 Live Preview prebuilt voices).
JASPER_GEMINI_VOICE=Aoede
JASPER_WAKE_MODEL=hey_jarvis
JASPER_WAKE_THRESHOLD=0.5
# JASPER_MIC_DEVICE is a PortAudio device name/substring (NOT an ALSA
# pcm string — sounddevice rejects "plughw:" syntax). Examples:
#   Array     → ReSpeaker XVF3800 (default; 16 kHz mono native)
#   UMIK-2    → MiniDSP UMIK-2 (48 kHz stereo native — see CAPTURE_RATE)
# Inspect with: /opt/jasper/.venv/bin/python -c \
#   'import sounddevice as sd; print(sd.query_devices())'
JASPER_MIC_DEVICE=Array
# Capture rate + channel count — MicCapture polyphase-downsamples to
# 16 kHz mono internally. XVF3800 = 16000/1 (defaults). Mics that only
# do 44.1/48 kHz (UMIK-2 et al.) need 48000/2.
JASPER_MIC_CAPTURE_RATE=16000
JASPER_MIC_CAPTURE_CHANNELS=1
# JASPER_TTS_DEVICE: PortAudio device name (bare ALSA pcm name from
# /root/.asoundrc — `plug:` aliases aren't enumerated by PortAudio).
# `jasper_out` is the fan-out PCM that duplicates the stream to BOTH
# the Apple USB-C dongle (the actual speaker) AND the XVF3800's
# USB-IN endpoint (the AEC reference). See asoundrc.jasper.
JASPER_TTS_DEVICE=jasper_out
# Top-level pcm.jasper_out runs at 48 kHz (matches the Apple dongle's
# native rate and CamillaDSP's chunk rate). TtsPlayout polyphase-
# upsamples Gemini's 24 kHz → 48 kHz before write (factor 2, exact).
JASPER_TTS_OUTPUT_RATE=48000
# Static attenuation applied to TTS PCM before it hits the dongle.
# Gemini outputs at peaks ~-3 dBFS; without this gain stage TTS is
# uncomfortably loud vs music. -8 dB is a comfortable default. Make
# more negative for quieter voice, 0 for "match Gemini native level".
JASPER_TTS_GAIN_DB=-8
JASPER_CAMILLA_HOST=127.0.0.1
JASPER_CAMILLA_PORT=1234
JASPER_DUCK_DB=-15
JASPER_IDLE_TIMEOUT_SEC=10
# Silero VAD threshold for barge-in. While the model is producing TTS,
# mic frames are only forwarded to Gemini if local VAD says speech
# probability >= this value. 0.5 = Silero default; raise to filter out
# more noise, lower if real interrupts are missed.
JASPER_VAD_BARGE_IN_THRESHOLD=0.5
JASPER_DAILY_SPEND_CAP_USD=1.00
JASPER_USAGE_DB=/var/lib/jasper/usage.db
MOODE_BASE_URL=http://127.0.0.1
MPD_HOST=127.0.0.1
MPD_PORT=6600
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8765/callback
SPOTIFY_CACHE_PATH=/var/lib/jasper/.spotify-cache
JASPER_SPOTIFY_DEVICE_NAME=moode
JASPER_DEFAULT_LOCATION=
JASPER_WEATHER_UNITS=celsius
# NYC MTA subway. Empty = disabled. Find your stop_id at
# data.ny.gov "MTA Subway Stations and Complexes" (column "GTFS Stop ID").
# 9 Av on the West End line is "B16".
JASPER_SUBWAY_STATION_ID=
JASPER_SUBWAY_DEFAULT_DIRECTION=uptown
# Lines that actually stop at your station (space- or comma-separated).
# Used for validation so we don't try to look up trains that never stop here.
JASPER_SUBWAY_LINES=
# Example for Sunset Park (9 Av on the West End line, D train):
#   JASPER_SUBWAY_STATION_ID=B12
#   JASPER_SUBWAY_DEFAULT_DIRECTION=uptown
#   JASPER_SUBWAY_LINES=D
