# =========================================================================
# .env.example is the install-time template for /etc/jasper/jasper.env
# (Pi-side config). install.sh copies it to that path during deploy.
# Settings here are NOT loaded by laptop-side scripts in scripts/.
#
# For LAPTOP-side settings (which Pi to target, which SSH user), edit
# `.env.local` at the repo root — it's gitignored and auto-written by
# `bash scripts/onboard.sh <hostname>`. The two vars `scripts/_lib.sh`
# recognizes there are:
#
#   PI_HOST=jts.local    # default. Set per-checkout for multi-Pi
#   PI_USER=pi
#
# Multi-Pi: a second checkout (or worktree) targeting jts2.local has
# its own .env.local with PI_HOST=jts2.local. See QUICKSTART.md.
# =========================================================================

# =========================================================================
# Voice provider — the user MUST pick one via the wizard at
# http://${JASPER_HOSTNAME}/voice on first boot. Intentionally NOT set
# here: this file is the install-time template, and JASPER_VOICE_PROVIDER
# is owned by the wizard, which writes /var/lib/jasper/voice_provider.env.
# Having a default in BOTH files is the kind of stale-vs-runtime mismatch
# that bites later. If you want a non-interactive default (CI, headless
# imaging), write the value to /var/lib/jasper/voice_provider.env
# directly. See docs/HANDOFF-voice-providers.md for cost / model /
# capability tradeoffs and `scripts/switch-voice-provider.sh` for a
# one-liner that flips the provider on the Pi without restarting by hand.
# =========================================================================

# ---- Gemini Live (default) ----------------------------------------------
GEMINI_API_KEY=
# Live API model. `gemini-3.1-flash-live-preview` is the production
# default. Fallback `gemini-2.5-flash-native-audio-preview-12-2025`
# is positioned by Google as 3.1's predecessor; flip via
# `scripts/switch-gemini-model.sh 2.5` when 3.1 Live is silently
# failing (sessions ending with 0 tokens AND no SDK exception — a
# Google-side condition we've hit). Do NOT use the plain
# `gemini-2.5-flash` — it's not a Live model. See CLAUDE.md
# "Gemini model switching" for symptoms and detection.
JASPER_GEMINI_MODEL=gemini-3.1-flash-live-preview
# Pin the TTS voice so it's consistent across sessions. Choices:
# Aoede, Charon, Fenrir, Kore, Puck, Leda, Orus, Zephyr (per Gemini
# 3.1 Live Preview prebuilt voices).
JASPER_GEMINI_VOICE=Aoede

# ---- OpenAI Realtime ----------------------------------------------------
# gpt-realtime-2 (released 2026-05-07): reasoning-capable, 128K context,
# image input, multi-tool-at-once. Audio billing: $32 / $64 / $0.40 per
# 1M tokens (in / out / cached) → roughly $0.30/minute of conversation,
# ~5x Gemini Live. For lighter workloads use gpt-realtime-mini ($10/$20/
# $0.30). Voices: marin (default), cedar, alloy, ash, ballad, coral,
# echo, sage, shimmer, verse.
OPENAI_API_KEY=
JASPER_OPENAI_MODEL=gpt-realtime-2
JASPER_OPENAI_VOICE=marin
# Reasoning effort for gpt-realtime-2: minimal | low | medium | high |
# xhigh. `low` matches the SDK default and is right for short voice
# queries; `minimal` cuts ~1 second of TTFA at the cost of less coherent
# multi-step answers. Field is silently dropped on non-`-2` models.
JASPER_OPENAI_REASONING_EFFORT=low
# Time budget (seconds) for the initial OpenAI Realtime WebSocket
# connect at daemon startup. Transient failures (DNS lookup error,
# WS reset, 5xx) retry with exponential backoff + jitter until either
# the connect succeeds or the budget is exhausted. On exhaustion the
# daemon exits non-zero and systemd's `Restart=on-failure` outer loop
# spawns a fresh process with another full budget.
#
# 600 s (10 min) is the production default — long enough to ride out
# any realistic home-network blip at boot (the user typically restores
# WiFi within ~1-2 min of a router reboot or unclean shutdown), short
# enough that a real misconfiguration (revoked API key, persistent DNS
# break) still surfaces on the dashboard / doctor within ~10 min
# instead of hanging forever. Pre-2026-05-23 the cap was 5 retries
# (~15 s wall-time), which silently killed the voice daemon during
# the WiFi-recovery window after an unclean shutdown.
#
# Lower (e.g. 60) only if you want fast-feedback at the cost of
# resilience to network races; 0 means "single attempt, no retries"
# (auth/config errors propagate immediately regardless of budget —
# only transient errors are retried). Authoritative variable name;
# no per-provider equivalents until Gemini/Grok hit the same bug.
JASPER_OPENAI_INITIAL_CONNECT_BUDGET_SEC=600

# ---- xAI Grok Voice Agent -----------------------------------------------
# grok-voice-think-fast-1.0 — OpenAI-Realtime-protocol-compatible per
# xAI's docs (we route through the same adapter with a base-URL swap to
# wss://api.x.ai/v1/realtime). Bills a flat $3/hour per session, NOT
# per-token, so JASPER_DAILY_SPEND_CAP_USD's token-based accounting
# under-counts under Grok — the daemon logs a warning at startup and
# the cap becomes a liveness nudge rather than a real ceiling. Voices:
# eve (default), ara, rex, sal, leo.
XAI_API_KEY=
JASPER_GROK_MODEL=grok-voice-think-fast-1.0
JASPER_GROK_VOICE=eve

# Active wake-word model. Either a bundled openWakeWord name
# (`alexa`, `hey_jarvis`, `hey_mycroft`) or an absolute path to a
# .onnx file under /var/lib/jasper/wake/ (e.g. the community
# `jarvis_v2.onnx` model is what the JTS install ships with as
# `/var/lib/jasper/wake/jarvis_v2.onnx`). Set via the picker at
# http://${JASPER_HOSTNAME}/wake/ or `scripts/switch-wake-word.sh`
# — both write `/var/lib/jasper/wake_model.env`, which overrides
# this template value at runtime. Registry of curated models lives
# in jasper/wake_models.py; add a new row there to surface it in
# the picker. Fallback `hey_jarvis` is the openWakeWord-bundled
# model that is always present (no separate download), so
# dev/test runs without seeded env files still load something.
JASPER_WAKE_MODEL=hey_jarvis
# JASPER_WAKE_THRESHOLD: openWakeWord confidence threshold (0–1).
# 0.30 is the empirically-tuned production value — sensitive enough
# to catch "Hey Jarvis" at high music SPL, low enough to false-fire
# rarely on typical music. Raise to 0.40 if music starts triggering
# wakes; lower to 0.20 if you're missing a lot of attempts.
JASPER_WAKE_THRESHOLD=0.30
# JASPER_WAKE_EVENTS_MAX_AUDIO_BYTES caps per-event WAV storage at
# /var/lib/jasper/wake-events/. Audio rolls oldest-first when full;
# DB rows are kept forever (their `audio_*_path` fields flip to
# `rolled_off` after audio is reaped). 1 GiB default sized for the
# triple-stream architecture: each event saves 3 WAVs (AEC ON +
# AEC OFF + DTLN, ~192 KB each = ~576 KB/event), so 1 GiB ≈ 1740
# events ≈ 5-7 weeks at 30-50 events/day. Bump higher if you need
# longer history; lower if you're tight on the SD card.
JASPER_WAKE_EVENTS_MAX_AUDIO_BYTES=1073741824
# JASPER_MIC_DEVICE selects the mic source for jasper-voice. The
# install-time reconciler owns this value when it is one of the
# standard JTS choices (Array or udp:<AEC port>), so stale AEC
# settings are cleared automatically if the mic disappears. Set a
# custom value here only when intentionally bypassing that policy.
# Two transport flavours:
#
#   PortAudio device (substring match; sounddevice rejects "plughw:"
#   syntax). Examples:
#     Array    → XVF3800 chip's processed conference channel
#                (DEFAULT, also the chip's BF/NS/AGC output).
#                Software AEC bridge is bypassed.
#     UMIK-2   → MiniDSP UMIK-2 (48 kHz stereo native — see CAPTURE_RATE)
#     Inspect: /opt/jasper/.venv/bin/python -c \
#       'import sounddevice as sd; print(sd.query_devices())'
#
#   UDP socket (paired with jasper-aec-bridge over PR 2's UDP
#   transport — the bridge writes 16 kHz mono int16 frames to this
#   host:port). Forms:
#     udp:<port>           shorthand, host = 127.0.0.1
#     udp://<host>:<port>  full URL form
#   Enables software AEC when `JASPER_AEC_MODE=auto` and the
#   configured AEC mic is present with 6-channel firmware. The
#   reconciler sets this automatically; don't hard-code it by hand
#   unless you are debugging the bridge.
#   See AGENTS.md / CLAUDE.md "Acoustic echo cancellation" for full
#   context.
JASPER_MIC_DEVICE=Array
# AEC reconciler config. `JASPER_AEC_MIC_DEVICE` is the PortAudio
# substring used by jasper-aec-bridge for the XVF raw-mic stream;
# `JASPER_MIC_DEVICE_CANDIDATES` is the direct-mic fallback list the
# reconciler may select when AEC is unavailable. Keep this as simple
# card/device names for now (comma-separated, or shell-quoted if you
# use spaces); future mics can be added here without changing the
# reconciler.
JASPER_AEC_MIC_DEVICE=Array
JASPER_MIC_DEVICE_CANDIDATES=Array
# JASPER_AEC_MODE is stateful on the Pi at /var/lib/jasper/aec_mode.env
# rather than in this secrets file. Values: auto | disabled. Default
# is auto; set disabled there to force chip-direct mic and keep the
# bridge off.
#
# JASPER_WAKE_LEG_RAW and JASPER_WAKE_LEG_DTLN live in the same file
# (also written by the /system Wake detection card) and gate the two
# additive wake-detection legs the bridge can fan out. Defaults:
#
#   JASPER_WAKE_LEG_RAW=1   - dual-stream baseline (~5 MB / negligible
#                             CPU; recovers wake-rate misses on the
#                             AEC ON leg via OR-fusion).
#   JASPER_WAKE_LEG_DTLN=0  - triple-stream third leg (+~75 MB RAM,
#                             +~25% one core); opt-in via /system for
#                             2 GB Pis where the OR-fusion gain is
#                             worth the resource cost.
#
# The reconciler maps these booleans to JASPER_MIC_DEVICE_RAW,
# JASPER_MIC_DEVICE_DTLN, and JASPER_AEC_DTLN_ENABLED in this file
# on every reconcile pass — do NOT set those directly here; on next
# deploy migrate_wake_legs_config moves any hand-set values into
# aec_mode.env and strips them from here.
# JASPER_AEC_UDP_HOST / JASPER_AEC_UDP_PORT control where the bridge
# sends AEC'd mic. jasper-voice listens on whatever
# `JASPER_MIC_DEVICE=udp:<port>` points at. Default 127.0.0.1:9876;
# only change if 9876 collides on your LAN (the socket binds to
# loopback so non-LAN clients can't reach it anyway).
JASPER_AEC_UDP_HOST=127.0.0.1
JASPER_AEC_UDP_PORT=9876
# JASPER_AEC_REF_GAIN_DB pre-amplifies the digital AEC reference
# signal before it enters the engine.
#
# Current production: 0 dB. Tuned 2026-05-16 after the bridge
# switched from raw mic 0 (chip channel 2, no chip processing) to
# the ASR beam (chip channel 1, with chip BF + NS + AGC + HPF).
# The chip's AGC now normalizes the mic to ~-24 dBFS RMS, which
# closes the loop-gain gap that REF_GAIN used to compensate for.
# Any positive REF_GAIN now drives the digital reference into hard
# clipping during music playback (observed 11-44% ref_clip with
# REF_GAIN=25 + chip AGC), which destabilizes AEC3's adaptive filter
# and produces wildly variable cancellation (-0.3 to -20.8 dB across
# consecutive 5-second windows).
#
# At REF_GAIN=0 with chip channel 1, ref and mic naturally arrive
# at ~-22 dBFS each (AEC3's design point: ref ~= mic). Steady-state
# attenuation is -15 to -20 dB on music, ref_clip stays at 0%.
#
# Historical: REF_GAIN=25 was correct for the previous architecture
# (channel 2 raw mic, no chip AGC). Don't restore that value without
# also reverting `MIC_CHANNEL_INDEX` in jasper/mics/xvf3800.py.
# See docs/HANDOFF-aec.md "Production tuning (2026-05-16)" for the
# full story.
JASPER_AEC_REF_GAIN_DB=0
# JASPER_AEC_NS_ENABLED / JASPER_AEC_NS_LEVEL toggle + tune the
# post-AEC noise-suppression stage. NS aggressiveness directly
# affects wake-word detection: more NS = more HF speech feature
# stripping = more silent misses. 2026-05-20 sweep: ns=low caught
# 5/20 Jarvis vs ns=moderate 4/20 vs ns=high 3/20 vs ns=very_high
# 2/20. Default is 'low' (the best non-disabled option on Trixie's
# libwebrtc-audio-processing-1 v1.3-3, which lacks kVeryLow).
# Disable entirely with JASPER_AEC_NS_ENABLED=0 for max HF
# preservation at the cost of residual music passing through.
JASPER_AEC_NS_ENABLED=1
JASPER_AEC_NS_LEVEL=low
# JASPER_AEC_AGC1_ENABLED enables WebRTC AGC1 in kAdaptiveDigital
# mode for post-AEC level normalization. Empirically (2026-05-20
# sweep) this produces a uniform ~RMS 1213 output across utterances,
# regardless of instantaneous music level — fixing the "some
# Jarvises overblown, some too quiet" symptom that pure static
# JASPER_AEC_MIC_GAIN_DB produces. Wake-rate is unchanged from
# static +12 dB gain; the win is output consistency, not detection
# rate. On by default since 2026-05-20.
#
# The TARGET_DBFS and MAX_GAIN_DB knobs map to WebRTC's
# `target_level_dbfs` (0–31, where the value is positive dBFS-below-
# zero; so 9 → −9 dBFS target) and `compression_gain_db` (0–90,
# the soft-knee compressor gain parameter — NOT a "max headroom").
# A 2026-05-21 audit confirmed these are valid WebRTC fields, but
# our sweep showed they have minimal observable effect on Trixie's
# libwebrtc-audio-processing-1 v1.3-3 (the built-in limiter
# dominates the output level). Keep at defaults unless future
# measurement shows otherwise. There is NO attack-time / release-
# time parameter in WebRTC's public AGC1 surface — any earlier
# claim of "150 ms attack" was incorrect and has been removed from
# the docs.
#
# AGC2 (below) is the no-op alternative — adaptive_digital sub-
# config defaults off in our binding, so AGC2=1 does essentially
# nothing for level control. Use AGC1, not AGC2.
JASPER_AEC_AGC1_ENABLED=1
JASPER_AEC_AGC1_TARGET_DBFS=9
JASPER_AEC_AGC1_MAX_GAIN_DB=18
# JASPER_AEC_AGC2 — see comment above; left for compat but no-op.
JASPER_AEC_AGC2=0
# JASPER_AEC_MIC_GAIN_DB applies a static gain to the AEC engine's
# output before it reaches openWakeWord (via UDP). +6 dB is
# the tested production value — restores level into openWakeWord's
# training distribution without warping speech envelopes (the HA
# Voice PE pattern, `gain_factor: 4` ≈ +12 dB; we use a more modest
# +6 since our XVF mic preamp delivers higher digital level than
# Voice PE's). Soft-clipped via tanh on the way out, so high gain
# doesn't hard-clip; any saturation is reported as `out_clip=X%` in
# the bridge's RMS log. Tune downward (3 dB, 0 dB) if you see
# `out_clip` >1% sustained or false wakes from TTS bleed; tune
# upward (9 dB, 12 dB) if wake-word still misses at high music SPL.
JASPER_AEC_MIC_GAIN_DB=6
# JASPER_AEC_STALL_RESTART_SEC is the consecutive-empty-second
# threshold after which the bridge bails non-zero so systemd
# `Restart=on-failure` can spin up a fresh process. PortAudio's
# `InputStream` is one-shot — once the underlying ALSA capture PCM
# dies (typically a USB underrun on the XVF chip's UAC2 endpoint),
# the callback simply stops being invoked, and there's no in-process
# recovery path. Hit in production 2026-05-11 — bridge sat silently
# stalled for 10 minutes, wake-word was deaf, no audible cue.
# 0 = disabled (legacy "log forever" behaviour). Default 5 s →
# typical recovery is ~5 s detect + 2 s `RestartSec` + 1 s bridge
# warm-up ≈ 8 s of mic-deaf, vs. forever without it.
JASPER_AEC_STALL_RESTART_SEC=5
# JASPER_AEC_STALL_DRIP_MAX_WINDOWS hardens that same recovery against a
# *slow-drip* stall the consecutive-empty counter structurally misses: it
# resets on a single frame, so an intermittent trickle (a frame every few
# seconds) keeps the mic effectively dead (<1 usable frame/s vs ~12.5/s
# healthy) without ever reaching the continuous threshold. Observed
# 2026-05-31 — the bridge ran ~13 h deaf, NRestarts=0, until a manual
# restart. This watchdog counts the mic frame *rate* over rolling ~10 s
# windows and bails non-zero (→ systemd restart) after this many CONSECUTIVE
# low-rate windows. Conservative: a brief blip clears on the next good
# window; a healthy or merely-degraded mic never trips. Default 3 (~30 s
# sustained). 0 = disabled.
JASPER_AEC_STALL_DRIP_MAX_WINDOWS=3
# Capture rate + channel count for the PortAudio path. (UDP transport
# from the bridge is always 16 kHz mono — these knobs don't apply
# under `JASPER_MIC_DEVICE=udp:...`.) XVF chip raw is 16k 6ch (use
# Array + ch=6 if bypassing the bridge). UMIK-2 et al.: 48000/2.
JASPER_MIC_CAPTURE_RATE=16000
JASPER_MIC_CAPTURE_CHANNELS=1
# Outputd cutover default: voice/cue TTS sends 48 kHz stereo PCM plus
# gain metadata to jasper-outputd, the final output owner. outputd is the
# supported runtime path. The old sounddevice/PortAudio
# playout class remains in-tree for tests and pre-outputd archaeology, but
# JASPER_TTS_TRANSPORT=sounddevice is rejected by current runtime config
# because it no longer has dynamic assistant-loudness matching.
JASPER_TTS_TRANSPORT=outputd
JASPER_TTS_OUTPUTD_SOCKET=/run/jasper-outputd/tts.sock
# Optional DAC8x final-output route. Leave unset/direct for the normal
# selected-DAC alias. On recognized DAC8x hardware only, mono:N sums the
# stereo outputd program onto physical output N, and stereo:L,R maps
# left/right to two distinct physical outputs. Numbers are 1-indexed to
# match the DAC8x terminals. This is a lab/single-amp commissioning
# route, not an active-speaker crossover channel map. Takes effect when
# deploy, boot/udev reconcile, or a manual jasper-audio-hardware-reconcile
# run re-renders /etc/asound.conf.
# JASPER_OUTPUT_DAC_ROUTE=mono:5
# Legacy sounddevice-only target, ignored by the supported outputd runtime.
JASPER_TTS_DEVICE=jasper_out
# outputd's IPC contract and the legacy pcm.jasper_out path both run
# at 48 kHz. TtsPlayout polyphase-upsamples provider/cue PCM from
# 24 kHz → 48 kHz before write (factor 2, exact).
JASPER_TTS_OUTPUT_RATE=48000
# Provider/model/voice loudness profile store. Python can seed/learn the
# source profile; jasper-outputd consumes it when choosing final
# assistant gain.
JASPER_ASSISTANT_LOUDNESS_PROFILE_PATH=/var/lib/jasper/assistant_loudness_profiles.json
# Off by default so daemon restarts never spend provider TTS calls
# implicitly. The /voice/ wizard's "Save and Test" button runs one
# deliberate bounded seed; operators can opt into one startup seed with:
# JASPER_ASSISTANT_LOUDNESS_AUTO_SEED=1
# outputd assistant loudness policy. These defaults should normally be
# retuned in /var/lib/jasper/outputd.env, not here.
JASPER_OUTPUTD_ASSISTANT_OFFSET_LU=1.5
JASPER_OUTPUTD_ASSISTANT_MAX_PEAK_DBFS=-3.0
JASPER_OUTPUTD_ASSISTANT_FALLBACK_SOURCE_LUFS=-24.0
JASPER_OUTPUTD_ASSISTANT_FALLBACK_SOURCE_PEAK_DBFS=-6.0
JASPER_OUTPUTD_ASSISTANT_DEFAULT_SILENCE_TARGET_LUFS=-41.0
JASPER_OUTPUTD_CONTENT_SILENCE_LUFS=-60.0
# CamillaDSP websocket — jasper-voice and jasper-control reach the
# DSP for ducking (`main_volume`), gain reads, and lightweight
# content-activity telemetry. CamillaDSP listens on
# loopback only (set in `deploy/camilladsp/v1.yml`); no auth, but
# also not reachable off-host. Change the port if 1234 collides on
# this host.
JASPER_CAMILLA_HOST=127.0.0.1
JASPER_CAMILLA_PORT=1234
# Music attenuation while the model is actively listening / speaking.
# -25 dB drops music from "full" to "background voice over" — clear
# enough to hear the assistant without losing the song. Anything
# tighter than ~-18 dB makes wake utterances harder to pick out;
# anything beyond ~-30 dB is effectively a music pause and feels
# abrupt when the duck releases. CamillaDSP's `main_volume` actuates
# this; the un-duck back to 0 dB happens on turn_complete + tail.
JASPER_DUCK_DB=-25
# Pre-response idle watchdog. If the voice daemon has sent
# activity_end (or commit + response.create for OpenAI) and then
# receives zero audio chunks AND no other server activity for this
# many seconds, the turn is closed, music un-ducks, and the wake
# loop returns to listening. Recovery timer for "API is silent and
# we got nothing back." 20 s sits ~2.6× above the worst observed
# OpenAI Realtime first-chunk latency (~7.7 s in 2026-05-21
# production logs) while keeping recovery from a genuine hang under
# half a minute. Lower (e.g. 10) for faster un-duck at the cost of
# clipping risk on slow days. Tool dispatches and intermediate
# server events DO reset the anchor (see
# docs/HANDOFF-voice-providers.md "Idle anchor + tool rounds"), so
# this knob is purely about pure-silence recovery, not "model is
# thinking too long." Separate from NO_SPEECH_ABORT_SEC=5 (the
# "wake word but no speech" case, hardcoded in voice_daemon.py).
JASPER_IDLE_TIMEOUT_SEC=20
# jasper-control HTTP surface for the rotary dial and other LAN
# clients (volume / transport / session). Bound to 0.0.0.0 because
# the dial connects from a different host. No auth — home network
# only. Change the port if 8780 collides with something on your LAN.
JASPER_CONTROL_HOST=0.0.0.0
JASPER_CONTROL_PORT=8780
# Management request guardrails. Host/Origin checks allow localhost,
# loopback/private IPs, JASPER_HOSTNAME, and this machine's hostname.
# Add comma-separated extra local aliases here if a custom DNS name or
# reverse proxy should reach jasper-control directly. POST bodies are
# tiny JSON payloads; keep the cap low unless a future accessory needs
# more room.
JASPER_MANAGEMENT_ALLOWED_HOSTS=
JASPER_CONTROL_MAX_POST_BYTES=4096
# UDP log listener for the dial — diagnostic stream from the dial's
# firmware ends up in `journalctl -u jasper-control` so we can debug
# without USB-tethering. Lossy-but-fast UDP. Avoid 514 to dodge
# rsyslog conflict.
JASPER_DIAL_LOG_HOST=0.0.0.0
JASPER_DIAL_LOG_PORT=5514
# Unix-domain socket where voice_daemon listens for external session
# triggers (dial long-press via jasper-control). Lives in /run, which
# systemd auto-cleans at service stop. Both jasper-voice and
# jasper-control run as root so default 0o660 perms are fine.
JASPER_VOICE_CONTROL_SOCKET=/run/jasper/voice.sock
# Idle context reset is OFF by default — the persistent live session
# keeps conversational context indefinitely. OpenAI Realtime auto-
# truncates past 128K and caps sessions at 60 min, so unbounded growth
# is impossible. Set a positive value (e.g. 21600 = 6 h) only if you
# observe stale-context glitches in practice; each reset busts the
# OpenAI prompt cache (~$0.008/reset) and blocks the wake event for
# 1-6 s during reopen. Per-provider: tune separately or leave each at
# 0. Legacy JASPER_LIVE_CONTEXT_RESET_SEC, if set, supplies a global
# default for any provider whose specific var is unset.
JASPER_OPENAI_CONTEXT_RESET_SEC=0
JASPER_GEMINI_CONTEXT_RESET_SEC=0
JASPER_GROK_CONTEXT_RESET_SEC=0
# Silero VAD threshold for barge-in. While the model is producing TTS,
# mic frames are only forwarded to Gemini if local VAD says speech
# probability >= this value. 0.5 = Silero default; raise to filter out
# more noise, lower if real interrupts are missed.
JASPER_VAD_BARGE_IN_THRESHOLD=0.5

# Server-side VAD experiment: when enabled and music is playing, switch
# providers that support it (OpenAI/Grok today) to server_vad for
# end-of-utterance detection instead of local Silero. Production defaults
# to local Silero because OpenAI server VAD cut off real utterances in
# the May 2026 A/B matrix (see docs/HANDOFF-vad-experiments.md).
# create_response and interrupt_response are always false so the daemon
# retains control of response timing.
JASPER_SERVER_VAD_ENABLED=0
# Start at 0.5 (OpenAI default) if you are deliberately testing server
# VAD. Lower if short commands during music are still missed; raise if
# music lyrics trigger false commits.
JASPER_SERVER_VAD_THRESHOLD=0.5
JASPER_SERVER_VAD_SILENCE_MS=350
JASPER_SERVER_VAD_PREFIX_MS=300

# Daily voice-API spend ceiling (USD). When the rolling 24h estimate
# crosses this value, jasper-voice refuses new turns and the
# `spend_cap_reached` cue plays on wake. Cost is estimated per
# `jasper/usage.py`: token-billed providers (Gemini/OpenAI) from token
# counts, time-billed providers (Grok, $3/hour) from connection uptime.
# $1/day is the household-safe default at Gemini Live rates
# (~$0.02/min → ~50 min of conversation/day); raise for heavier use.
# Setting to 0 disables the cap entirely.
JASPER_DAILY_SPEND_CAP_USD=1.00
# Safety multiplier the spend cap applies to the rolling 24h spend
# before comparing it to the ceiling above. Keeps the circuit breaker
# conservative (headroom for estimation error and provider-side
# rounding) WITHOUT inflating the cost shown on the /system/ dashboard,
# which reflects best-estimate true rates. 1.0 = no padding; the 1.25
# default trips the cap when true spend reaches ~80% of the ceiling.
# Must be >= 1.0 — a safety multiplier never weakens the cap. To turn
# the cap off, set JASPER_DAILY_SPEND_CAP_USD=0 (not this knob to 0).
JASPER_DAILY_SPEND_CAP_SAFETY_MULTIPLIER=1.25
# SQLite file where session token usage is persisted (one row per
# session, plus connection-uptime intervals for time-billed providers).
# Read by the spend cap and the `/system/` dashboard's spend card. Path
# must be writable by jasper-voice (root) and is created on first run.
# Lives under /var/lib/jasper so it survives deploys.
JASPER_USAGE_DB=/var/lib/jasper/usage.db
# Optional pricing override file. Provider list rates are built into
# jasper/usage.py (correct as of 2026-05-30); when those drift, drop a
# JSON file here to overlay them without a code change — no need to
# edit/redeploy. Keys are provider ids ("gemini", "openai",
# "openai_mini", "grok"); inner keys are the Pricing fields, e.g.:
#   {"gemini": {"audio_input_per_million_usd": 3.0,
#               "audio_output_per_million_usd": 12.0},
#    "grok":   {"flat_per_hour_usd": 3.0}}
# Missing or malformed file falls back to the built-in rates (fail-soft,
# logged). Unset uses the default path below.
JASPER_PRICING_FILE=/var/lib/jasper/pricing.json

# The speaker's mDNS hostname — what other devices on the LAN type
# into their browser to reach the speaker. Single source of truth:
# JASPER_MANAGEMENT_URL and JASPER_SPOTIFY_SETUP_URL default to
# http://${JASPER_HOSTNAME} when not explicitly set. Bash scripts
# under scripts/ also fall back to this if PI_HOST isn't set.
#
# `install.sh` auto-derives this from the OS hostname on fresh
# installs ($(hostname).local), so if you set "jts2" in Raspberry Pi
# Imager you'll end up with JASPER_HOSTNAME=jts2.local without
# manually editing this line. The default below is the template
# placeholder — install.sh overwrites it for fresh seedings. The
# deploy-to-pi.sh wrapper also passes JASPER_HOSTNAME explicitly
# (highest precedence).
JASPER_HOSTNAME=jts.local

# Spotify Web API — multi-account routing for voice commands. Auth
# uses PKCE (no client secret needed). Paste the Client ID via the
# wizard at http://${JASPER_HOSTNAME}/spotify, or set it here.
SPOTIFY_CLIENT_ID=
# Default redirect URI is the canonical hosted bounce page on
# GitHub Pages (separate public repo `jaspercurry/spotify-oauth-callback`).
# The `?host=` query param tells the page which mDNS hostname to
# redirect back to, so a single page works for any speaker. Override
# to "http://127.0.0.1:8888/callback" if you want the manual paste-back
# mode (zero external dependencies). Leave blank to use the default
# derived from JASPER_HOSTNAME.
SPOTIFY_REDIRECT_URI=
# Where spotipy persists the per-account OAuth refresh tokens. One
# file per household member is created here (filename derives from
# the account label entered via the wizard). Multi-account routing
# in `jasper/spotify_router.py` reads these on every refresh.
# Path must be writable by jasper-voice (root) and survives deploys
# under /var/lib/jasper.
SPOTIFY_CACHE_PATH=/var/lib/jasper/.spotify-cache
# Speaker display name is owned by the wizard at
# http://${JASPER_HOSTNAME}/speaker/ and persisted in
# /var/lib/jasper/speaker_name.env as JASPER_SPEAKER_NAME. It defaults
# to "JTS" and feeds Spotify Connect, AirPlay, Bluetooth, and USB Audio.
# Default location for bare `get_weather` queries is owned by the
# wizard at http://jts.local/weather/ and persisted in
# /var/lib/jasper/weather.env. Operators may still set a geocodable
# fallback string here for headless/CI installs; the wizard migrates
# this out of jasper.env on deploy.
JASPER_DEFAULT_LOCATION=
# Optional coordinate form used by the wizard/runtime. When set,
# bare weather queries skip geocoding and call Open-Meteo forecast
# directly. The display name is what the voice prompt sees.
JASPER_WEATHER_LAT=
JASPER_WEATHER_LON=
JASPER_WEATHER_DISPLAY_NAME=
# Temperature units returned by `get_weather`. The /weather/ wizard
# owns this too. `celsius` or `fahrenheit`; invalid values fall back
# to celsius in the runtime client.
JASPER_WEATHER_UNITS=celsius
# NYC subway, bus, and Citi Bike are configured via the wizard at
# http://jts.local/transit/ — geocode an address, pick from nearby
# stops, save. Wizard owns /var/lib/jasper/transit.env; never put
# transit vars here in jasper.env directly (install.sh migrates them
# out on the next deploy).
#
# Schema there (for reference; you shouldn't edit by hand):
#   JASPER_SUBWAY_STATION_ID         e.g. B12 (9 Av, Sunset Park)
#   JASPER_SUBWAY_DEFAULT_DIRECTION  uptown / downtown / "" (=both)
#   JASPER_MTA_BUSTIME_KEY           free key from bustime.mta.info
#                                    /wiki/Developers/Index (~30 min approval)
#   JASPER_BUS_STOPS                 list "id|label,id|label" — both
#                                    directions at one corner saved
#                                    as two entries.
#   JASPER_CITIBIKE_STATIONS         list "id|label,id|label" — Citi
#                                    Bike stations (NYC + JC + Hoboken).
#                                    Station IDs are GBFS UUIDs from
#                                    gbfs.citibikenyc.com. Keyless.
#   JASPER_CITIBIKE_EBIKE_ONLY       "1" to suppress classic-bike counts
#                                    in voice answers (household only
#                                    rides e-bikes); empty/"0" → report
#                                    both kinds.
