# =========================================================================
# .env.example is the install-time template for /etc/jasper/jasper.env
# (Pi-side config). install.sh copies it to that path during deploy.
# Settings here are NOT loaded by laptop-side scripts in scripts/.
# Any literal here that shadows a jasper.config.Config default must stay
# value-equal to that code default; tests/test_env_example_matches_config_defaults.py
# pins that contract so fresh-install seeds do not silently drift from runtime.
#
# For LAPTOP-side settings (which Pi to target, which SSH user), edit
# `.env.local` at the repo root — it's gitignored and auto-written by
# `bash scripts/onboard.sh <hostname>`. The two vars `scripts/_lib.sh`
# recognizes there are:
#
#   PI_HOST=jts.local    # default. Set per-checkout for multi-Pi
#   PI_USER=pi
#
# Multi-Pi: a second checkout (or worktree) targeting jts2.local has
# its own .env.local with PI_HOST=jts2.local. See QUICKSTART.md.
# =========================================================================

# =========================================================================
# Voice provider — the user MUST pick one via the wizard at
# http://${JASPER_HOSTNAME}/voice on first boot. Intentionally NOT set
# here: this file is the install-time template, and JASPER_VOICE_PROVIDER
# is owned by the wizard, which writes /var/lib/jasper/voice_provider.env.
# Having a default in BOTH files is the kind of stale-vs-runtime mismatch
# that bites later. If you want a non-interactive default (CI, headless
# imaging), write the value to /var/lib/jasper/voice_provider.env
# directly. See docs/HANDOFF-voice-providers.md for cost / model /
# capability tradeoffs and `scripts/switch-voice-provider.sh` for a
# one-liner that flips the provider on the Pi without restarting by hand.
# =========================================================================

# ---- Gemini Live --------------------------------------------------------
GEMINI_API_KEY=
# Live API model. `gemini-3.1-flash-live-preview` is the production
# default. Fallback `gemini-2.5-flash-native-audio-preview-12-2025`
# is positioned by Google as 3.1's predecessor; flip via
# `scripts/switch-gemini-model.sh 2.5` when 3.1 Live is silently
# failing (sessions ending with 0 tokens AND no SDK exception — a
# Google-side condition we've hit). Do NOT use the plain
# `gemini-2.5-flash` — it's not a Live model. See CLAUDE.md
# "Gemini model switching" for symptoms and detection.
JASPER_GEMINI_MODEL=gemini-3.1-flash-live-preview
# Pin the TTS voice so it's consistent across sessions. Choices:
# Aoede, Charon, Fenrir, Kore, Puck, Leda, Orus, Zephyr (per Gemini
# 3.1 Live Preview prebuilt voices).
JASPER_GEMINI_VOICE=Aoede

# ---- OpenAI Realtime ----------------------------------------------------
# gpt-realtime-2 (released 2026-05-07): reasoning-capable, 128K context,
# image input, multi-tool-at-once. Audio billing: $32 / $64 / $0.40 per
# 1M tokens (in / out / cached) → roughly $0.30/minute of conversation,
# ~5x Gemini Live. For lighter workloads use gpt-realtime-mini ($10/$20/
# $0.30). Voices: marin (default), cedar, alloy, ash, ballad, coral,
# echo, sage, shimmer, verse.
OPENAI_API_KEY=
JASPER_OPENAI_MODEL=gpt-realtime-2
JASPER_OPENAI_VOICE=marin
# Reasoning effort for gpt-realtime-2: minimal | low | medium | high |
# xhigh. `low` matches the SDK default and is right for short voice
# queries; `minimal` cuts ~1 second of TTFA at the cost of less coherent
# multi-step answers. Field is silently dropped on non-`-2` models.
JASPER_OPENAI_REASONING_EFFORT=low
# OpenAI Realtime input noise reduction: auto | off | near_field | far_field.
# Auto resolves from the active audio input contract: already-processed
# AEC/chip-AEC streams omit provider denoising; raw direct mics use
# far_field. Explicit values override the profile-derived recommendation.
JASPER_OPENAI_NOISE_REDUCTION=auto
# Time budget (seconds) for the initial OpenAI Realtime WebSocket
# connect at daemon startup. Transient failures (DNS lookup error,
# WS reset, 5xx) retry with exponential backoff + jitter until either
# the connect succeeds or the budget is exhausted. On exhaustion the
# daemon exits non-zero and systemd's `Restart=on-failure` outer loop
# spawns a fresh process with another full budget.
#
# 600 s (10 min) is the production default — long enough to ride out
# any realistic home-network blip at boot (the user typically restores
# WiFi within ~1-2 min of a router reboot or unclean shutdown), short
# enough that a real misconfiguration (revoked API key, persistent DNS
# break) still surfaces on the dashboard / doctor within ~10 min
# instead of hanging forever. Pre-2026-05-23 the cap was 5 retries
# (~15 s wall-time), which silently killed the voice daemon during
# the WiFi-recovery window after an unclean shutdown.
#
# Lower (e.g. 60) only if you want fast-feedback at the cost of
# resilience to network races; 0 means "single attempt, no retries"
# (auth/config errors propagate immediately regardless of budget —
# only transient errors are retried). Authoritative variable name;
# no per-provider equivalents until Gemini/Grok hit the same bug.
JASPER_OPENAI_INITIAL_CONNECT_BUDGET_SEC=600

# ---- xAI Grok Voice Agent -----------------------------------------------
# grok-voice-think-fast-1.0 — OpenAI-Realtime-protocol-compatible per
# xAI's docs (we route through the same adapter with a base-URL swap to
# wss://api.x.ai/v1/realtime). Bills a flat $3/hour per session, NOT
# per-token, so JASPER_DAILY_SPEND_CAP_USD's token-based accounting
# under-counts under Grok — the daemon logs a warning at startup and
# the cap becomes a liveness nudge rather than a real ceiling. Voices:
# eve (default), ara, rex, sal, leo.
XAI_API_KEY=
JASPER_GROK_MODEL=grok-voice-think-fast-1.0
JASPER_GROK_VOICE=eve

# Active wake-word model. Either a bundled openWakeWord name
# (`alexa`, `hey_jarvis`, `hey_mycroft`) or an absolute path to a
# .onnx file under /var/lib/jasper/wake/ (e.g. the community
# `jarvis_v2.onnx` model is what the JTS install ships with as
# `/var/lib/jasper/wake/jarvis_v2.onnx`). Set via the picker at
# http://${JASPER_HOSTNAME}/wake/ or `scripts/switch-wake-word.sh`
# — both write `/var/lib/jasper/wake_model.env`, which overrides
# this template value at runtime. Registry of curated models lives
# in jasper/wake_models.py; add a new row there to surface it in
# the picker. Fallback `hey_jarvis` is the openWakeWord-bundled
# model that is always present (no separate download), so
# dev/test runs without seeded env files still load something.
JASPER_WAKE_MODEL=hey_jarvis
# JASPER_WAKE_THRESHOLD: openWakeWord confidence threshold (0–1).
# 0.30 is the empirically-tuned production value — sensitive enough
# to catch "Hey Jarvis" at high music SPL, low enough to false-fire
# rarely on typical music. Raise to 0.40 if music starts triggering
# wakes; lower to 0.20 if you're missing a lot of attempts.
JASPER_WAKE_THRESHOLD=0.30
# JASPER_WAKE_EVENTS_MAX_AUDIO_BYTES caps per-event WAV storage at
# /var/lib/jasper/wake-events/. Audio rolls oldest-first when full;
# DB rows are kept forever (their `audio_*_path` fields flip to
# `rolled_off` after audio is reaped). 1 GiB default sized for the
# triple-stream architecture: each event saves 3 WAVs (AEC ON +
# AEC OFF + DTLN, ~192 KB each = ~576 KB/event), so 1 GiB ≈ 1740
# events ≈ 5-7 weeks at 30-50 events/day. Bump higher if you need
# longer history; lower if you're tight on the SD card.
JASPER_WAKE_EVENTS_MAX_AUDIO_BYTES=1073741824
# ---- jasper-doctor ------------------------------------------------------
# JASPER_DOCTOR_MAX_CONCURRENCY caps how many independent doctor checks may
# run at once. 8 is the production default: enough to hide subprocess wait
# time, but bounded for a 1 GB Pi so diagnostics do not stampede CPU, memory,
# or process slots. The runtime clamps values to 1..16; lower to 4 when
# debugging under memory pressure, and raise only on larger Pis.
JASPER_DOCTOR_MAX_CONCURRENCY=8
# JASPER_DOCTOR_CHECK_TIMEOUT_SECONDS is the outer per-check row timeout.
# 15 seconds sits above the 5-10 second subprocess/socket timeouts most checks
# already own, so slow probes become visible failure rows without masking
# normal hardware waits. Keep this above the low-level probe timeouts.
JASPER_DOCTOR_CHECK_TIMEOUT_SECONDS=15
# ---- Voice tool catalog (/tools/ wizard) --------------------------------
# JASPER_DISABLED_TOOLS — comma-separated tool NAMES the household has
#   turned OFF in the /tools/ wizard (e.g. spotify_play,gmail_unread_summary).
#   Wizard-owned: lives in /var/lib/jasper/tool_state.env, NOT here — the
#   wizard writes it and jasper-voice reads it to drop those tools from the
#   model's registry. FAIL-SAFE: a missing/malformed file means NOTHING is
#   disabled (every tool on) — JTS fails toward more functionality. A
#   disabled tool is the user's explicit choice, not an error, so no audible
#   cue fires. Left unset/commented here on purpose: the default (no file =
#   all tools on) is right for every install; manage it at http://jts.local/tools.
# JASPER_DISABLED_TOOLS=
# JASPER_MIC_DEVICE selects the mic source for jasper-voice. The
# install-time reconciler owns this value when it is one of the
# standard JTS choices (Array or udp:<AEC port>), so stale AEC
# settings are cleared automatically if the mic disappears. Set a
# custom value here only when intentionally bypassing that policy.
# Two transport flavours:
#
#   PortAudio device (substring match; sounddevice rejects "plughw:"
#   syntax). Examples:
#     Array    → XVF3800 chip's processed conference channel
#                (DEFAULT, also the chip's BF/NS/AGC output).
#                Software AEC bridge is bypassed.
#     UMIK-2   → MiniDSP UMIK-2 (48 kHz stereo native — see CAPTURE_RATE)
#     Inspect: /opt/jasper/.venv/bin/python -c \
#       'import sounddevice as sd; print(sd.query_devices())'
#
#   UDP socket (paired with jasper-aec-bridge over PR 2's UDP
#   transport — the bridge writes 16 kHz mono int16 frames to this
#   host:port). Forms:
#     udp:<port>           shorthand, host = 127.0.0.1
#     udp://<host>:<port>  full URL form
#   Enables software AEC when `JASPER_AEC_MODE=auto` and the
#   configured AEC mic is present with 6-channel firmware. The
#   reconciler sets this automatically; don't hard-code it by hand
#   unless you are debugging the bridge.
#   See AGENTS.md / CLAUDE.md "Acoustic echo cancellation" for full
#   context.
JASPER_MIC_DEVICE=Array
# Push-to-talk microphones that bypass wake detection because the user is
# physically holding a hardware button. Format: source_id=device, comma-
# separated. Leave empty unless an accessory reconciler or an operator has
# activated a hardware profile. The WiiM Remote 2 profile writes
# wiim_remote_2=udp:9892 when that remote is paired.
JASPER_MANUAL_MIC_SOURCES=
# AEC reconciler runtime outputs. `JASPER_AEC_MIC_DEVICE` is the
# concrete PortAudio/ALSA card used by jasper-aec-bridge for the XVF
# capture stream. Fresh install seeds it, but selectable input profiles
# (`auto`, `xvf_chip_aec`, `xvf_software_aec3`, `direct_mic`) treat it
# as reconciler-owned derived state: the detected mic profile rewrites
# it to `Array` for legacy square/circular XVF firmware or `L16K6Ch`
# for ReSpeaker Flex LINEAR-4. Use `JASPER_AUDIO_INPUT_PROFILE=custom`
# for a deliberately hand-pinned AEC mic.
#
# `JASPER_MIC_DEVICE_CANDIDATES` is the direct-mic fallback list the
# reconciler may select when AEC is unavailable. Keep entries as simple
# card/device names for now (comma-separated, or shell-quoted if using
# spaces). Supported XVF card names are prepended dynamically from the
# mic profile so swapping square/circular and linear variants self-heals.
JASPER_AEC_MIC_DEVICE=Array
JASPER_MIC_DEVICE_CANDIDATES=Array,L16K6Ch
# The AEC reconciler derives these read-only XVF runtime facts from
# jasper.mics.xvf3800 via `jasper-xvf-profile`. Do not hand-edit them:
# they are the central mic-geometry/profile answer that downstream
# status surfaces, chip-AEC gating, and corpus metadata consume. Legacy
# square/circular 6-channel firmware resolves to geometry=square and
# beam_plan=xvf_square_fixed_150_210; Flex LINEAR-4 resolves to
# geometry=linear with no production chip beam plan until corpus testing
# validates one.
# JASPER_XVF_VARIANT=
# JASPER_XVF_GEOMETRY=
# JASPER_XVF_CHIP_BEAM_PLAN=
# JASPER_XVF_CHIP_AEC_SUPPORTED=0
# The AEC reconciler derives these read-only chip-AEC DAC gate facts from
# the active output DAC profile plus live outputd clock evidence. Do not
# hand-edit them: /wake/, /state, jasper-doctor, and validation artifacts
# all consume this as the single DAC-side chip-AEC gate. Values:
# approved = auto/production chip-AEC may run; testing = explicit
# xvf_chip_aec_testing is running on an unapproved DAC; needs_calibration =
# software AEC3 remains the safe default. `JASPER_AEC_CHIP_AEC_TESTING_REQUESTED`
# records the operator's explicit testing-profile request.
# `JASPER_AEC_CHIP_AEC_DAC_ID` records which output DAC the gate was resolved
# against, so status readers can ignore stale approvals after hardware changes.
# JASPER_AEC_CHIP_AEC_TESTING_REQUESTED=0
# JASPER_AEC_CHIP_AEC_DAC_ID=unknown
# JASPER_AEC_CHIP_AEC_DAC_STATUS=needs_calibration
# JASPER_AEC_CHIP_AEC_DAC_SOURCE=
# JASPER_AEC_CHIP_AEC_DAC_DETAIL=
# JASPER_AEC_CHIP_AEC_DAC_ACTION=use_software_aec3_or_enable_testing
# JASPER_AEC_MODE is stateful on the Pi at /var/lib/jasper/aec_mode.env
# rather than in this secrets file. Values: auto | disabled. Default
# is auto; set disabled there to force chip-direct mic and keep the
# bridge off.
#
# JASPER_AUDIO_INPUT_PROFILE, JASPER_WAKE_LEG_RAW, JASPER_WAKE_LEG_DTLN,
# JASPER_WAKE_LEG_CHIP_AEC, JASPER_WAKE_LEG_CHIP_AEC_150, and
# JASPER_WAKE_LEG_CHIP_AEC_210 live in the same file (written by /wake/).
# Profile values: auto, xvf_chip_aec, xvf_chip_aec_testing,
# xvf_software_aec3, direct_mic, custom. `auto` uses chip-AEC only when
# the mic and DAC gate are approved; unapproved DAC validation uses the
# explicit xvf_chip_aec_testing profile. The chip-AEC profile opens only the
# primary/session wake detector by default; extra 150°/210° chip-beam wake
# detectors are separate advanced opt-ins.
#
# The wake-leg booleans gate additive wake-detection legs the bridge can
# fan out. Defaults:
#
#   JASPER_WAKE_LEG_RAW=1   - dual-stream baseline (~5 MB / negligible
#                             CPU; recovers wake-rate misses on the
#                             AEC ON leg via OR-fusion).
#   JASPER_WAKE_LEG_DTLN=0  - triple-stream third leg (+~75 MB RAM,
#                             +~25% one core); opt-in via /wake/ for
#                             2 GB Pis where the OR-fusion gain is
#                             worth the resource cost.
#   JASPER_WAKE_LEG_CHIP_AEC_150=0 - optional extra XVF3800 150° chip-AEC
#                                   wake detector (+~30 MB RAM).
#   JASPER_WAKE_LEG_CHIP_AEC_210=0 - optional extra XVF3800 210° chip-AEC
#                                   wake detector (+~30 MB RAM).
#
# The reconciler maps these booleans to JASPER_MIC_DEVICE_RAW,
# JASPER_MIC_DEVICE_DTLN, JASPER_AEC_DTLN_ENABLED,
# JASPER_MIC_DEVICE_CHIP_AEC_150, JASPER_MIC_DEVICE_CHIP_AEC_210, and
# JASPER_AEC_CHIP_AEC_ENABLED in this file
# on every reconcile pass — do NOT set those directly here; on next
# deploy migrate_wake_legs_config moves any hand-set values into
# aec_mode.env and strips them from here.
# JASPER_AEC_UDP_HOST / JASPER_AEC_UDP_PORT control where the bridge
# sends AEC'd mic. jasper-voice listens on whatever
# `JASPER_MIC_DEVICE=udp:<port>` points at. Default 127.0.0.1:9876;
# only change if 9876 collides on your LAN (the socket binds to
# loopback so non-LAN clients can't reach it anyway).
JASPER_AEC_UDP_HOST=127.0.0.1
JASPER_AEC_UDP_PORT=9876
# JASPER_AEC_REF_GAIN_DB pre-amplifies the digital AEC reference
# signal before it enters the engine.
#
# Current production: 0 dB. Tuned 2026-05-16 after the bridge
# switched from raw mic 0 (chip channel 2, no chip processing) to
# the ASR beam (chip channel 1, with chip BF + NS + AGC + HPF).
# The chip's AGC now normalizes the mic to ~-24 dBFS RMS, which
# closes the loop-gain gap that REF_GAIN used to compensate for.
# Any positive REF_GAIN now drives the digital reference into hard
# clipping during music playback (observed 11-44% ref_clip with
# REF_GAIN=25 + chip AGC), which destabilizes AEC3's adaptive filter
# and produces wildly variable cancellation (-0.3 to -20.8 dB across
# consecutive 5-second windows).
#
# At REF_GAIN=0 with chip channel 1, ref and mic naturally arrive
# at ~-22 dBFS each (AEC3's design point: ref ~= mic). Steady-state
# attenuation is -15 to -20 dB on music, ref_clip stays at 0%.
#
# Historical: REF_GAIN=25 was correct for the previous architecture
# (channel 2 raw mic, no chip AGC). Don't restore that value without
# also reverting `MIC_CHANNEL_INDEX` in jasper/mics/xvf3800.py.
# See docs/HANDOFF-aec.md "Production tuning (2026-05-16)" for the
# full story.
JASPER_AEC_REF_GAIN_DB=0
# JASPER_AEC_NS_ENABLED / JASPER_AEC_NS_LEVEL toggle + tune the
# post-AEC noise-suppression stage. NS aggressiveness directly
# affects wake-word detection: more NS = more HF speech feature
# stripping = more silent misses. 2026-05-20 sweep: ns=low caught
# 5/20 Jarvis vs ns=moderate 4/20 vs ns=high 3/20 vs ns=very_high
# 2/20. Default is 'low' (the best non-disabled option on Trixie's
# libwebrtc-audio-processing-1 v1.3-3, which lacks kVeryLow).
# Disable entirely with JASPER_AEC_NS_ENABLED=0 for max HF
# preservation at the cost of residual music passing through.
JASPER_AEC_NS_ENABLED=1
JASPER_AEC_NS_LEVEL=low
# JASPER_AEC_AGC1_ENABLED enables WebRTC AGC1 in kAdaptiveDigital
# mode for post-AEC level normalization. Empirically (2026-05-20
# sweep) this produces a uniform ~RMS 1213 output across utterances,
# regardless of instantaneous music level — fixing the "some
# Jarvises overblown, some too quiet" symptom that pure static
# JASPER_AEC_MIC_GAIN_DB produces. Wake-rate is unchanged from
# static +12 dB gain; the win is output consistency, not detection
# rate. On by default since 2026-05-20.
#
# The TARGET_DBFS and MAX_GAIN_DB knobs map to WebRTC's
# `target_level_dbfs` (0–31, where the value is positive dBFS-below-
# zero; so 9 → −9 dBFS target) and `compression_gain_db` (0–90,
# the soft-knee compressor gain parameter — NOT a "max headroom").
# A 2026-05-21 audit confirmed these are valid WebRTC fields, but
# our sweep showed they have minimal observable effect on Trixie's
# libwebrtc-audio-processing-1 v1.3-3 (the built-in limiter
# dominates the output level). Keep at defaults unless future
# measurement shows otherwise. There is NO attack-time / release-
# time parameter in WebRTC's public AGC1 surface — any earlier
# claim of "150 ms attack" was incorrect and has been removed from
# the docs.
#
# AGC2 (below) is the no-op alternative — adaptive_digital sub-
# config defaults off in our binding, so AGC2=1 does essentially
# nothing for level control. Use AGC1, not AGC2.
JASPER_AEC_AGC1_ENABLED=1
JASPER_AEC_AGC1_TARGET_DBFS=9
JASPER_AEC_AGC1_MAX_GAIN_DB=18
# JASPER_AEC_AGC2 — see comment above; left for compat but no-op.
JASPER_AEC_AGC2=0
# JASPER_AEC_BINDING selects which jasper_aec3 pybind11 binding the
# bridge loads: `auto` (code default — prefer v2/BEST_A, fall back
# to v1 when the v2 module isn't built), `v2` to force BEST_A, `v1`
# to force the legacy AEC3 v1.3 tuning. This is a rollback knob, not
# a tunable — set JASPER_AEC_BINDING=v1 only to revert the BEST_A
# production tuning while diagnosing a wake-rate regression (see
# AGENTS.md "Rip-out is single env-var changes"). Deliberately not
# assigned here: `auto` is right for every install, and freezing a
# literal would pin old behaviour across future binding upgrades.
# JASPER_AEC_MIC_GAIN_DB applies a static gain to the AEC engine's
# output before it reaches openWakeWord (via UDP). +6 dB is
# the tested production value — restores level into openWakeWord's
# training distribution without warping speech envelopes (the HA
# Voice PE pattern, `gain_factor: 4` ≈ +12 dB; we use a more modest
# +6 since our XVF mic preamp delivers higher digital level than
# Voice PE's). Soft-clipped via tanh on the way out, so high gain
# doesn't hard-clip; any saturation is reported as `out_clip=X%` in
# the bridge's RMS log. Tune downward (3 dB, 0 dB) if you see
# `out_clip` >1% sustained or false wakes from TTS bleed; tune
# upward (9 dB, 12 dB) if wake-word still misses at high music SPL.
JASPER_AEC_MIC_GAIN_DB=6
# JASPER_AEC_STALL_RESTART_SEC is the consecutive-empty-second
# threshold after which the bridge bails non-zero so systemd
# `Restart=on-failure` can spin up a fresh process. PortAudio's
# `InputStream` is one-shot — once the underlying ALSA capture PCM
# dies (typically a USB underrun on the XVF chip's UAC2 endpoint),
# the callback simply stops being invoked, and there's no in-process
# recovery path. Hit in production 2026-05-11 — bridge sat silently
# stalled for 10 minutes, wake-word was deaf, no audible cue.
# 0 = disabled (legacy "log forever" behaviour). Default 5 s →
# typical recovery is ~5 s detect + 2 s `RestartSec` + 1 s bridge
# warm-up ≈ 8 s of mic-deaf, vs. forever without it.
JASPER_AEC_STALL_RESTART_SEC=5
# JASPER_AEC_STALL_DRIP_MAX_WINDOWS hardens that same recovery against a
# *slow-drip* stall the consecutive-empty counter structurally misses: it
# resets on a single frame, so an intermittent trickle (a frame every few
# seconds) keeps the mic effectively dead (<1 usable frame/s vs ~12.5/s
# healthy) without ever reaching the continuous threshold. Observed
# 2026-05-31 — the bridge ran ~13 h deaf, NRestarts=0, until a manual
# restart. This watchdog counts the mic frame *rate* over rolling ~10 s
# windows and bails non-zero (→ systemd restart) after this many CONSECUTIVE
# low-rate windows. Conservative: a brief blip clears on the next good
# window; a healthy or merely-degraded mic never trips. Default 3 (~30 s
# sustained). 0 = disabled.
JASPER_AEC_STALL_DRIP_MAX_WINDOWS=3
# Capture rate + channel count for the PortAudio path. (UDP transport
# from the bridge is always 16 kHz mono — these knobs don't apply
# under `JASPER_MIC_DEVICE=udp:...`.) XVF chip raw is 16k 6ch (use
# Array + ch=6 if bypassing the bridge). UMIK-2 et al.: 48000/2.
JASPER_MIC_CAPTURE_RATE=16000
JASPER_MIC_CAPTURE_CHANNELS=1
# TTS IPC default: voice/cue TTS sends 48 kHz stereo PCM plus gain
# metadata to jasper-fanin, before CamillaDSP crossover/protection.
# The transport name remains `outputd` for protocol compatibility.
# The old sounddevice/PortAudio
# playout class remains in-tree for tests and pre-outputd archaeology, but
# JASPER_TTS_TRANSPORT=sounddevice is rejected by current runtime config
# because it no longer has dynamic assistant-loudness matching.
JASPER_TTS_TRANSPORT=outputd
JASPER_TTS_OUTPUTD_SOCKET=/run/jasper-fanin/tts.sock
# Legacy sounddevice-only target, ignored by the supported outputd runtime.
JASPER_TTS_DEVICE=jasper_out
# outputd's IPC contract and the legacy pcm.jasper_out path both run
# at 48 kHz. TtsPlayout polyphase-upsamples provider/cue PCM from
# 24 kHz → 48 kHz before write (factor 2, exact).
JASPER_TTS_OUTPUT_RATE=48000
# Provider/model/voice loudness profile store. Python can seed/learn the
# source profile; the active TTS IPC owner consumes it when choosing
# final assistant gain.
JASPER_ASSISTANT_LOUDNESS_PROFILE_PATH=/var/lib/jasper/assistant_loudness_profiles.json
# Off by default so daemon restarts never spend provider TTS calls
# implicitly. The /voice/ wizard's "Save and Test" button runs one
# deliberate bounded seed; operators can opt into one startup seed with:
# JASPER_ASSISTANT_LOUDNESS_AUTO_SEED=1
# Assistant loudness policy. These defaults are consumed by fan-in for
# the packaged pre-DSP TTS path and by outputd only in rollback/lab IPC
# mode. Retune in /var/lib/jasper/fanin.env, not here.
JASPER_OUTPUTD_ASSISTANT_OFFSET_LU=1.5
JASPER_OUTPUTD_ASSISTANT_MAX_PEAK_DBFS=-3.0
JASPER_OUTPUTD_ASSISTANT_FALLBACK_SOURCE_LUFS=-24.0
JASPER_OUTPUTD_ASSISTANT_FALLBACK_SOURCE_PEAK_DBFS=-6.0
JASPER_OUTPUTD_ASSISTANT_DEFAULT_SILENCE_TARGET_LUFS=-41.0
JASPER_OUTPUTD_CONTENT_SILENCE_LUFS=-60.0
# Audio lab tone playback is disabled by default. Leave these unset on
# production speakers; product commissioning uses the protected CamillaDSP
# lane instead. For bench experiments only, set the backend to `aplay` and
# point the PCM at a dedicated non-daemon test device. Never use jasper_out,
# outputd_* lanes, or another normal listening path here.
# JASPER_AUDIO_LAB_TONE_BACKEND=aplay
# JASPER_AUDIO_LAB_TEST_PCM=hw:LabDevice
# CamillaDSP websocket — jasper-voice and jasper-control reach the
# DSP for ducking (`main_volume`), gain reads, and lightweight
# content-activity telemetry. CamillaDSP listens on
# loopback only (set in `deploy/camilladsp/v1.yml`); no auth, but
# also not reachable off-host. Change the port if 1234 collides on
# this host.
JASPER_CAMILLA_HOST=127.0.0.1
JASPER_CAMILLA_PORT=1234
# camilla#2 — the SECOND CamillaDSP instance, the per-driver
# endpoint-crossover on an ACTIVE LEADER (a box that is both a multi-room
# leader and an active/crossover speaker; see docs/HANDOFF-distributed-
# active.md "Stage B"). It coexists with camilla#1 (above, :1234) and is
# DORMANT until a later reconciler arms jasper-camilla-crossover.service —
# on an ordinary speaker this instance never runs. Host is loopback (the
# instance listens on 127.0.0.1 only, no auth). Port is 1235 so it cannot
# collide with camilla#1's 1234; change it only if 1235 collides on this
# host. The statefile is camilla#2's OWN persisted-config path, separate
# from camilla#1's outputd-statefile.yml so the two never overwrite each
# other; install.sh seeds it to a tweeter-safe driver-domain baseline.
JASPER_CAMILLA2_HOST=127.0.0.1
JASPER_CAMILLA2_PORT=1235
JASPER_CAMILLA2_STATEFILE=/var/lib/camilladsp/crossover-statefile.yml
# CamillaDSP buffering latency knobs (audio-latency foundation G7). These set
# the `chunksize` and `target_level` baked into generated loopback / correction /
# active-speaker configs; the ring-coupled graph has its own fixed validated
# geometry (chunk 128 / target 128 / queue 1) because it is coupled to the 2-slot
# SHM ring. The JTS config emitters read these at generation time
# (jasper.camilla_config_contract.resolve_camilla_*). Smaller values cut
# CamillaDSP's contribution to end-to-end latency but raise xrun risk under CPU
# contention; the shipped loopback defaults (chunksize 1024 ≈ 21 ms, target 2048
# ≈ 43 ms at 48 kHz) are the validated safe point on a 1 GB Pi 5. Leave both
# UNSET (commented) unless you are deliberately tuning latency and have a
# zero-xrun soak to back the new value — a too-small chunksize produces audible
# dropouts. A malformed/zero/negative value silently falls back to the default
# rather than emit a config that won't load. Both must be positive integers
# (powers of two are conventional). Apply by regenerating the active config.
# JASPER_CAMILLA_CHUNKSIZE=1024
# JASPER_CAMILLA_TARGET_LEVEL=2048
# Audio route profile. Default `corrected_48k` is the safe production path:
# all sources fan into CamillaDSP and outputd remains the sole physical DAC /
# final-reference owner, with no low-latency claim. `usb_low_latency_48k` is an
# explicit production USB-ingress profile: fixed 48 kHz, Rust usbsink bridge,
# fan-in's USB input resampler, CamillaDSP protection/correction in path, and a
# doctor-gated route-latency artifact (p95 <= 40 ms; promotion p99 <= 60 ms).
# `jasper-route-latency-artifact` writes that artifact from measured
# click/capture latency samples; it does not generate or measure the samples.
# `bitperfect_passthrough_declared` is a declared future contract only; it is
# inactive because bit-perfect bypass and final AEC-reference truth are in
# tension. Apply changes by re-running jasper-audio-hardware-reconcile.
JASPER_AUDIO_ROUTE_PROFILE=corrected_48k
# Music attenuation while the model is actively listening / speaking.
# -25 dB drops music from "full" to "background voice over" — clear
# enough to hear the assistant without losing the song. Anything
# tighter than ~-18 dB makes wake utterances harder to pick out;
# anything beyond ~-30 dB is effectively a music pause and feels
# abrupt when the duck releases. Because TTS now enters before CamillaDSP,
# attenuation is applied in fan-in so the assistant itself is not ducked.
JASPER_DUCK_DB=-25
JASPER_DUCK_TRANSPORT=fanin
# Pre-response idle watchdog. If the voice daemon has sent
# activity_end (or commit + response.create for OpenAI) and then
# receives zero audio chunks AND no other server activity for this
# many seconds, the turn is closed, music un-ducks, and the wake
# loop returns to listening. Recovery timer for "API is silent and
# we got nothing back." 20 s sits ~2.6× above the worst observed
# OpenAI Realtime first-chunk latency (~7.7 s in 2026-05-21
# production logs) while keeping recovery from a genuine hang under
# half a minute. Lower (e.g. 10) for faster un-duck at the cost of
# clipping risk on slow days. Tool dispatches and intermediate
# server events DO reset the anchor (see
# docs/HANDOFF-voice-providers.md "Idle anchor + tool rounds"), so
# this knob is purely about pure-silence recovery, not "model is
# thinking too long." Separate from NO_SPEECH_ABORT_SEC=5 (the
# "wake word but no speech" case, hardcoded in voice_daemon.py).
JASPER_IDLE_TIMEOUT_SEC=20
# Response-stall watchdog. Once the provider has produced at least
# one audio chunk, normal turn close should come from the provider's
# turn_complete signal after playback drains. This larger last-resort
# cap recovers if a provider wedges mid-response with the socket still
# open: after this many seconds with no new output chunk and no
# turn_complete, jasper-voice ends the turn through normal teardown so
# music un-ducks and the wake loop returns to listening. 120 s is
# intentionally generous to avoid clipping slow but valid responses;
# lower only if you prefer faster recovery from rare provider stalls.
JASPER_RESPONSE_STALL_TIMEOUT_SEC=120
# jasper-control HTTP surface for the rotary dial and other LAN
# clients (volume / transport / session). No auth — home network
# only. Change the port if 8780 collides with something on your LAN.
#
# JASPER_CONTROL_HOST is the *server bind* address only, and its code
# default is already 0.0.0.0 (LAN-reachable so the dial can connect),
# so it is deliberately NOT seeded here: a seeded copy would shadow
# future code defaults forever (the frozen first-install-seed bug
# class), and it poisoned on-Pi clients that misread it as a connect
# host — `Host: 0.0.0.0` is rejected by the management-host guard
# (the 2026-06-11 /system/ dashboard 403). jasper.control.client now
# maps an unspecified bind value to 127.0.0.1, and install.sh's
# migrate_control_host_bind_seed prunes the stale seeded line from
# existing Pis. Uncomment only to bind the control server elsewhere
# (e.g. 127.0.0.1 to hide it from the LAN — breaks the dial).
# JASPER_CONTROL_HOST=0.0.0.0
JASPER_CONTROL_PORT=8780
# Management request guardrails. Host/Origin checks allow localhost,
# loopback/private IPs, JASPER_HOSTNAME, and this machine's hostname.
# Add comma-separated extra local aliases here if a custom DNS name or
# reverse proxy should reach jasper-control directly. POST bodies are
# tiny JSON payloads; keep the cap low unless a future accessory needs
# more room.
JASPER_MANAGEMENT_ALLOWED_HOSTS=
JASPER_CONTROL_MAX_POST_BYTES=4096
# Mandatory invisible control-token gate (SECURITY.md). jasper-control has no
# hard auth, so any LAN device could otherwise curl the high-impact mutations
# (power/reboot/restart, mic-mute, grouping). jasper-control auto-generates a
# shared X-JTS-Token at startup and the management UI delivers it behind the
# read guard, so those routes are protected from drive-by/CSRF/casual curl
# without household setup. JASPER_CONTROL_TOKEN_FILE overrides where that file
# lives; the default /var/lib/jasper/control_token (mode 0640 group jasper) is
# right for every install — set this ONLY for tests/headless imaging.
# The token value itself is never put in env: it lives in the file the daemon/CLI
# writes.
# JASPER_CONTROL_TOKEN_FILE=/var/lib/jasper/control_token
# Household credential for DEVICE-TO-DEVICE control — the cross-speaker bond
# fan-out (docs/HANDOFF-control-plane-auth.md). Distinct from the per-device
# control token above: ONE secret per household, minted when a human bonds
# speakers (the /rooms/ page), distributed to each member, and presented as
# X-JTS-Household on the cross-device /grouping/set so a paired household — and
# only it — can re-route grouping. NOT seeded at install (a lone speaker never
# needs it; absence = "not yet paired"). JASPER_HOUSEHOLD_SECRET_FILE overrides
# where it lives; the default /var/lib/jasper/household_secret (mode 0640, group
# jasper — both non-root jasper-web and jasper-control read it) is right for
# every install — set this ONLY for tests/headless imaging. The
# secret itself is never put in env: it lives in the file the bond fan-out writes.
# JASPER_HOUSEHOLD_SECRET_FILE=/var/lib/jasper/household_secret
# UDP log listener for the dial — diagnostic stream from the dial's
# firmware ends up in `journalctl -u jasper-control` so we can debug
# without USB-tethering. Lossy-but-fast UDP. Avoid 514 to dodge
# rsyslog conflict.
JASPER_DIAL_LOG_HOST=0.0.0.0
JASPER_DIAL_LOG_PORT=5514
# Unix-domain socket where voice_daemon listens for external session
# triggers (dial long-press via jasper-control). Lives in /run, which
# systemd auto-cleans at service stop. Both jasper-voice and
# jasper-control run as root so default 0o660 perms are fine.
JASPER_VOICE_CONTROL_SOCKET=/run/jasper/voice.sock
# Idle context reset is OFF by default — the persistent live session
# keeps conversational context indefinitely. OpenAI Realtime auto-
# truncates past 128K and caps sessions at 60 min, so unbounded growth
# is impossible. Set a positive value (e.g. 21600 = 6 h) only if you
# observe stale-context glitches in practice; each reset busts the
# OpenAI prompt cache (~$0.008/reset) and blocks the wake event for
# 1-6 s during reopen. Per-provider: tune separately or leave each at
# 0. Legacy JASPER_LIVE_CONTEXT_RESET_SEC, if set, supplies a global
# default for any provider whose specific var is unset.
JASPER_OPENAI_CONTEXT_RESET_SEC=0
JASPER_GEMINI_CONTEXT_RESET_SEC=0
JASPER_GROK_CONTEXT_RESET_SEC=0
# Silero speech-probability threshold for in-session barge-in. While the
# assistant is speaking, the daemon scores the AEC-cleaned mic leg with
# local Silero VAD; a sustained run of frames each at or above this value
# (~200 ms, the wake-tail arming window) flushes the assistant's local TTS
# so the user can talk over it. 0.5 = Silero default, tuned strict to
# avoid TTS-bleed false-positives; raise toward 0.7 if music/TTS bleed
# trips it, lower if real interrupts are missed.
#
# Barge-in is OFF by default and enabled PER PROVIDER, not here. To turn
# it on, set JASPER_BARGE_IN_<PROVIDER>=1 (e.g. JASPER_BARGE_IN_GEMINI=1)
# in the wizard-owned /var/lib/jasper/voice_provider.env — the same file
# JASPER_VOICE_PROVIDER lives in. (The /voice wizard will surface this as
# a toggle in a later increment; until then set the key directly.) This
# threshold is provider-agnostic (one value, applies to whichever provider
# has barge-in on); it only takes effect once a provider has barge-in
# enabled, and is ignored entirely on a direct_mic profile (no AEC
# reference to cancel the speaker's own output, so detection would
# self-trip). See docs/HANDOFF-barge-in.md.
JASPER_VAD_BARGE_IN_THRESHOLD=0.5

# Server-side VAD experiment: when enabled and music is playing, switch
# providers that support it (OpenAI/Grok today) to server_vad for
# end-of-utterance detection instead of local Silero. Production defaults
# to local Silero because OpenAI server VAD cut off real utterances in
# the May 2026 A/B matrix (see docs/HANDOFF-vad-experiments.md).
# create_response and interrupt_response are always false so the daemon
# retains control of response timing.
JASPER_SERVER_VAD_ENABLED=0
# Start at 0.5 (OpenAI default) if you are deliberately testing server
# VAD. Lower if short commands during music are still missed; raise if
# music lyrics trigger false commits.
JASPER_SERVER_VAD_THRESHOLD=0.5
JASPER_SERVER_VAD_SILENCE_MS=350
JASPER_SERVER_VAD_PREFIX_MS=300

# Daily voice-API spend ceiling (USD). When the rolling 24h estimate
# crosses this value, jasper-voice refuses new turns and the
# `spend_cap_reached` cue plays on wake. Cost is estimated per
# `jasper/usage.py`: token-billed providers (Gemini/OpenAI) from token
# counts, time-billed providers (Grok, $3/hour) from connection uptime.
# $1/day is the household-safe default at Gemini Live rates
# (~$0.02/min → ~50 min of conversation/day); raise for heavier use.
# Setting to 0 disables the cap entirely.
JASPER_DAILY_SPEND_CAP_USD=1.00
# Safety multiplier the spend cap applies to the rolling 24h spend
# before comparing it to the ceiling above. Keeps the circuit breaker
# conservative (headroom for estimation error and provider-side
# rounding) WITHOUT inflating the cost shown on the /voice/ spend card,
# which reflects best-estimate true rates. 1.0 = no padding; the 1.25
# default trips the cap when true spend reaches ~80% of the ceiling.
# Must be >= 1.0 — a safety multiplier never weakens the cap. To turn
# the cap off, set JASPER_DAILY_SPEND_CAP_USD=0 (not this knob to 0).
JASPER_DAILY_SPEND_CAP_SAFETY_MULTIPLIER=1.25
# SQLite file where session token usage is persisted (one row per
# session, plus connection-uptime intervals for time-billed providers).
# Read by the spend cap and the `/voice/` spend-cap status card. Path
# must be writable by jasper-voice (root) and is created on first run.
# Lives under /var/lib/jasper so it survives deploys.
JASPER_USAGE_DB=/var/lib/jasper/usage.db

# Conversation-history capture gate. Default-off: no perceived-command
# or assistant transcript text is stored unless the household opts in.
# Captured text stays local in the SQLite database below, is skipped
# while mic mute is active, and can be reviewed or cleared at /chat/.
JASPER_CONVERSATION_CAPTURE=0
# SQLite file where opt-in conversation-history turns are persisted.
# Lives under /var/lib/jasper so it survives deploys.
JASPER_CONVERSATION_HISTORY_DB=/var/lib/jasper/conversation_history.db
# Maximum age for locally saved conversation-history turns. The /chat/
# toggle is household opt-in, but once enabled the speaker should still
# bound long-term transcript growth by default. 30 days keeps recent
# troubleshooting context without turning a living-room appliance into an
# indefinite transcript archive. The 30-day default is a CODE default
# (conversation_history.DEFAULT_RETENTION_DAYS), so leaving this unset
# keeps retention bounded — including on speakers upgraded from a build
# that predated this var. Set blank or 0 to disable age pruning; set a
# positive integer to override the default.
#JASPER_CONVERSATION_HISTORY_RETENTION_DAYS=30
# Maximum number of locally saved conversation-history turns. This is a
# second retention guard alongside age pruning for busy households and
# research read-outs; 500 rows is small for SQLite but enough to inspect
# recent behavior. Also a CODE default
# (conversation_history.DEFAULT_RETENTION_MAX_ROWS), so leaving this unset
# stays bounded. Set blank or 0 to disable row-count pruning; set a
# positive integer to override the default.
#JASPER_CONVERSATION_HISTORY_MAX_ROWS=500

# SQLite file where async research jobs are persisted so finished-but-
# unannounced reports survive a jasper-voice restart and are re-announced.
# Lives under /var/lib/jasper so the systemd StateDirectory covers it.
JASPER_RESEARCH_DB=/var/lib/jasper/research_jobs.db
# Per-job wall-clock ceiling for async research work. 300 seconds gives a
# text provider room for background-mode completion while bounding the
# "I'll tell you later" promise; timed-out jobs are marked failed (and the
# server-side background job is best-effort cancelled) and surfaced through
# the scheduler's on_done hook.
JASPER_RESEARCH_MAX_RUNTIME_SEC=300
# Maximum number of simultaneous research jobs. The default of 2 keeps
# CPU/network/cost exposure bounded on the 1 GB Pi; when both slots are
# busy, the voice tool declines immediately with a speakable "try again in
# a moment" response instead of queueing silently.
JASPER_RESEARCH_CONCURRENCY=2
# Hard character cap for stored/spoken research answers. The text model
# is prompted to keep reports under 30 seconds; this 600-character
# backstop keeps a provider drift or prompt miss from turning a proactive
# announcement into a long monologue.
JASPER_RESEARCH_MAX_RESULT_CHARS=600
# How many terminal (done/failed) research jobs to retain in the SQLite
# store and the in-memory map. Bounds growth on an always-on speaker
# (RUNNING jobs are never pruned). Raise on bigger-RAM hardware if you want
# a longer local history; 0 keeps none past announcement.
JASPER_RESEARCH_RETENTION=200
# Research text model. Defaults (in code) to gpt-5.4 — the full flagship,
# not the mini. Any override here MUST have a matching row in
# jasper/data/model_pricing.json (or a /var/lib/jasper/pricing.json
# override) or research cost records as $0 and the daily spend cap can't
# see it (jasper-voice logs event=pricing.unpriced at startup if so).
# JASPER_RESEARCH_OPENAI_MODEL=gpt-5.4

# P6 tuning assistant (the /correction/ "explain my room" + confirm-gated
# proposer). It is OpenAI-only and REUSES the OpenAI voice key from the
# jasper-secrets compartment (/var/lib/jasper-secrets/voice_keys.env,
# written by the /voice wizard) — there is no separate key to set here.
# When the household is on Gemini/Grok voice and no OpenAI key exists, the
# tuning surface is hidden with a nudge, never broken. This var only
# overrides the text MODEL id; it defaults (in code) to the same current
# GPT-class flagship the research provider uses (gpt-5.4). A model rename
# is a value change here, not a code edit. Leave unset for the default.
# The request pins reasoning effort low and budgets output tokens for a
# reasoning-capable GPT-5-class model; an incompatible (non-reasoning)
# model id fails at call time with an honest error in the panel.
# JASPER_TUNING_LLM_MODEL=gpt-5.4
# Per-tap HTTP timeout (seconds) for a tuning interpret/propose call. A
# frontier text model answering the compact packet is a few seconds; the
# 90 s default is a generous ceiling that still bounds a stalled provider
# connection on the Pi web process. No paid call ever happens without an
# explicit user tap (the calls are per-tap, never polled).
# JASPER_TUNING_LLM_TIMEOUT_SEC=90

# Optional pricing override file. Default voice/research model rates are
# built into jasper/data/model_pricing.json (correct as of 2026-06-20);
# when those drift, drop a JSON file here to overlay them without a code
# change — no need to edit/redeploy. Keys are exact model IDs; inner keys
# are the Pricing fields, e.g.:
#   {"models": {"gemini-3.1-flash-live-preview": {
#      "audio_input_per_million_usd": 3.0,
#      "audio_output_per_million_usd": 12.0},
#    "gpt-5.4-mini": {"text_input_per_million_usd": 0.75}}}
# Missing or malformed file falls back to the built-in rates (fail-soft,
# logged). Unset uses the default path below.
JASPER_PRICING_FILE=/var/lib/jasper/pricing.json

# The speaker's mDNS hostname — what other devices on the LAN type
# into their browser to reach the speaker. Single source of truth:
# JASPER_MANAGEMENT_URL and JASPER_SPOTIFY_SETUP_URL default to
# http://${JASPER_HOSTNAME} when not explicitly set. Bash scripts
# under scripts/ also fall back to this if PI_HOST isn't set.
#
# `install.sh` auto-derives this from the OS hostname on fresh
# installs ($(hostname).local), so if you set "jts2" in Raspberry Pi
# Imager you'll end up with JASPER_HOSTNAME=jts2.local without
# manually editing this line. The default below is the template
# placeholder — install.sh overwrites it for fresh seedings. The
# deploy-to-pi.sh wrapper also passes JASPER_HOSTNAME explicitly
# (highest precedence).
JASPER_HOSTNAME=jts.local

# Spotify Web API — multi-account routing for voice commands. Auth
# uses PKCE (no client secret needed). Paste the Client ID via the
# wizard at http://${JASPER_HOSTNAME}/spotify; the wizard writes
# /var/lib/jasper-intsecrets/spotify_credentials.env, which is sourced
# after this file by the runtime services.
# Default redirect URI is the canonical hosted bounce page on
# GitHub Pages (separate public repo `jaspercurry/spotify-oauth-callback`).
# The `?host=` query param tells the page which mDNS hostname to
# redirect back to, so a single page works for any speaker. Override
# to "http://127.0.0.1:8888/callback" if you want the manual paste-back
# mode (zero external dependencies). Leave unset to use the default
# derived from JASPER_HOSTNAME. Do not leave an empty assignment here:
# systemd treats that as a real override and suppresses the default.
# SPOTIFY_REDIRECT_URI=
# Legacy single-account spotipy cache path, kept only so existing
# pre-multi-account tokens can migrate into the registry. New per-account
# OAuth refresh tokens live under /var/lib/jasper-intsecrets/spotify/caches,
# where voice/control/mux/web can refresh them and jasper-input cannot read
# them. Leave this default unless you are migrating a custom legacy cache.
SPOTIFY_CACHE_PATH=/var/lib/jasper-intsecrets/.spotify-cache
# Speaker display name is owned by the wizard at
# http://${JASPER_HOSTNAME}/speaker/ and persisted in
# /var/lib/jasper/speaker_name.env as JASPER_SPEAKER_NAME. It defaults
# to "JTS" and feeds Spotify Connect, AirPlay, Bluetooth, and USB Audio.
# Default location for bare `get_weather` queries is owned by the
# wizard at http://jts.local/weather/ and persisted in
# /var/lib/jasper/weather.env. Operators may still set a geocodable
# fallback string here for headless/CI installs; the wizard migrates
# this out of jasper.env on deploy.
JASPER_DEFAULT_LOCATION=
# Optional coordinate form used by the wizard/runtime. When set,
# bare weather queries skip geocoding and call Open-Meteo forecast
# directly. The display name is what the voice prompt sees.
JASPER_WEATHER_LAT=
JASPER_WEATHER_LON=
JASPER_WEATHER_DISPLAY_NAME=
# Temperature units returned by `get_weather`. The /weather/ wizard
# owns this too. `celsius` or `fahrenheit`; invalid values fall back
# to celsius in the runtime client.
JASPER_WEATHER_UNITS=celsius
# NYC subway, bus, and Citi Bike are configured via the wizard at
# http://jts.local/transit/ — geocode an address, pick from nearby
# stops, save. Wizard owns /var/lib/jasper/transit.env; never put
# transit vars here in jasper.env directly (install.sh migrates them
# out on the next deploy).
#
# Schema there (for reference; you shouldn't edit by hand):
#   JASPER_SUBWAY_STATION_ID         e.g. B12 (9 Av, Sunset Park)
#   JASPER_SUBWAY_DEFAULT_DIRECTION  uptown / downtown / "" (=both)
#   JASPER_MTA_BUSTIME_KEY           free key from bustime.mta.info
#                                    /wiki/Developers/Index (~30 min approval)
#   JASPER_BUS_STOPS                 list "id|label,id|label" — both
#                                    directions at one corner saved
#                                    as two entries.
#   JASPER_CITIBIKE_STATIONS         list "id|label,id|label" — Citi
#                                    Bike stations (NYC + JC + Hoboken).
#                                    Station IDs are GBFS UUIDs from
#                                    gbfs.citibikenyc.com. Keyless.
#   JASPER_CITIBIKE_EBIKE_ONLY       "1" to suppress classic-bike counts
#                                    in voice answers (household only
#                                    rides e-bikes); empty/"0" → report
#                                    both kinds.
#
# Google Routes destination ETA/directions are configured on the same
# /transit/ page because they use the saved speaker location as their
# origin. The billable Maps API key's canonical runtime file is
# /var/lib/jasper-secrets/google_routes.env as GOOGLE_ROUTES_API_KEY.
# This empty placeholder documents the name; non-empty values seeded
# here are migrated into the secrets file on deploy.
GOOGLE_ROUTES_API_KEY=
# JASPER_TRAVEL_DEFAULT_MODE is the household default for "how long
# will it take to get to..." questions when the user does not name a
# mode. Valid values: transit, drive, walk, bicycle. The /transit/
# wizard owns the runtime value in /var/lib/jasper/transit.env, and
# voice instructions like "drive to" or "walk to" override it per call.
JASPER_TRAVEL_DEFAULT_MODE=transit

# ---- Advanced escape hatches (none assigned — code defaults are right
#      for every install; set one here only while diagnosing the specific
#      behaviour it gates, and remove it after) -----------------------------
# JASPER_MUX_SPOTIFY_PREEMPT_RESTART=disabled reverts mux's Spotify
#   preemption to "Web API pause only, mix-on-failure" — use if the
#   librespot-restart fallback ever causes more disruption than the
#   brief audio mix it prevents.
# JASPER_AIRPLAY_METADATA_GATE=disabled reverts airplay_playing() to
#   trusting MPRIS PlaybackStatus alone, without metadata
#   corroboration.
# JASPER_USBSINK_PREEMPT=disabled turns off mux's preempt-via-POST to
#   the USB sink daemon; USB then mixes briefly like Bluetooth when
#   another source starts. Restart jasper-control after editing.
# All three take the exact literal `disabled` (case-insensitive);
# other values log a warning and stay enabled.

# ---- USB management network (composite gadget) ---------------------------
# JASPER_USB_NETWORK is the kill switch for the always-on USB management
# network: a laptop plugged into the speaker's USB-C port (8086 splitter
# data leg, or A-to-C cable) gets an NCM network link to the Pi at
# 10.12.194.1/24 on usb0, so http://<JASPER_HOSTNAME>/ (mDNS) or
# http://10.12.194.1/ (fallback) works even with no Wi-Fi. Unlike USB
# AUDIO input (wizard-toggled, off by default — see below), the network
# function is on by default after install; this is the only opt-out.
# JASPER_USB_NETWORK=disabled — the exact literal `disabled`
#   (case-insensitive) drops the ncm.usb0 function from the composite
#   gadget; the wizard-toggled uac2.usb0 audio function is unaffected
#   (it can still compose alone). Any other value logs a warning and
#   stays enabled, mirroring JASPER_SHAIRPORT_SUPERVISOR /
#   JASPER_SYSTEM_SUPERVISOR. Read directly by the bash gadget scripts
#   (deploy/usbsink/jasper-usbgadget-{up,wanted}) — not a Python
#   Config field; there is nothing on a Python hot path that needs it.
#   See docs/HANDOFF-usb-gadget.md for the full design and the
#   no-IP-forwarding / no-NAT decision this kill switch does not affect
#   (the DHCP server never advertises a route regardless of this flag).

# ---- USB Audio Input (jasper-usbsink) ------------------------------------
# No env is required — defaults work; the on/off switch lives at
# http://jts.local/sources/. Overrides for nonstandard setups (see
# docs/HANDOFF-usbsink.md, and note the two-names ALSA gotcha):
# JASPER_USBSINK_CAPTURE_DEVICE (production default `hw:UAC2Gadget`) —
#   the ALSA capture PCM opened by the Rust bridge. Older Python lab
#   paths used the PortAudio/sounddevice substring `UAC2_Gadget` (WITH
#   the underscore); keep that distinction in mind if temporarily
#   running the non-claiming Python bridge.
# JASPER_USBSINK_MIXER_CARD (default `UAC2Gadget`, NO underscore) —
#   the kernel short card name used by amixer / /proc/asound.
# They look like the same card but the kernel registers the two names
# differently; setting them to the same value breaks both tools.
#
# USB-input LATENCY tuning (lip-sync). For the claiming `usb_low_latency_48k`
# route, jasper-audio-hardware-reconcile writes these into
# /var/lib/jasper/usbsink.env from the route plan: Rust bridge, 256-frame
# periods, a bounded 2-3 period ring, and `aloop` output into fan-in. Do not set
# them in /etc/jasper/jasper.env for normal use; override only for a measured
# on-device sweep and confirm /state.audio_graph plus doctor before keeping it.
# JASPER_USBSINK_BLOCK_FRAMES (route default 256 ≈ 5.3 ms @48k) — ALSA period
#   size. The Rust bridge rejects non-48k/non-stereo settings for the claiming
#   route.
# JASPER_USBSINK_RING_PERIODS (route default 3) — bounded Rust bridge ring
#   depth. 2 is the only lower supported value; no unbounded queue exists in the
#   production bridge.
# JASPER_USBSINK_LATENCY (route default `low`) — label carried for diagnostics
#   and compatibility with older lab tooling.
# JASPER_USBSINK_OUTPUT_MODE (always `aloop`) — the Rust jasper-usbsink-audio
#   bridge has one delivery mode (the aloop fan-in lane). The route reconciler
#   records this in /var/lib/jasper/usbsink.env for route identity; the daemon
#   does not read it. There is no runtime flip and no other value.
#
# Stage 1 host-slaved USB clock (default-OFF; see
# docs/HANDOFF-usb-low-latency.md "Host-slaved USB clock"). The Pi's UAC2
# gadget exposes a writable ALSA ctl ("Capture Pitch 1000000") that both
# Windows and macOS honor dynamically: nudging it commands the HOST to
# speed up or slow down its USB audio clock, closing the standing rate
# offset a wired USB source otherwise accumulates against the Pi's own
# clock. Default OFF because it actively drives host behavior (not merely
# observes it) and needs a per-host compliance probe before being trusted;
# when unset/disabled the feature is entirely inert (only a one-time
# startup neutralize write runs, healing a stale pitch left by a crashed
# predecessor).
# JASPER_USBSINK_HOST_CLOCK (default unset = disabled) — master opt-in
#   gate. Only the exact literal `enabled` (case-insensitive) arms the
#   ladder (per-session compliance probe, DLL servo, ctl writes); any
#   other value logs a warning once and stays disabled, mirroring
#   JASPER_USBSINK_PREEMPT's literal-`disabled` idiom, inverted because
#   this feature is opt-in rather than opt-out.
# JASPER_USBSINK_HOST_CLOCK_TARGET_FILL_FRAMES (default 384 ≈ 8 ms, 1.5×
#   one 256-frame period) — the gadget capture ring fill (in frames) the
#   servo holds via commanded host pitch. Enforced range 128..4096 (a hard
#   safety bound at config-parse time — the daemon does not know the
#   configured ring depth yet at that point; a target below one period or
#   above a few periods is nonsensical for the 2-3 period ring regardless).
#   Out-of-range is rejected at daemon startup with a clear error rather
#   than silently clamped.
# JASPER_USBSINK_HOST_CLOCK_PROBE_PPM (default 300) — the commanded pitch
#   step (in ppm) used for the per-session compliance probe. Valid range
#   200..800. The floor (200) sits ABOVE the ~163 ppm reaction deadband
#   Windows' usbaudio2.sys applies to pitch feedback: a probe at or below
#   that deadband would measure ~no response on a compliant host and
#   falsely fail every session. The ceiling (800) keeps the probe inside
#   the ~±1000 ppm window commodity USB audio hosts treat as a valid pitch
#   command, with margin. (Even the default 300 leaves only modest margin
#   against a full-deadband subtraction — (300-163)/300 ~ 0.46 vs the 0.5
#   pass ratio — so a Windows host near the deadband edge may probe-fail
#   into L2; raise this toward 500-600 if a Windows lab box demotes
#   spuriously. macOS honors feedback without a deadband.)
# JASPER_USBSINK_HOST_CLOCK_PROBE_SECONDS (default 6) — duration of the
#   probe's step phase (a fixed 4 s neutral baseline phase runs first, so
#   the whole probe takes 4 s + this value = 10 s at the default, up to
#   14 s at the maximum). Valid range 5..10; long enough for a host's
#   fill-slope response to become measurable, short enough that a
#   non-compliant host doesn't audibly drift before the probe demotes it
#   to L2 (neutral pitch).

# ---- Adaptive fan-in output buffer (lab / legacy low-latency writer) ----
# fan-in's per-lane INPUT rings are WiFi-burst headroom (near-empty for a steady
# wired source, so NOT a latency lever); the OUTPUT buffer is the real one —
# fan-in's writei() blocks on the DAC-paced pull, so it runs near-FULL. The
# production output buffer is now 1024 frames (~21 ms @ 48 kHz), so this writer
# remains mainly for lab sweeps and for older deployments that still carry a
# larger persisted /var/lib/jasper/fanin.env value. When USB is the SOLE
# active/winning source and the gate below is enabled, jasper-mux writes the
# target into fanin.env; when any networked/mixed/idle/manual state returns it
# restores the packaged unit default by removing the override line. Changing it
# restarts the SHARED fan-in daemon (a brief all-source glitch on the
# transition), so the gate stays opt-in.
#
# JASPER_FANIN_ADAPTIVE_BUFFER (default unset = OFF) — opt-IN master gate.
#   Only the exact literal `enabled` (case-insensitive) turns it on; anything
#   else (unset, `disabled`, `1`, `true`) stays OFF and jasper-mux's tick is
#   byte-identical to today. Opt-IN polarity because it restarts the shared
#   summing daemon and must pass an on-device zero-xrun soak before going live.
# JASPER_FANIN_ADAPTIVE_SHRUNK_FRAMES (default 1024) — the output-buffer frame
#   count the lab writer targets. FLOOR 1024; the reconciler REJECTS a
#   below-floor value rather than clamping it, so a typo cannot persist a value
#   that only breaks on the next daemon restart. Exists so the soak can sweep
#   1024/1536/2048 without a redeploy. Written into the wizard-owned
#   /var/lib/jasper/fanin.env by jasper.fanin.buffer_reconcile (the single
#   writer of JASPER_FANIN_OUTPUT_BUFFER_FRAMES there), loaded by the unit AFTER
#   the Environment="...=1024" default so the override wins.
#
# JASPER_AUDIO_RUNTIME_OVERRIDES_PATH (default
#   `/var/lib/jasper/audio_runtime_overrides.json`) — path for the reasoned,
#   expiring lab override artifact used by jasper-audio-config overrides-* and
#   the runtime plan. Normal deployments leave this unset; set it only to test
#   against an alternate override file without editing the device profile,
#   generated env files, or packaged defaults.

# ---- fan-in → CamillaDSP coupling (low-latency endgame, default-OFF) ----
# The convergence endgame that supersedes the adaptive output-buffer shrink
# above once it soaks. Instead of fan-in writing the ALSA
# snd-aloop substream and CamillaDSP dsnoop-capturing it (~64 ms loopback ring +
# dsnoop hop), fan-in writes a bounded S32_LE stereo pipe into CamillaDSP
# RawFile capture, CamillaDSP writes its post-DSP S32_LE stereo program to a
# second local pipe, and outputd drains that pipe at the blocking DAC cadence.
# Camilla rate_adjust and async capture resampling are OFF in this mode: the
# pipes are transport only, and outputd's DAC write is the pace root. The fan-in
# mixer still does ALL its work (every renderer lane, TTS, ducking, the
# music-only tap); only the local program transport changes. Both Rust daemons
# (jasper-fanin, jasper-outputd) and the Python config generator
# (jasper.fanin_coupling) read these — they are the cross-language source of
# truth and MUST agree.
#
# JASPER_FANIN_CAMILLA_COUPLING (default unset = `loopback`) — the transport.
#   Three recognized tokens (case-insensitive): `loopback` (default),
#   `transport_pipe`, and `shm_ring` (the END-TO-END SHM ring — Ring A + Ring B;
#   see the ring keys below). The literal `transport_pipe` turns the end-to-end
#   pipe topology on. `shm_ring` is a FIRST-CLASS reconciler mode as of P2: arm it
#   (and its coherent outputd Ring B partner) with the product reconciler —
#   `jasper-fanin-coupling-reconcile shm_ring` (and `… loopback` to revert). Do
#   NOT set this by hand in isolation: the reconciler is the SINGLE writer of the
#   coherent pair (this key + JASPER_OUTPUTD_CONTENT_BRIDGE=shm_ring); a partial
#   flip (one end ring, the other loopback/direct) strands a ring and is
#   fail-closed by the doctor, the artifact binder, and the reconciler itself.
#   AS OF P4 (default-flip): the SHIPPED default on a solo, ring-eligible box is
#   now `shm_ring` — the boot/deploy pass `jasper-fanin-coupling-reconcile --auto`
#   resolves it (arming BOTH rings) when every #1169 arm preflight passes (ring
#   platform assets present, topology ring-eligible, geometry coherent), else it
#   resolves `loopback`. Ineligible boxes (roleful/composite/mono topology, or no
#   ring platform) stay loopback — the auto pass is a NO-OP there. This key still
#   fail-SAFE resolves to `loopback` on unset/typo, and loopback is BYTE-IDENTICAL
#   to today. The auto pass never touches this key when the operator marker below
#   is set.
# JASPER_FANIN_COUPLING_CHOICE (default unset = auto-owned) — the OPERATOR-CHOICE
#   marker (P4). Absence-vs-present, like JASPER_TRANSIT_CITIES: UNSET means the
#   `--auto` default-resolution pass OWNS the coupling + USB combo and resolves
#   them by eligibility; the single value `operator` means the operator made an
#   explicit choice (written automatically by the explicit
#   `jasper-fanin-coupling-reconcile <loopback|transport_pipe|shm_ring>` CLI path)
#   and the auto pass is a COMPLETE NO-OP so the choice STICKS across reboots and
#   deploys. Any other value is treated as NOT an operator choice (fail toward
#   auto-ownership so a typo never silently freezes a box off the default).
#
#   >>> TO REVERT a box off the new defaults and KEEP it reverted, set ALL of:
#   >>>   JASPER_FANIN_COUPLING_CHOICE=operator      (freeze — auto pass no-ops)
#   >>>   JASPER_FANIN_CAMILLA_COUPLING=loopback     (fan-in end: snd-aloop)
#   >>>   JASPER_OUTPUTD_CONTENT_BRIDGE=direct        (outputd end: snd-aloop)
#   >>>   (and set the USB combo flags to their OFF values —
#   >>>    JASPER_FANIN_USB_DIRECT=disabled /
#   >>>    JASPER_FANIN_HOST_CLOCK=disabled /
#   >>>    JASPER_FANIN_RESAMPLER_CUSHION_DECAY=disabled in fanin.env, and
#   >>>    JASPER_USBSINK_AUDIO_STANDBY=0 in /var/lib/jasper/usbsink.env)
#   >>> in /var/lib/jasper/fanin.env + /var/lib/jasper/outputd.env +
#   >>> /var/lib/jasper/usbsink.env, then restart jasper-fanin + jasper-outputd +
#   >>> jasper-usbsink. The auto pass will NEVER override these.
#   >>> IMPORTANT: prefer the explicit OFF value (`disabled` / `0`) over UNSETTING
#   >>> the key. jasper.env is loaded BEFORE these wizard-owned files, so if a stale
#   >>> `JASPER_FANIN_USB_DIRECT=enabled` (or `JASPER_USBSINK_AUDIO_STANDBY=1`) is in
#   >>> /etc/jasper/jasper.env, merely UNSETTING it in fanin.env/usbsink.env leaves
#   >>> the jasper.env `enabled` standing — the explicit `disabled`/`0` in the
#   >>> later-loaded file overrides it. (The auto pass writes these explicit off
#   >>> values for the same reason.)
#   >>> The one-shot operator path does this for you PARTIALLY: running
#   >>> `jasper-fanin-coupling-reconcile loopback` stamps the marker AND flips the
#   >>> coherent pair back — but it does NOT touch the USB combo (set those off by
#   >>> hand if you also want the combo off).
# JASPER_FANIN_CAMILLA_PIPE (default `/run/jasper-fanin/camilla.pipe`) — the
#   named pipe fan-in writes and CamillaDSP RawFile-captures under
#   `transport_pipe`. tmpfs, producer-owned (fan-in creates it; CamillaDSP opens
#   it read-only). Only consulted under `transport_pipe`.
# JASPER_OUTPUTD_LOCAL_CONTENT_PIPE (default
#   `/run/jasper-outputd/content.pipe`) — the second named pipe, written by
#   CamillaDSP's File playback and read by jasper-outputd. Normally written to
#   /var/lib/jasper/outputd.env by jasper-fanin-coupling-reconcile so fan-in,
#   Camilla, and outputd arm together; override only for a deliberate soak path.
# JASPER_OUTPUTD_LOCAL_CONTENT_PIPE_BYTES (default 8192) — the requested
#   Camilla->outputd pipe size (F_SETPIPE_SZ). Keep this small: outputd reads
#   one S32_LE stereo period per DAC period, and this FIFO is transport, not a
#   staging buffer. Doctor fails transport_pipe when the actual pipe or queued
#   bytes grow large enough to hide latency. Only consulted under
#   `transport_pipe`.
# JASPER_FANIN_CAMILLA_PIPE_BYTES (default 8192) — the requested write-end pipe
#   buffer size (F_SETPIPE_SZ). The kernel rounds up to a power-of-two ≥ page
#   size; the daemon logs requested vs actual (event=fanin.fifo.pipe_sized).
#   Small on purpose so the pipe stays DAC-paced — it is the FIFO equivalent of
#   the snd-aloop output ring depth. Exists so the soak can sweep
#   4096 -> 8192 -> 16384 without a redeploy. Only consulted under
#   `transport_pipe`.
#
# SHM-ring keys. Only consulted when the matching `shm_ring` flag is armed
# (Ring A = JASPER_FANIN_CAMILLA_COUPLING=shm_ring; Ring B =
# JASPER_OUTPUTD_CONTENT_BRIDGE=shm_ring). The product path arms BOTH together
# via the auto/default reconciler or `jasper-fanin-coupling-reconcile shm_ring`;
# scripts/ring-proto/ can still arm ONE ring in isolation for lab measurement.
# While the flag is unset these keys are inert. The Rust daemons (jasper-fanin /
# jasper-outputd) and the Python config generator (jasper.fanin_coupling)
# resolve each absent key to the SAME default, so producer and consumer never
# drift; the ring header's own on-disk validation is the runtime fail-loud
# backstop.
# JASPER_OUTPUTD_CONTENT_BRIDGE (default `direct`) — outputd's content source.
#   `direct` (snd-aloop content lane, the default), `shm_ring` (Ring B — outputd
#   reads content.ring, the coherent partner of Ring A), or `rate_match`
#   (a separate deferred lab bridge, NOT part of the shm_ring coupling). Written
#   to /var/lib/jasper/outputd.env by jasper-fanin-coupling-reconcile so it flips
#   coherently with the fan-in coupling; do not hand-set it out of step.
# JASPER_FANIN_RING_PATH (default `/dev/shm/jts-ring/program.ring`) — Ring A SHM
#   file: fan-in creates it and writes the summed program; CamillaDSP reads it
#   via the `jts_ring` ioplug capture. tmpfs, producer-owned.
# JASPER_FANIN_RING_SLOTS (default 2) — Ring A slot count. Ring A is the
#   fan-in -> CamillaDSP program.ring. The product default is the
#   hardware-validated latency floor: 2 x 128 frames ≈ 5.3 ms at 48 kHz, versus
#   the old 8-slot placeholder's ≈21 ms. Raise this only to absorb a measured
#   ring-underflow / attach-stability issue, and update the matching
#   jts_ring_capture `n_slots` in the ALSA conf.d at the same time. Present-but-
#   out-of-range values fail loud (ValueError / anyhow::bail! on both sides — no
#   clamp). Must match the ioplug conf.d geometry (the drift axis with the
#   capture dev).
# JASPER_OUTPUTD_SHM_RING_PATH (default `/dev/shm/jts-ring/content.ring`) — Ring
#   B SHM file: CamillaDSP writes the post-DSP program via the ioplug playback;
#   jasper-outputd reads one slot per DAC period. tmpfs, survives outputd restarts.
# JASPER_OUTPUTD_SHM_RING_SLOTS (default 2, range 2..16) — Ring B slot count;
#   2 is the ping-pong floor. Out-of-range fails loud (no clamp).

# ---- USB low-latency combo (P3 default on gadget boxes with USB audio on) ---
# The certified USB-in low-latency combo is FOUR flags across TWO files that arm
# together. THREE are fan-in flags in fanin.env: JASPER_FANIN_USB_DIRECT (fan-in
# owns the hw:UAC2Gadget capture directly), JASPER_FANIN_HOST_CLOCK (fan-in steers
# the gadget pitch ctl — see the combo-mode block below), and
# JASPER_FANIN_RESAMPLER_CUSHION_DECAY (the post-lock cushion decay — see the
# cushion-decay block below). The FOURTH is JASPER_USBSINK_AUDIO_STANDBY in
# usbsink.env (the usbsink bridge stands down so it stops holding hw:UAC2Gadget —
# WITHOUT it, fan-in's direct capture and the still-live bridge fight over the
# gadget and USB audio goes silent / crash-loops). Each fail-safes to OFF (fan-in
# keys arm only on the literal `enabled`; the standby key arms only on the literal
# `1`; case-insensitive; the Rust jasper_fanin::config / jasper-usbsink-audio
# parsers).
#
# AS OF P3 (default-flip): the boot/deploy pass `jasper-fanin-coupling-reconcile
# --auto` arms the combo ONLY on a box that BOTH (a) has the gadget stack available
# (`dtoverlay=dwc2,dr_mode=peripheral` in /boot/firmware/config.txt — added
# fleet-wide for the always-on USB network, so NOT a sufficient gate alone) AND
# (b) has USB Audio Input turned ON by the household (`jasper-usbsink.service`
# enabled — the same intent the /sources/ toggle owns). When armed it WRITES the
# three fan-in keys `=enabled` into fanin.env AND `JASPER_USBSINK_AUDIO_STANDBY=1`
# into usbsink.env, then restarts jasper-usbsink. Off a combo box it writes the
# EXPLICIT off values (`disabled` / `0`, NOT unset — a stale `enabled` in the
# earlier-loaded jasper.env would otherwise win). The reconciler is the SINGLE
# writer of this set across BOTH files (mirrors jasper-aec-reconcile owning the
# mic-device vars); do NOT hand-append them to /etc/jasper/jasper.env. To revert a
# box off the combo, set the operator marker (JASPER_FANIN_COUPLING_CHOICE=operator
# — the auto pass then no-ops) and set the four keys to their off values; see the
# revert block under JASPER_FANIN_CAMILLA_COUPLING.
#
# ---- USB DIRECT gadget capture geometry (fan-in; lab lever) -------------
# JASPER_FANIN_USB_DIRECT_PERIOD_FRAMES (default 256, range 32..=1024) — the
#   gadget capture OPEN period, in frames, that the USB DIRECT lane negotiates
#   on hw:UAC2Gadget. This is LEVER 2 of the USB low-latency plan (the H1
#   "hw-pointer / period-granularity" test knob). WHAT it does: sets the ALSA
#   period the direct capture opens with; the capture BUFFER is derived from it
#   and always stays DEEP (>= 3 periods AND >= 768 frames, period-aligned) — so a
#   small period rides a deep buffer, NOT the refuted shallow 2-period URB-
#   headroom failure. WHY: the ~186-frame (3.9 ms) standing gadget avail we
#   measured is consistent with the u_audio pointer advancing in period-sized
#   steps; if so, a smaller open period exposes ready frames sooner and cuts the
#   dwell. WHEN to touch: this is a LAB lever, not a household knob. Unset (=256)
#   is byte-identical to today's bridge-proven envelope. The H1 experiment sets
#   64 and watches the STATUS `inputs[].direct.drain_avail` block (mean/max/hist)
#   for a lower mean AND `inputs[].direct.xrun`/fanin.xrun for ZERO new capture
#   xruns. Out-of-range values fail loud at startup (anyhow::bail!). Only
#   consulted on the direct lane (JASPER_FANIN_USB_DIRECT=enabled); parsed on
#   every boot so a typo fails loud regardless. NOTE: "byte-identical" here means
#   the ALSA open REQUEST is unchanged when unset — the same period/buffer_near
#   arguments. The post-negotiation ACCEPTANCE floor did tighten alongside this
#   knob (>= 3 periods AND >= 768 frames, was >= 2 periods): a hypothetical
#   negotiation to 512..767 frames that the old code would have accepted with a
#   `buffer_near` warn now sends the lane Absent. This is deliberate deep-buffer
#   doctrine (fail-loud beats running the refuted shallow class), and u_audio has
#   always negotiated exactly 768 at period 256, so the tightening is inert in
#   practice. See docs/HANDOFF-usb-low-latency.md and the lever-2 plan.
#
# ---- Combo-mode host-slaved USB clock (fan-in; default-OFF) -------------
# The SAME host-slaved USB clock as the solo-mode usbsink Stage 1 above
# (JASPER_USBSINK_HOST_CLOCK), but driven by fan-in in COMBO mode. When USB
# DIRECT is armed (JASPER_FANIN_USB_DIRECT=enabled + JASPER_USBSINK_AUDIO_STANDBY=1),
# fan-in — not the usbsink bridge — owns the hw:UAC2Gadget capture, so per the
# invariant "the daemon that owns the gadget capture owns the pitch ctl" fan-in
# must be the one steering the gadget's "Capture Pitch 1000000" ctl. A dedicated
# `fanin-host-clock` thread runs the shared jasper_host_clock ladder (byte-
# identical servo to solo mode), pinning the DIRECT lane's resampler fill at
# target so the drift wander (~500 f observed at 5 min vs the 256 target) is
# removed. Default OFF because it actively drives host behavior and needs a
# per-host compliance probe; when unset/disabled the thread is not even spawned
# (a one-time startup neutralize still runs iff armed, healing a stale pitch).
# Meaningful ONLY with USB DIRECT: `enabled` with direct OFF logs one
# `event=fanin.host_clock.noop reason=usb_direct_off` and stays fully inert (no
# ctl writes ever) — in aloop mode the usbsink bridge owns the clock.
# See docs/HANDOFF-usb-low-latency.md "USB DIRECT (combo mode)".
# JASPER_FANIN_HOST_CLOCK (default unset = disabled) — master opt-in gate.
#   Only the exact literal `enabled` (case-insensitive) arms it; any other
#   non-empty value logs a warning once
#   (event=fanin.host_clock_config_ignored) and stays disabled (mirrors
#   JASPER_USBSINK_HOST_CLOCK's literal idiom).
# JASPER_FANIN_HOST_CLOCK_PROBE_PPM (default 300) — the commanded pitch step
#   (in ppm) for the per-session compliance probe. Valid range 200..800,
#   identical to usbsink's JASPER_USBSINK_HOST_CLOCK_PROBE_PPM: the floor (200)
#   sits above the ~163 ppm Windows usbaudio2.sys reaction deadband (a probe at
#   or below it would falsely fail every session on a compliant host), and the
#   ceiling (800) keeps the probe inside the ~±1000 ppm validity window with
#   margin. Out-of-range is rejected at daemon startup with a clear error.
# JASPER_FANIN_HOST_CLOCK_PROBE_SECONDS (default 6) — parsed and range-validated
#   (5..10) identically to usbsink's JASPER_USBSINK_HOST_CLOCK_PROBE_SECONDS, but
#   NOTE: fan-in always runs the CORRECTION observable, whose probe step phase is
#   held for a longer FIXED window (CORRECTION_PROBE_STEP_SECS = 15 s in
#   jasper-host-clock) because the inner-resampler correction signal is slower to
#   slew than the gadget-fill slope. So this env value sets the step duration only
#   in FILL mode (usbsink solo); in fan-in COMBO mode it is validated but does not
#   change the 15 s correction-probe step. The 4 s neutral baseline runs first in
#   both modes.
# (No target env: the setpoint is derived — it is the DIRECT lane resampler's
#  HELD target, JASPER_FANIN_INPUT_RESAMPLER_TARGET_FRAMES +
#  JASPER_FANIN_INPUT_RESAMPLER_WARMUP_CUSHION_FRAMES — one setpoint shared with
#  the inner rate controller, so no second knob fights it.)
#
# ---- Post-lock cushion decay (latency lever 1; fan-in; default-OFF) ------
# The acquisition warm-up cushion (JASPER_FANIN_INPUT_RESAMPLER_WARMUP_CUSHION_
# FRAMES) is load-bearing only during the bursty USB cold start: once the lane
# is locked AND the host-clock DLL has pinned the fill at the setpoint, that
# cushion is standing latency (~10 ms) the steady state does not need. A static
# lower cushion was refuted twice on hardware (free-run never locks; under the
# live DLL it locks but latency REGRESSES from lock churn). So decay it: hold the
# full cushion through acquisition, then — ONLY while locked AND the DLL is
# l0_locked AND stable AND not commanding hard — lower the HELD target one small
# step at a time toward a floor, and snap all the way back to the ceiling the
# instant lock/l0 is lost (a raised setpoint refills naturally from input, no
# glitch). The DLL setpoint tracks this LIVE held target (single source of truth
# = the resampler's held_target gauge), so the two controllers never disagree.
# Meaningful ONLY with the host-clock DLL armed (decay requires l0_locked).
# JASPER_FANIN_RESAMPLER_CUSHION_DECAY (default unset = disabled) — master
#   opt-in gate. Only the exact literal `enabled` (case-insensitive) arms it;
#   anything else stays OFF (held target pinned at the acquisition ceiling,
#   byte-identical to today).
# JASPER_FANIN_RESAMPLER_CUSHION_DECAY_FLOOR_FRAMES (default 576, clamped into
#   [max(TARGET_FRAMES, minimum_safe_fill) + 32, acquisition ceiling]) — the total
#   held-target floor the decay descends to. The SHIPPED default is the hardware-
#   VALIDATED floor 576 (the jts.local combo-armed product-path gate value at
#   target 512 / period 256 / ±500 ppm — P3 default-coherence), NOT a bare
#   `target + 32`. It is clamped: never below the hard minimum
#   `max(target, minimum_safe_fill) + 32` (= 544 at the default geometry — the
#   armed guard rejects a floor under this), never above the acquisition ceiling
#   (target + warmup cushion; a small-cushion geometry whose ceiling < 576 lands at
#   its ceiling). An explicit value must sit in that same
#   [max(target, minimum_safe_fill) + 32, ceiling] range. The 32-frame ≈ 0.67 ms
#   working cushion is what the DLL always keeps above whichever anchor binds.
#   `minimum_safe_fill = ceil(period × (1 + max_ppm/1e6)) + 16 + 1` (= 274 at
#   period 256 / ±500 ppm) is the PHYSICAL underfill-unlock threshold: a floor
#   at/below it thrashes lock every period (churn-by-construction), so for a small
#   base target the hard minimum is pinned to the physical floor, not `target + 32`.
#   Out-of-range is rejected at daemon startup WHEN THE FEATURE IS ARMED (a stale
#   floor on a decay-OFF box never blocks boot). Shipping 576 (not 544) means a
#   default-flip box (P3/P4) that arms the combo with no explicit floor lands on
#   the exact floor the gate proved stable and constructs cleanly.
#   The SAME physical threshold guards the STATIC held target: whenever a
#   resampler is armed (JASPER_FANIN_INPUT_RESAMPLER=enabled or implied by
#   JASPER_FANIN_USB_DIRECT=enabled), the daemon fails loud at startup unless
#   `TARGET_FRAMES + WARMUP_CUSHION_FRAMES >= minimum_safe_fill + period + 32`.
#   Below that, the steady post-render fill sits on the unlock threshold and
#   ordinary USB delivery coalescing thrashes lock→silence→relock (the fan-in
#   unlock-churn diagnosis, 2026-07). The shipping defaults (512 + 2048 = 2560)
#   clear it by ~2030 frames; a hand-tuned lab geometry (e.g. 256 + 256 = 512)
#   trips it. At period 256 / ±500 ppm the minimum passing HELD target is
#   274 + 256 + 32 = 562, so the lab 256-target route needs WARMUP_CUSHION_FRAMES
#   >= 306 (or a larger TARGET_FRAMES so target+cushion >= 562), OR a lower
#   max_ppm / period. Because the guard bails at startup and jasper-fanin.service
#   reboots on repeated start failure, bump a box already running the churny
#   256+256 geometry to cushion >= 306 BEFORE deploying, or it will reboot-loop.
# JASPER_FANIN_RESAMPLER_CUSHION_DECAY_STEP_FRAMES (default 18) — frames dropped
#   from the held target per decay step. Valid range 1..64. Why 18 (raised from
#   the original 16): the ~2.5-min floor descent is paced by step / interval, so a
#   slightly larger step shortens it proportionally (18 vs 16 ≈ 12 % faster). 18
#   frames per 1000 ms ≈ 375 ppm of demanded rate — 25 ppm INSIDE the ±400 ppm
#   cascade-stability guard, so the decay still pauses before it can perturb the
#   DLL cascade. The 2026-07-03 jts.local hardware pass REFUTED 64 (it rails the
#   ±500 ppm inner authority); 18 is the measured sweet spot. Below the DLL's
#   ±adjust authority so a step is absorbed by the loop, not forced as a trim
#   glitch.
# JASPER_FANIN_RESAMPLER_CUSHION_DECAY_INTERVAL_MS (default 1000) — wall interval
#   between decay steps (converted to render periods by the lane). Valid range
#   250..10000.
# JASPER_FANIN_HOST_COMPLIANCE_PATH (default /var/lib/jasper/fanin/host_compliance.json)
#   — the persistence file for the prime-at-floor authority (rides the cushion-
#   decay flag above; no separate top-level gate). Once a session PROVES the host
#   honours the pitch command AND the decay has walked the held target all the way
#   to the floor with zero unlock churn AND l0 held for a settle window, a small
#   JSON proof {schema, proved_at_epoch_s, probe_response_ratio, floor_frames,
#   consecutive_failures} is written here (atomic tempfile+rename, world-readable
#   0644). The NEXT session primes the resampler AT the decay floor instead of
#   descending from the ceiling — skipping the ~2.5-min descent otherwise paid at
#   every session start. The servo's per-session probe (#1142's post-lock lock
#   gate) is the immediate revalidation: a floor-primed session that fails the
#   probe, has its DLL demoted, or underfill-unlocks in its first 60 s snaps the
#   held target back to the ceiling and DELETES the proof (one strike → fail toward
#   safety); the normal descent then re-proves. USB re-enumeration / a new host /
#   a new port needs NO special handling — a new session simply re-probes, and the
#   probe verdict is what revalidates. A missing / corrupt / stale-geometry file
#   means "no proof" (descend as today) — never a crash, never a stale prime. Only
#   CONSULTED when the cushion decay is armed; on a decay-off box this is inert.
#   The file rides fan-in's already-owned /var/lib/jasper write (the xrun-log
#   dir) — no new StateDirectory / privilege grant. STATUS surfaces it at
#   /state.audio_graph.fanin ... resampler.compliance
#   {flag_present, proved_at, revoked_reason_last}.
# See docs/HANDOFF-usb-low-latency.md "Post-lock cushion decay (lever 1)" +
# "Host-compliance persistence — prime at floor".

# ---- Observability ------------------------------------------------------
# JASPER_FLIGHT_RECORDER opts a daemon OUT of the in-RAM DEBUG log
# flight recorder (the ring buffer dumped to the journal as
# `event=flightrec.dump` when an anomaly fires — see
# docs/HANDOFF-observability.md). Set JASPER_FLIGHT_RECORDER=disabled
# to fall back to the plain logger-level path; any other value (or
# unset, the code default) leaves the recorder on. Deliberately not
# assigned here: on is the right default everywhere, this exists only
# as an escape hatch if the ring's overhead is ever implicated on a
# hot audio path.
#
# JASPER_LOG_JSON switches structured `event=` lines (emitted via
# jasper.log_event.log_event) from logfmt to one JSON object per line
# — `{"event":"domain.action", ...}` instead of
# `event=domain.action k=v ...`. Default (unset / not truthy) is
# logfmt: it stays grep-friendly and matches the journal shape every
# scripts/*-logs.sh helper and HANDOFF query already assumes, so leave
# this off for normal operation. Set JASPER_LOG_JSON=1 only when a
# log-shipping/aggregation pipeline that wants machine-parseable JSON
# is consuming the journal. Truthy values: 1/true/yes/on/enabled
# (case-insensitive), matching the rest of JTS's boolean env knobs.
# Migration to log_event is incremental, so this currently affects the
# already-migrated emitters (e.g. the HID accessory `knob.*` lines and
# `wifi_scan_repair.*`); unmigrated hand-written event lines stay
# logfmt regardless.

# ---- Disk-pressure observability ----------------------------------------
# A full SD card is the corruption hazard the whole resilience ladder
# exists to survive: a write failure on a near-full root partition, then
# an unclean power-cut, can leave ext4 needing recovery (worst case, an
# unbootable Pi). jasper-doctor's `check_disk_space` warns/fails on
# root-filesystem fullness, and /state.resilience.disk surfaces the live
# percent-used so a filling card is visible before the doctor is run.
# The two storage-size checks below are READ-ONLY warnings — they report
# growth so you can prune, they never delete a household's data.
#
# JASPER_DISK_WARN_PERCENT — root-fs %used at which check_disk_space
#   WARNs. Default 85. The FAIL threshold is a fixed 95% (the
#   "writes are about to fail" line, not a preference) and always takes
#   precedence, so a value <=0 or >=95 is ignored and snaps back to 85.
#   Lower it on a tiny SD card if you want earlier warning; most
#   installs want the default.
# JASPER_CORRECTION_STORAGE_WARN_BYTES — total bytes under
#   /var/lib/jasper/correction/sessions/ at which check_correction_storage
#   WARNs. Default 536870912 (512 MiB). Room-correction runs keep sweeps,
#   captures, and optional raw audio; un-pruned sessions accumulate.
#   Raise it if you intentionally keep many calibration bundles.
# JASPER_WAKE_EVENTS_STORAGE_WARN_BYTES — total bytes under
#   /var/lib/jasper/wake-events/ at which check_wake_events_storage WARNs.
#   Default 1363148800 (1.3 GiB) — comfortably ABOVE the 1 GiB
#   JASPER_WAKE_EVENTS_MAX_AUDIO_BYTES audio cap so a healthy oldest-first
#   ring never warns; a breach means the ring drifted well past its cap
#   (reaper wedged, or the cap was raised and forgotten).
# All three are deliberately unset here — the code defaults are right for
# every install; set one only if your SD card or retention needs differ.

# --- Phone-mic capture relay (cloud transport for browser mic capture) -------
# JASPER_CAPTURE_RELAY_BASE — the https origin of the Cloudflare relay Worker
#   the Pi pulls phone-mic captures from. Fresh installs default to Jasper Tech's
#   shared Cloudflare relay because mobile browsers only grant getUserMedia
#   microphone access to secure contexts with a publicly trusted HTTPS
#   certificate; a LAN Pi with a self-signed cert is fragile on iOS and blocked
#   for mic access by Android Chrome. The relay lets the phone record on
#   https://capture.jasper.tech while the Pi stays LAN-only and pulls encrypted
#   captures over outbound HTTPS.
#   Self-hosters can deploy the same Cloudflare code from relay/ and
#   capture-page/; see relay/README.md, capture-page/README.md, and
#   docs/phone-mic-relay-plan.md. Override this value for your own Worker. To
#   intentionally keep the older on-Pi same-origin capture path across installs,
#   set this to disabled (also accepts off/0/none); leaving it blank is treated
#   as stale legacy config and the installer restores this public default.
#   Otherwise it must be https://.
JASPER_CAPTURE_RELAY_BASE=https://relay.jasper.tech
# JASPER_CAPTURE_ORIGIN — the trusted capture-page origin the phone tap-link
#   points at. Fresh installs use Jasper Tech's Cloudflare Pages capture page.
#   If you set JASPER_CAPTURE_RELAY_BASE for a self-hosted relay, set this to
#   your capture page's host too. Only consulted on the relay capture path.
JASPER_CAPTURE_ORIGIN=capture.jasper.tech
# JASPER_CAPTURE_RELAY_REGISTRATION_TOKEN — optional Pi-side shared secret for
#   minting relay sessions. It must match the Cloudflare Worker secret
#   RELAY_REGISTRATION_TOKEN; when the Worker secret is set, POST /sessions
#   rejects Pis without this value. Jasper Tech's public default relay is
#   intended to work without committing a fleet secret here; self-hosters who set
#   a Worker secret should set the matching Pi value from private deploy state
#   (.env.local / shell env), never by committing a real token here. Leave blank
#   for a relay that intentionally allows open registration.
JASPER_CAPTURE_RELAY_REGISTRATION_TOKEN=
# JASPER_CAPTURE_ALIGNMENT_THRESHOLD — cross-correlation alignment-confidence
#   gate (0..1) below which a phone-mic capture is rejected as
#   weak/ambiguous (jasper.capture_relay.alignment). Default 0.40 is a
#   conservative v1 starting point, NOT empirically derived; tune it against
#   real on-device sweeps once you have them — set it here, no rebuild needed.
#   Out-of-range / unparseable values fall back to 0.40.
#
# --- Level-match ramp (P2, jasper.audio_measurement.ramp) ---
#   The relay-closed level-match ramp raises CamillaDSP main_volume from quiet
#   until the phone-reported mic level settles inside a safe window, then locks.
#   Every threshold below is a CONSERVATIVE PLACEHOLDER, not empirically derived
#   — H1 (on-device settle-cadence + iOS/Android AGC tuning) supplies the real
#   numbers. Set them here once measured; no rebuild needed. Out-of-range or
#   unparseable values fall back to the documented default, and a COMBINATION of
#   individually-valid values that fails cross-field validation (e.g. window low
#   raised above window high, or a settle hold below the loop latency) is dropped
#   as a whole with a warning — a jasper.env edit can never brick the ramp. The
#   safety timeout is DERIVED from these knobs (the config's own worst-case
#   walk), so slowing the ramp automatically lengthens the backstop. Note: these
#   are ramp control-loop knobs; the operative volume ceiling is the lower of
#   original+12 dB and -3 dBFS main_volume. It never floors a quiet listening
#   setting upward, and the independent 0 dB hard clamp in camilla.py remains
#   absolute. The phone clipping abort, feed-liveness guard, and exact restore
#   remain active regardless of these values.
# JASPER_RAMP_WINDOW_LOW_DBFS — bottom of the safe mic-level target window, dBFS
#   (-60..0). The coarse staircase stops-ahead BELOW this bound; the settled
#   jump aims at the window midpoint. Default -20.
JASPER_RAMP_WINDOW_LOW_DBFS=
# JASPER_RAMP_WINDOW_HIGH_DBFS — top of the safe mic-level target window, dBFS
#   (-60..0). Must be above the low bound. Default -12.
JASPER_RAMP_WINDOW_HIGH_DBFS=
# JASPER_RAMP_TRUST_MARGIN_DB — a mic reading is only trusted once it clears
#   noise_floor + this many dB (0..40); below it the level is ambient-dominated.
#   Default 10.
JASPER_RAMP_TRUST_MARGIN_DB=
# JASPER_RAMP_SETTLE_HOLD_S — after the level crosses the pre-window the ramp
#   freezes and holds at least this long (0..30 s) so the relay transport delay
#   has elapsed before the settled level is read; the hold EXTENDS itself until
#   the settle buffer has enough post-latency samples. Must be >= the max loop
#   latency. Default 2.0.
JASPER_RAMP_SETTLE_HOLD_S=
# JASPER_RAMP_MAX_LOOP_LATENCY_S — modeled worst-case phone->relay->Pi round trip
#   including the phone's sampling block (0..30 s). Bounds the coarse-staircase
#   overshoot; the config REJECTS a ramp whose step + rate*latency would reach
#   half the window width. Default 2.0.
JASPER_RAMP_MAX_LOOP_LATENCY_S=
# JASPER_RAMP_CONFIRM_K — consecutive in-window trusted samples required before
#   the level is locked (floor 2, max 20; the spec's default is 3 — a single
#   sample is never accepted as "consecutive confirmation"). Default 3.
JASPER_RAMP_CONFIRM_K=
# JASPER_RAMP_SETTLE_MIN_SAMPLES — minimum post-latency samples in the settle
#   buffer before its median is trusted as the gain map (1..10). One sample is
#   too noise-prone to aim a volume jump with. Default 3.
JASPER_RAMP_SETTLE_MIN_SAMPLES=
# JASPER_RAMP_FEED_TIMEOUT_S — if NO phone samples at all arrive for this long
#   (2..60 s), the phone is considered gone and the ramp aborts + restores (a
#   vanished phone also has no clip protection — never blind-climb). Default 8.
JASPER_RAMP_FEED_TIMEOUT_S=
# JASPER_RAMP_CAP_BUMP_DB — maximum automatic rise above the user's listening
#   main_volume (0..24 dB). The ramp still begins at its quiet floor and climbs
#   gradually; this only sets its dynamic stopping point. Default 12, raised
#   after the 2026-07-11 JTS3 UMIK-2 run proved +6 dB could remain below the
#   measurement window with substantial digital headroom left.
JASPER_RAMP_CAP_BUMP_DB=
# JASPER_RAMP_CAP_CEIL_DB — absolute automatic-ramp ceiling (-30..0 dBFS
#   main_volume). The operative cap is the lower of this and original+bump;
#   CamillaDSP's independent 0 dB hard ceiling still applies. Default -3.
JASPER_RAMP_CAP_CEIL_DB=
# JASPER_RAMP_DRIFT_UNIFORM_DB — |mean per-band dB shift| above this (same
#   geometry, all bands within the band tolerance of the mean) flags an amp/volume
#   move and offers re-level (0..24). Computed on RAW pre-normalize band levels.
#   Default 3.0.
JASPER_RAMP_DRIFT_UNIFORM_DB=
# JASPER_RAMP_DRIFT_BAND_TOL_DB — max per-band deviation from the mean shift for a
#   change to count as UNIFORM (an amp move) rather than acoustic (0..24). A large
#   mean shift with scatter beyond this reports "level shift suspected", never
#   "consistent". Default 2.0.
JASPER_RAMP_DRIFT_BAND_TOL_DB=

# --- P4 deterministic verify-acceptance verdict (jasper/correction/acceptance.py)
# After a correction is applied and re-measured, deterministic code decides
# accept / surface / auto-revert (revision plan §4 P4). These thresholds are the
# statistical guard against reverting a good correction on measurement noise —
# the "before" is an N-position average, the verify is one seat, and 4-6 dB
# seat-to-seat std is NORMAL. All defaults are CONSERVATIVE PLACEHOLDERS seeded
# from correction/spatial.py's std constants; H1 retunes them from real
# on-device repeatability data (revision plan §5 H1). Out-of-range or
# unparseable values fall back to the documented default — an env edit can never
# brick the evaluator.
# JASPER_ACCEPT_BAND_REGRESSION_DB — a 1/3-octave band counts as "clearly worse"
#   only if its error-to-target grew by more than this many dB (0.5..24). Seeded
#   from the MEDIUM (looser) seat-to-seat std floor, deliberately: auto-revert is
#   the one automatic action against the user's applied choice, so its trigger
#   clears the generous end of the repeatability band. Default 6.0.
JASPER_ACCEPT_BAND_REGRESSION_DB=
# JASPER_ACCEPT_OVERALL_RMS_REGRESSION_DB — the overall band-RMS error-to-target
#   must worsen by more than this to count toward a clear regression (0.1..12).
#   Smaller than the per-band knob: RMS over many bands averages out per-band
#   noise, so a real whole-curve regression shows at a lower dB. A clear
#   regression needs BOTH this AND a band clearing the per-band floor. Default 1.0.
JASPER_ACCEPT_OVERALL_RMS_REGRESSION_DB=
# JASPER_ACCEPT_OVERALL_RMS_IMPROVEMENT_DB — to call an ACCEPT (not merely
#   "surface"), the overall band-RMS error must have improved by at least this
#   much (0..12); below it the result is an honest "surface", neither revert nor
#   a claimed win. Must stay below the per-band regression floor. Setting 0
#   opts into accept-on-tie (an exactly-zero delta reads "confirmed improved")
#   — keep it > 0 unless that is deliberate. Default 0.5.
JASPER_ACCEPT_OVERALL_RMS_IMPROVEMENT_DB=
# JASPER_ACCEPT_SMOOTHING_FRACTION — fractional-octave band width for the
#   per-band verdict (1..6). 3 = 1/3-octave (the plan's ">=1/3-octave" floor,
#   the audiometric standard). Do NOT raise past ~6 without re-deriving the
#   repeatability floor — finer bands carry a higher per-band std. Default 3.
JASPER_ACCEPT_SMOOTHING_FRACTION=
