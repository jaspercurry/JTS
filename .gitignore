__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example
# .env.local for laptop-side voice-eval — gitignored to keep
# API keys out of the repo. See tests/voice_eval/README.md.
.env.local
.pytest_cache/
.ruff_cache/
build/
dist/
target/
*.onnx
*.tflite
.vscode/
.idea/
.DS_Store
# Pi log fetches — never commit log dumps (may contain transient
# state / device serial numbers etc.)
logs/*
!logs/.gitkeep

# Test recordings from satellite mic captures — large binaries,
# regenerate via scripts/capture-satellite-amoled.sh.
captures/

# Phase 1.3 mic validation outputs — corpus, raw recordings, CSVs.
# Throwaway artifacts of jasper.cli.satellite_validation; regenerate
# rather than commit. Whole tree is deletable post-validation.
phase1_3/

# Voice-eval harness artifacts:
# - audio_cache/: OpenAI TTS-synthesized prompt WAVs (regenerate
#   from text on first run, cached by sha256 — no need to ship)
# - transcripts_out/: per-trial markdown + response WAV. Run-local.
# - traces_out/: per-trial JSONL traces. Run-local.
tests/voice_eval/audio_cache/*
!tests/voice_eval/audio_cache/.gitkeep
tests/voice_eval/transcripts_out/*
!tests/voice_eval/transcripts_out/.gitkeep
tests/voice_eval/traces_out/*
!tests/voice_eval/traces_out/.gitkeep
wake-events/

# Per-session scratch and WIP files used by Claude Code agents.
# Use `.claude/*` not `.claude/` so re-include below actually works —
# git can't un-ignore a file inside a fully-ignored parent directory.
.claude/*
# Slash commands ARE checked in — they're how users invoke flows
# like /onboard-pi.
!.claude/commands/
!.claude/commands/**

# Per-laptop active-Pi marker, written by scripts/onboard.sh. Loaded
# into Claude Code's context via CLAUDE.md's @-import directive.
CLAUDE.local.md

# Reference voice recordings (whisper/yell/music/fast/slow) used as
# the stable A/B baseline for AEC engine + wake-word model swaps.
# User-specific audio; never ship to the repo.
reference-conditions/

# AEC3 v2.1 deep-tune spike — locally-built pybind11 extension
experiments/aec3-v2-deep-tune-spike/*.so
experiments/aec3-v2-deep-tune-spike/*.dylib
